target		:molecular-protocol/{molecular_protocol_id} a dwc:MolecularProtocol ; dwc:assayType {assay_type}^^xsd:string ; gbif:pcr_primer_forward {pcr_primer_forward}^^xsd:string ; gbif:pcr_primer_name_forward {pcr_primer_name_forward}^^xsd:string ; gbif:pcr_primer_name_reverse {pcr_primer_name_reverse}^^xsd:string ; gbif:pcr_primer_reference {pcr_primer_reference}^^xsd:string ; gbif:pcr_primer_reverse {pcr_primer_reverse}^^xsd:string ; ggbn:concentration {concentration}^^xsd:decimal ; ggbn:concentrationUnit {concentration_unit}^^xsd:string ; ggbn:methodDeterminationConcentrationAndRatios {method_determination_concentration_and_ratios}^^xsd:string ; ggbn:ratioOfAbsorbance260_230 {ratio_of_absorbance_260_230}^^xsd:decimal ; ggbn:ratioOfAbsorbance260_280 {ratio_of_absorbance_260_280}^^xsd:decimal ; miqe:ampliconSize {amplicon_size}^^xsd:integer ; miqe:amplificationReactionVolume {amplification_reaction_volume}^^xsd:decimal ; miqe:amplificationReactionVolumeUnit {amplification_reaction_volume_unit}^^xsd:string ; miqe:annealingTemp {annealing_temp}^^xsd:decimal ; miqe:annealingTempUnit {annealing_temp_unit}^^xsd:string ; miqe:automaticBaselineValue {automatic_baseline_value}^^xsd:boolean ; miqe:automaticThresholdQuantificationCycle {automatic_threshold_quantification_cycle}^^xsd:boolean ; miqe:baselineValue {baseline_value}^^xsd:integer ; miqe:contaminationAssessment {contamination_assessment}^^xsd:boolean ; miqe:estimatedNumberOfCopies {estimated_number_of_copies}^^xsd:integer ; miqe:experimentalVariance {experimental_variance}^^xsd:string ; miqe:partitionVolume {partition_volume}^^xsd:string ; miqe:partitionVolumeUnit {partition_volume_unit}^^xsd:string ; miqe:pcr_analysis_software {pcr_analysis_software}^^xsd:string ; miqe:pcr_primer_lod {pcr_primer_lod}^^xsd:string ; miqe:pcr_primer_loq {pcr_primer_loq}^^xsd:string ; miqe:probeQuencher {probe_quencher}^^xsd:string ; miqe:probeReporter {probe_reporter}^^xsd:string ; miqe:quantificationCycle {quantification_cycle}^^xsd:d