[MappingDeclaration] @collection [[
mappingId	agent
target		:agent/{agent_id} a dcterms:Agent ; dcterms:title {preferred_agent_name}^^xsd:string ; dwc:agentID {agent_id}^^xsd:string ; dwc:agentRemarks {agent_remarks}^^xsd:string ; dwc:agentType {agent_type}^^xsd:string . 
source		SELECT * FROM dwcowl.main.agent

mappingId	bibliographic_resource
target		:bibliographic-resource/{reference_id} a dcterms:BibliographicResource ; bibo:edition {edition}^^xsd:string ; bibo:editor :agent/{editor_id} ; bibo:issue {issue}^^xsd:string ; bibo:pages {pages}^^xsd:string ; bibo:status <{peer_review_status}> ; bibo:volume {volume}^^xsd:string ; dc:creator {author}^^xsd:string ; dc:publisher {publisher}^^xsd:string ; dcterms:bibliographicCitation {bibliographic_citation}^^xsd:string ; dcterms:creator :agent/{author_id} ; dcterms:issued {issued}^^xsd:string ; dcterms:publisher :agent/{publisher_id} ; dwc:editor {editor}^^xsd:string ; dwc:parentReferenceID {parent_reference_id}^^xsd:string ; dwc:referenceID {reference_id}^^xsd:string ; dwc:referenceRemarks {reference_remarks}^^xsd:string ; dwc:referenceType {reference_type}^^xsd:string ; pav:sourceAccessedOn {accessed}^^xsd:string ; pav:version {version}^^xsd:string ; dwcdp:authoredBy :agent/{author_id} ; dwcdp:editedBy :agent/{editor_id} ; dwcdp:partOf :bibliographic-resource/{parent_reference_id} ; dwcdp:publishedBy :agent/{publisher_id} . 
source		SELECT * FROM dwcowl.main.bibliographic_resource

mappingId	event
target		:event/{event_id} a dwc:Event ; dcterms:title {preferred_event_name}^^xsd:string ; dwc:datasetName {dataset_name}^^xsd:string ; dwc:datasetID {dataset_id}^^xsd:string ; dwc:day {day}^^xsd:integer ; dwc:endDayOfYear {end_day_of_year}^^xsd:integer ; dwc:eventCategory {event_category}^^xsd:string ; dwc:recordedBy {event_conducted_by}^^xsd:string ; dwc:recordedByID {event_conducted_by_id}^^xsd:string ; dwc:eventDate {event_date}^^xsd:string ; dwc:eventEffort {event_effort} ; dwc:eventID {event_id}^^xsd:string ; dwc:eventReferences {event_references}^^xsd:string ; dwc:eventRemarks {event_remarks}^^xsd:string ; dwc:eventTime {event_time}^^xsd:string ; dwc:eventType {event_type}^^xsd:string ; dwc:fieldNotes {field_notes}^^xsd:string ; dwc:fieldNumber {field_number}^^xsd:string ; dwc:geologicalContextID {geological_context_id}^^xsd:string ; dwc:georeferenceVerificationStatus {georeference_verification_status}^^xsd:string ; dwc:habitat {habitat}^^xsd:string ; dwc:month {month}^^xsd:integer ; dwc:startDayOfYear {start_day_of_year}^^xsd:integer ; dwc:verbatimEventDate {verbatim_event_date}^^xsd:string ; dwc:year {year}^^xsd:integer ; dwcdp:conductedBy :agent/{event_conducted_by_id} ; dwcdp:happenedDuring :event/{parent_event_id} ; dwcdp:spatialLocation :location/{location_id} . 
source		SELECT * FROM dwcowl.main.event

mappingId	geological_context
target		:geological-context/{geological_context_id} a dwc:GeologicalContext ; dwc:bed {bed}^^xsd:string ; dwc:earliestAgeOrLowestStage {earliest_age_or_lowest_stage}^^xsd:string ; dwc:earliestEonOrLowestEonothem {earliest_eon_or_lowest_eonothem}^^xsd:string ; dwc:earliestEpochOrLowestSeries {earliest_epoch_or_lowest_series}^^xsd:string ; dwc:earliestEraOrLowestErathem {earliest_era_or_lowest_erathem}^^xsd:string ; dwc:earliestPeriodOrLowestSystem {earliest_period_or_lowest_system}^^xsd:string ; dwc:formation {formation}^^xsd:string ; dwc:geologicalContextID {geological_context_id}^^xsd:string ; dwc:group {group}^^xsd:string ; dwc:highestBiostratigraphicZone {highest_biostratigraphic_zone}^^xsd:string ; dwc:latestAgeOrHighestStage {latest_age_or_highest_stage}^^xsd:string ; dwc:latestEonOrHighestEonothem {latest_eon_or_highest_eonothem}^^xsd:string ; dwc:latestEpochOrHighestSeries {latest_epoch_or_highest_series}^^xsd:string ; dwc:latestEraOrHighestErathem {latest_era_or_highest_erathem}^^xsd:string ; dwc:latestPeriodOrHighestSystem {latest_period_or_highest_system}^^xsd:string ; dwc:lithostratigraphicTerms {lithostratigraphic_terms}^^xsd:string ; dwc:lowestBiostratigraphicZone {lowest_biostratigraphic_zone}^^xsd:string ; dwc:member {member}^^xsd:string . 
source		SELECT * FROM dwcowl.main.geological_context

mappingId	identification
target		:identification/{identification_id} a dwc:Identification ; dc:source {external_classification_source}^^xsd:string ; dwc:class {class}^^xsd:string ; dwc:cultivarEpithet {cultivar_epithet}^^xsd:string ; dwc:dateIdentified {date_identified}^^xsd:string ; dwc:family {family}^^xsd:string ; dwc:feedbackURL {feedback_url}^^xsd:string ; dwc:genericName {generic_name}^^xsd:string ; dwc:genus {genus}^^xsd:string ; dwc:identificationReferences {identification_references}^^xsd:string ; dwc:identificationRemarks {identification_remarks}^^xsd:string ; dwc:identificationVerificationStatus {identification_verification_status}^^xsd:string ; dwc:identifiedBy {identified_by}^^xsd:string ; dwc:identifiedByID {identified_by_id}^^xsd:string ; dwc:infragenericEpithet {infrageneric_epithet}^^xsd:string ; dwc:infraspecificEpithet {infraspecific_epithet}^^xsd:string ; dwc:isAcceptedIdentification {is_accepted_identification}^^xsd:boolean ; dwc:kingdom {kingdom}^^xsd:string ; dwc:materialEntityID {material_entity_id}^^xsd:string ; dwc:mediaID {media_id}^^xsd:string ; dwc:nameAccordingTo {name_according_to}^^xsd:string ; dwc:namePublishedIn {name_published_in}^^xsd:string ; dwc:namePublishedInYear {name_published_in_year}^^xsd:string ; dwc:nomenclaturalCode {nomenclatural_code}^^xsd:string ; dwc:nomenclaturalStatus {nomenclatural_status}^^xsd:string ; dwc:nucleotideAnalysisID {nucleotide_analysis_id}^^xsd:string ; dwc:nucleotideSequenceID {nucleotide_sequence_id}^^xsd:string ; dwc:occurrenceID {occurrence_id}^^xsd:string ; dwc:order {order}^^xsd:string ; dwc:organismID {organism_id}^^xsd:string ; dwc:phylum {phylum}^^xsd:string ; dwc:scientificName {scientific_name}^^xsd:string ; dwc:scientificNameAuthorship {scientific_name_authorship} ; dwc:scientificNameID {scientific_name_id}^^xsd:string ; dwc:specificEpithet {specific_epithet}^^xsd:string ; dwc:subfamily {subfamily}^^xsd:string ; dwc:subgenus {subgenus}^^xsd:string ; dwc:taxonAssignmentMethod {taxon_assignment_method}^^xsd:string ; dwc:taxonID {taxon_id}^^xsd:string ; dwc:taxonRank {taxon_rank}^^xsd:string ; dwc:taxonRemarks {taxon_remarks}^^xsd:string ; dwc:typeStatus {type_status}^^xsd:string ; dwc:verbatimIdentification {verbatim_identification}^^xsd:string ; dwc:vernacularName {vernacular_name}^^xsd:string ; minext:classificationCode {geo_classification_code}^^xsd:string ; minext:name {geo_name} ; dwcdp:basedOn :material-entity/{material_entity_id} , :media/{media_id} , :nucleotide-analysis/{nucleotide_analysis_id} , :nucleotide-sequence/{nucleotide_sequence_id} , :occurrence/{occurrence_id} ; dwcdp:identifiedBy :agent/{identified_by_id} ; dwcdp:inferredOrganism :organism/{organism_id} . 
source		SELECT * FROM dwcowl.main.identification

mappingId	location
target		:location/{location_id} a dcterms:Location ; dwc:coordinatePrecision {coordinate_precision}^^xsd:decimal ; dwc:coordinateUncertaintyInMeters {coordinate_uncertainty_in_meters}^^xsd:decimal ; dwc:continent {continent}^^xsd:string ; dwc:country {country}^^xsd:string ; dwc:countryCode {country_code}^^xsd:string ; dwc:county {county}^^xsd:string ; dwc:dataGeneralizations {data_generalizations}^^xsd:string ; dwc:decimalLatitude {decimal_latitude}^^xsd:decimal ; dwc:decimalLongitude {decimal_longitude}^^xsd:decimal ; dwc:feedbackURL {feedback_url}^^xsd:string ; dwc:footprintSpatialFit {footprint_spatial_fit}^^xsd:decimal ; dwc:footprintSRS {footprint_srs}^^xsd:string ; dwc:footprintWKT {footprint_wkt}^^xsd:string ; dwc:geodeticDatum {geodetic_datum}^^xsd:string ; dwc:georeferencedBy {georeferenced_by}^^xsd:string ; dwc:georeferencedByID {georeferenced_by_id}^^xsd:string ; dwc:georeferencedDate {georeferenced_date}^^xsd:string ; dwc:georeferenceProtocol {georeference_protocol}^^xsd:string ; dwc:georeferenceProtocolID {georeference_protocol_id}^^xsd:string ; dwc:georeferenceRemarks {georeference_remarks}^^xsd:string ; dwc:georeferenceSources {georeference_sources}^^xsd:string ; dwc:higherGeography {higher_geography} ; dwc:higherGeographyID {higher_geography_id} ; dwc:informationWithheld {information_withheld}^^xsd:string ; dwc:island {island}^^xsd:string ; dwc:islandGroup {island_group}^^xsd:string ; dwc:locality {locality}^^xsd:string ; dwc:locationID {location_id}^^xsd:string ; dwc:locationRemarks {location_remarks}^^xsd:string ; dwc:maximumDepthInMeters {maximum_depth_in_meters}^^xsd:decimal ; dwc:maximumDistanceAboveSurfaceInMeters {maximum_distance_above_surface_in_meters}^^xsd:decimal ; dwc:maximumElevationInMeters {maximum_elevation_in_meters}^^xsd:decimal ; dwc:minimumDepthInMeters {minimum_depth_in_meters}^^xsd:decimal ; dwc:minimumDistanceAboveSurfaceInMeters {minimum_distance_above_surface_in_meters}^^xsd:decimal ; dwc:minimumElevationInMeters {minimum_elevation_in_meters}^^xsd:decimal ; dwc:municipality {municipality}^^xsd:string ; dwc:pointRadiusSpatialFit {point_radius_spatial_fit}^^xsd:decimal ; dwc:preferredSpatialRepresentation {preferred_spatial_representation}^^xsd:string ; dwc:siteNumber {site_number}^^xsd:string ; dwc:stateProvince {state_province}^^xsd:string ; dwc:verbatimCoordinates {verbatim_coordinates}^^xsd:string ; dwc:verbatimCoordinateSystem {verbatim_coordinate_system}^^xsd:string ; dwc:verbatimDepth {verbatim_depth}^^xsd:string ; dwc:verbatimElevation {verbatim_elevation}^^xsd:string ; dwc:verbatimLatitude {verbatim_latitude}^^xsd:string ; dwc:verbatimLocality {verbatim_locality}^^xsd:string ; dwc:verbatimLongitude {verbatim_longitude}^^xsd:string ; dwc:verbatimSRS {verbatim_srs}^^xsd:string ; dwc:verticalDatum {vertical_datum}^^xsd:string ; dwc:waterBody {water_body}^^xsd:string ; dwcdp:followed :protocol/{georeference_protocol_id} ; dwcdp:georeferencedBy :agent/{georeferenced_by_id} ; dwcdp:withinContext :geological-context/{geological_context_id} . 
source		SELECT * FROM dwcowl.main.v_location

mappingId	media
target		:media/{media_id} a dwc:Media ; ac:accessURI <{access_uri}> ; ac:caption {caption}^^xsd:string ; ac:captureDevice {capture_device}^^xsd:string ; ac:commenter <{commenter_id}> ; ac:commenterLiteral {commenter_literal}^^xsd:string ; ac:comments {comments}^^xsd:string ; ac:digitizationDate {digitization_date}^^xsd:string ; ac:endTime {end_time}^^xsd:decimal ; ac:endTimestamp {end_timestamp}^^xsd:string ; ac:frameRate {frame_rate}^^xsd:decimal ; ac:freqHigh {freq_high}^^xsd:decimal ; ac:freqLow {freq_low}^^xsd:decimal ; ac:furtherInformationURL {further_information_url}^^xsd:string ; ac:hashFunction {hash_function}^^xsd:string ; ac:hashValue {hash_value}^^xsd:string ; ac:hasServiceAccessPoint <{has_service_access_point}> ; ac:heightFrac {height_frac}^^xsd:decimal ; ac:isROIOf :media/{is_part_of_media_id} ; ac:mediaDuration {media_duration}^^xsd:decimal ; ac:mediaSpeed {media_speed}^^xsd:decimal ; ac:metadataLanguageLiteral {metadata_language_literal}^^xsd:string ; ac:metadataLanguage <{metadata_language_iri}> ; ac:physicalSetting {physical_setting}^^xsd:string ; ac:providerManagedID {provider_managed_id}^^xsd:string ; ac:resourceCreationTechnique {resource_creation_technique}^^xsd:string ; ac:radius {radius}^^xsd:integer ; ac:reviewer <{reviewer_id}> ; ac:reviewerComments {reviewer_comments}^^xsd:string ; ac:reviewerLiteral {reviewer_literal}^^xsd:string ; ac:startTime {start_time}^^xsd:decimal ; ac:startTimestamp {start_timestamp}^^xsd:string ; ac:subjectOrientation <{subject_orientation_iri}> ; ac:subjectOrientationLiteral {subject_orientation_literal}^^xsd:string ; ac:subjectPart <{subject_part_iri}> ; ac:subjectPartLiteral {subject_part_literal}^^xsd:string ; ac:subtypeLiteral {subtype_literal}^^xsd:string ; ac:tag {tag}^^xsd:string ; ac:timeOfDay {time_of_day}^^xsd:string ; ac:variantDescription {variant_description}^^xsd:string ; ac:variantLiteral {variant_literal}^^xsd:string ; ac:widthFrac {width_frac}^^xsd:decimal ; ac:xFrac {x_frac}^^xsd:decimal ; ac:yFrac {y_frac}^^xsd:decimal ; dc:format {format}^^xsd:string ; dc:language {language}^^xsd:string ; dcterms:available {available}^^xsd:string ; dcterms:description {description}^^xsd:string ; dcterms:format <{format_iri}> ; dcterms:language <{language_iri}> ; dcterms:modified {modified}^^xsd:string ; dcterms:title {title}^^xsd:string ; dcterms:type <{media_type}> ; dwc:collectionCode {collection_code}^^xsd:string ; dwc:collectionID {collection_id}^^xsd:string ; dwc:derivedFromMediaID {derived_from_media_id}^^xsd:string ; dwc:mediaID {media_id}^^xsd:string ; dwc:subjectCategory {subject_category}^^xsd:string ; dwciri:subjectCategory <{subject_category_iri}> ; exif:PixelXDimension {pixel_x_dimension}^^xsd:integer ; exif:PixelYDimension {pixel_y_dimension}^^xsd:integer ; mo:sample_rate {sample_rate}^^xsd:decimal ; xmp:CreateDate {create_date}^^xsd:string ; xmp:MetadataDate {metadata_date}^^xsd:string ; xmp:Rating {rating}^^xsd:string ; dwcdp:commentedBy :agent/{commenter_id} ; dwcdp:derivedFrom :media/{derived_from_media_id} ; dwcdp:partOf :media/{is_part_of_media_id} ; dwcdp:reviewedBy :agent/{reviewer_id} . 
source		SELECT * FROM dwcowl.main.media

