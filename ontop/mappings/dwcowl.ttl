@prefix : <https://biobang.org/> .
@prefix ac: <http://rs.tdwg.org/ac/terms/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix mo: <http://purl.org/ontology/mo/> .
@prefix dwc: <http://rs.tdwg.org/dwc/terms/> .
@prefix eco: <http://rs.tdwg.org/eco/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xmp: <http://ns.adobe.com/xap/1.0/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix exif: <http://ns.adobe.com/exif/1.0/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gbif: <http://rs.gbif.org/terms/> .
@prefix ggbn: <http://data.ggbn.org/schemas/ggbn/terms/> .
@prefix miqe: <http://rs.gbif.org/terms/miqe/> .
@prefix mixs: <https://w3id.org/mixs/> .
@prefix obda: <https://w3id.org/obda/vocabulary#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dwcdp: <http://rs.tdwg.org/dwcdp/terms/> .
@prefix chrono: <http://rs.tdwg.org/chrono/terms/> .
@prefix dwciri: <http://rs.tdwg.org/dwc/iri/> .
@prefix ecoiri: <http://rs.tdwg.org/eco/iri/> .
@prefix minext: <http://rs.tdwg.org/mineralogy/terms/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix photoshop: <http://ns.adobe.com/photoshop/1.0/> .
@prefix xmprights: <http://ns.adobe.com/xap/1.0/rights/> .
@base <https://biobang.org/> .

<http://example.org/dwcowl#> rdf:type owl:Ontology ;
                              dc:description "An OWL 2 QL compliant ontology based on terms from biodiversity related vocabularies used to describe Darwin Core DataPackages." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/dc/terms/accessRights
dcterms:accessRights rdf:type owl:ObjectProperty ;
                     rdfs:label "Access Rights" ;
                     skos:definition "Information about who can access the resource or an indication of its security status." .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:ObjectProperty ;
                rdfs:label "Creator" ;
                skos:definition "An entity responsible for making the resource." .


###  http://purl.org/dc/terms/format
dcterms:format rdf:type owl:ObjectProperty ;
               rdfs:label "Format" ;
               skos:definition "The file format, physical medium, or dimensions of the resource, denoted by an IRI." .


###  http://purl.org/dc/terms/language
dcterms:language rdf:type owl:ObjectProperty ;
                 rdfs:label "Language" ;
                 skos:definition "A language of the resource." .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:ObjectProperty ;
                rdfs:label "License" ;
                skos:definition "A legal document giving official permission to do something with a resource." .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:ObjectProperty ;
                  rdfs:label "Publisher" ;
                  skos:definition "An identifier for a dcterms:Agent responsible for making a Reference available." .


###  http://purl.org/dc/terms/references
dcterms:references rdf:type owl:ObjectProperty ;
                   rdfs:label "References" ;
                   skos:definition "A related resource that is referenced, cited, or otherwise pointed to by the described resource." .


###  http://purl.org/dc/terms/rights
dcterms:rights rdf:type owl:ObjectProperty ;
               rdfs:label "Rights" ;
               skos:definition "A URI pointing to structured information about rights held in and over the resource. Examples include http://creativecommons.org/licenses/by/3.0/legalcode and http://creativecommons.org/publicdomain/zero/1.0/. At least one of dcterms:rights and dc:rights must be supplied but, when feasible, supplying both may make the metadata more widely useful. They must specify the same rights. In case of ambiguity, dcterms:rights prevails." .


###  http://purl.org/dc/terms/rightsHolder
dcterms:rightsHolder rdf:type owl:ObjectProperty ;
                     rdfs:label "Rights Holder" ;
                     skos:definition "An identifier for a dcterms:Agent that owns or manages rights over a resource." .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:ObjectProperty ;
               rdfs:label "Source" ;
               skos:definition "An identifier for a resource from which this resource is derived." .


###  http://purl.org/dc/terms/type
dcterms:type rdf:type owl:ObjectProperty ;
             rdfs:label "Type" ;
             skos:definition "The nature or genre of the resource." .


###  http://purl.org/ontology/bibo/editor
bibo:editor rdf:type owl:ObjectProperty ;
            rdfs:label "Editor" ;
            skos:definition "An identifier for a dcterms:Agent having managerial and sometimes policy-making responsibility for the editorial part of a publishing firm or of a newspaper, magazine, or other publication." .


###  http://purl.org/ontology/bibo/status
bibo:status rdf:type owl:ObjectProperty ;
            rdfs:label "Status" ;
            skos:definition "An indication of whether a dcterms:BibliographicResource was peer reviewed." .


###  http://rs.tdwg.org/ac/terms/accessURI
ac:accessURI rdf:type owl:ObjectProperty ;
             rdfs:label "Access URI" ;
             skos:definition "A URI that uniquely identifies a service that provides a representation of the underlying resource." .


###  http://rs.tdwg.org/ac/terms/commenter
ac:commenter rdf:type owl:ObjectProperty ;
             rdfs:label "Commenter" ;
             skos:definition "An identifier for a dcterms:Agent primarily responsible for providing the ac:comments." .


###  http://rs.tdwg.org/ac/terms/hasServiceAccessPoint
ac:hasServiceAccessPoint rdf:type owl:ObjectProperty ;
                         rdfs:label "Has Service Access Point" ;
                         skos:definition "In a chosen serialization (RDF, XML Schema, etc.) the potentially multiple service access points (e.g., for different resolutions of an image) might be provided in a referenced or in a nested object." .


###  http://rs.tdwg.org/ac/terms/isROIOf
ac:isROIOf rdf:type owl:ObjectProperty ;
           rdfs:label "Is Region Of Interest Of" ;
           skos:definition "The media item within which a region of interest is located." .


###  http://rs.tdwg.org/ac/terms/metadataLanguage
ac:metadataLanguage rdf:type owl:ObjectProperty ;
                    rdfs:label "Metadata Language" ;
                    skos:definition "The URI of the language of description and other metadata (but not necessarily of the image itself)." .


###  http://rs.tdwg.org/ac/terms/reviewer
ac:reviewer rdf:type owl:ObjectProperty ;
            rdfs:label "Reviewer" ;
            skos:definition "An identifier for a dcterms:Agent primarily responsible for providing the ac:reviewerComments." .


###  http://rs.tdwg.org/ac/terms/subjectCategorySource
ac:subjectCategorySource rdf:type owl:ObjectProperty ;
                         rdfs:label "Subject Category Source" ;
                         skos:definition "A reference to a controlled vocabulary in which the definition of a value in dwc:subjectCategory is given." .


###  http://rs.tdwg.org/ac/terms/subjectOrientation
ac:subjectOrientation rdf:type owl:ObjectProperty ;
                      rdfs:label "Subject Orientation" ;
                      skos:definition "Specific orientation (= direction, view angle) of the subject represented in the dwc:Media resource with respect to the acquisition device, denoted by an IRI." .


###  http://rs.tdwg.org/ac/terms/subjectPart
ac:subjectPart rdf:type owl:ObjectProperty ;
               rdfs:label "Subject Part" ;
               skos:definition "The portion or product of organism morphology, behaviour, environment, etc. that is either predominantly shown or particularly well exemplified by the dwc:Media resource, denoted by an IRI." .


###  http://rs.tdwg.org/ac/terms/subtype
ac:subtype rdf:type owl:ObjectProperty .


###  http://rs.tdwg.org/ac/terms/variant
ac:variant rdf:type owl:ObjectProperty ;
           rdfs:label "Variant" ;
           skos:definition "The category describing this Service Access Point variant, denoted by an IRI." .


###  http://rs.tdwg.org/ac/terms/variantIRI
ac:variantIRI rdf:type owl:ObjectProperty ;
              rdfs:label "Variant IRI" ;
              skos:definition "The category describing this Service Access Point variant, denoted by an IRI." .


###  http://rs.tdwg.org/dwc/iri/assertionType
dwciri:assertionType rdf:type owl:ObjectProperty ;
                     rdfs:label "Assertion Type" ;
                     skos:definition "An IRI of a controlled vocabulary value for a type of dwc:Assertion." .


###  http://rs.tdwg.org/dwc/iri/assertionUnit
dwciri:assertionUnit rdf:type owl:ObjectProperty ;
                     rdfs:label "Assertion Unit" ;
                     skos:definition "An IRI of a controlled vocabulary value for the unit of a dwc:assertionValue or a dwc:assertionValueNumeric." .


###  http://rs.tdwg.org/dwc/iri/assertionValue
dwciri:assertionValue rdf:type owl:ObjectProperty ;
                      rdfs:label "Assertion Value" ;
                      skos:definition "An IRI of the controlled vocabulary value for a value of a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/iri/ownerInstitution
dwciri:ownerInstitution rdf:type owl:ObjectProperty ;
                        rdfs:label "Owner Institution" ;
                        skos:definition "An identifier for an institution that owns a dwc:MaterialEntity." ;
                        skos:example "http://grscicoll.org/institution/museum-southwestern-biology" ,
                                     "https://ror.org/015hz7p22" ,
                                     "https://scientific-collections.gbif.org/institution/e3d4dcc4-81e2-444c-8a5c-41d1044b5381" .


###  http://rs.tdwg.org/dwc/iri/samplingPerformedBy
dwciri:samplingPerformedBy rdf:type owl:ObjectProperty ;
                           rdfs:label "Sampling Performed By" ;
                           skos:definition "An identifier for a dcterms:Agent responsible for sampling." ;
                           skos:example "https://orcid.org/0000-0002-1825-0097" .


###  http://rs.tdwg.org/dwc/iri/subjectCategory
dwciri:subjectCategory rdf:type owl:ObjectProperty ;
                       rdfs:label "Subject Category" ;
                       skos:definition "A category for the content of a dwc:Media resource." .


###  http://rs.tdwg.org/dwc/iri/subjectCategoryIRI
dwciri:subjectCategoryIRI rdf:type owl:ObjectProperty ;
                          rdfs:label "Subject Category IRI" ;
                          skos:definition "An IRI of a controlled vocabulary value for the subject category of a dwc:Media resource." .


###  http://rs.tdwg.org/dwc/iri/surveyTargetUnit
dwciri:surveyTargetUnit rdf:type owl:ObjectProperty ;
                        rdfs:label "Survey Target Unit" ;
                        skos:definition "An IRI of a controlled vocabulary value for a target unit." .


###  http://rs.tdwg.org/dwc/iri/surveyTargetValue
dwciri:surveyTargetValue rdf:type owl:ObjectProperty ;
                         rdfs:label "Survey Target Value" ;
                         skos:definition "An IRI of a controlled vocabulary value for a target value." .


###  http://rs.tdwg.org/dwcdp/terms/about
dwcdp:about rdf:type owl:ObjectProperty ;
            rdfs:label "About" ;
            skos:definition "An object property to relate a dwc:Assertion to the resource it is about." .


###  http://rs.tdwg.org/dwcdp/terms/ageFor
dwcdp:ageFor rdf:type owl:ObjectProperty ;
             rdfs:label "Age For" ;
             skos:definition "An object property to relate a chrono:ChronometricAge to the dwc:Event it is an age for." .


###  http://rs.tdwg.org/dwcdp/terms/analysisOf
dwcdp:analysisOf rdf:type owl:ObjectProperty ;
                 rdfs:label "Analysis Of" ;
                 skos:definition "An object property used to relate a dwc:NucleotideAnalysis to a dwc:MaterialEntity it is an analysis of." .


###  http://rs.tdwg.org/dwcdp/terms/authoredBy
dwcdp:authoredBy rdf:type owl:ObjectProperty ;
                 rdfs:label "Authored By" ;
                 skos:definition "An object property to relate a dcterms:BibliographicResource to the dcterms:Agent that authored it." .


###  http://rs.tdwg.org/dwcdp/terms/basedOn
dwcdp:basedOn rdf:type owl:ObjectProperty ;
              rdfs:label "Based On" .


###  http://rs.tdwg.org/dwcdp/terms/collectedDuring
dwcdp:collectedDuring rdf:type owl:ObjectProperty ;
                      rdfs:label "Collected During" ;
                      skos:definition "An object property to relate a dwc:MaterialEntity to the dwc:Event during which it was collected." .


###  http://rs.tdwg.org/dwcdp/terms/commentedBy
dwcdp:commentedBy rdf:type owl:ObjectProperty ;
                  rdfs:label "Commented By" .


###  http://rs.tdwg.org/dwcdp/terms/conductedBy
dwcdp:conductedBy rdf:type owl:ObjectProperty ;
                  rdfs:label "Conducted By" ;
                  skos:definition "An object property to relate a dwc:Event to the dcterms:Agent that conducted it." .


###  http://rs.tdwg.org/dwcdp/terms/createdBy
dwcdp:createdBy rdf:type owl:ObjectProperty ;
                rdfs:label "Created By" ;
                skos:definition "An object property used to relate a dwc:Provenance to the dcterms:Agent responsible for creating it." .


###  http://rs.tdwg.org/dwcdp/terms/derivedFrom
dwcdp:derivedFrom rdf:type owl:ObjectProperty ;
                  rdfs:label "Derived From" .


###  http://rs.tdwg.org/dwcdp/terms/derivedFromTransitive
dwcdp:derivedFromTransitive rdf:type owl:ObjectProperty ;
                            rdfs:label "Derived From Transitive" ;
                            skos:definition "An object property to relate a resource to the resource from which it is derived from. This version is different from dwcdp:derivedFrom in that it considers transitive closure and relates the subject resource to all resources in the derivation chain." .


###  http://rs.tdwg.org/dwcdp/terms/derivedFromTransitiveReflexive
dwcdp:derivedFromTransitiveReflexive rdf:type owl:ObjectProperty ;
                                     rdfs:label "Derived From Transitive Reflexive" .


###  http://rs.tdwg.org/dwcdp/terms/editedBy
dwcdp:editedBy rdf:type owl:ObjectProperty ;
               rdfs:label "Edited By" ;
               skos:definition "An object property to relate a dcterms:BibliographicResource to the dcterms:Agent that edited it." .


###  http://rs.tdwg.org/dwcdp/terms/evidenceFor
dwcdp:evidenceFor rdf:type owl:ObjectProperty ;
                  rdfs:label "Evidence For" ;
                  skos:definition "An object property used to relate a dwc:MaterialEntity to the dwc:Occurrence it serves as evidence for." .


###  http://rs.tdwg.org/dwcdp/terms/followed
dwcdp:followed rdf:type owl:ObjectProperty ;
               rdfs:label "Followed" ;
               skos:definition "An object property to relate a resource to the dwc:Protocol it followed." .


###  http://rs.tdwg.org/dwcdp/terms/fundedBy
dwcdp:fundedBy rdf:type owl:ObjectProperty ;
               rdfs:label "Funded By" .


###  http://rs.tdwg.org/dwcdp/terms/georeferencedBy
dwcdp:georeferencedBy rdf:type owl:ObjectProperty ;
                      rdfs:label "Georeferenced By" .


###  http://rs.tdwg.org/dwcdp/terms/happenedDuring
dwcdp:happenedDuring rdf:type owl:ObjectProperty ;
                     rdfs:label "Happened During" .


###  http://rs.tdwg.org/dwcdp/terms/happenedDuringTransitive
dwcdp:happenedDuringTransitive rdf:type owl:ObjectProperty ;
                               rdfs:label "Happened During Transitive" ;
                               skos:definition "An object property to relate a resource to the resource in which it hppened. This version is different from dwcdp:happenedDuring in that it considers transitive closure and relates the subject resource to all resources in the happening chain." .


###  http://rs.tdwg.org/dwcdp/terms/happenedDuringTransitiveReflexive
dwcdp:happenedDuringTransitiveReflexive rdf:type owl:ObjectProperty ;
                                        rdfs:label "Happened During Transitive Reflexive" .


###  http://rs.tdwg.org/dwcdp/terms/hasDefinition
dwcdp:hasDefinition rdf:type owl:ObjectProperty ;
                    rdfs:label "Has Definition" ;
                    skos:definition "An object property used to relate a dwc:SurveyTarget to a dwc:Definition." .


###  http://rs.tdwg.org/dwcdp/terms/hasMedia
dwcdp:hasMedia rdf:type owl:ObjectProperty ;
               owl:inverseOf dwcdp:isMediaOf ;
               rdfs:label "Has Media" ;
               skos:definition "An object property to relate a resource to a dwc:Media instance depicting it." .


###  http://rs.tdwg.org/dwcdp/terms/hasProvenance
dwcdp:hasProvenance rdf:type owl:ObjectProperty ;
                    rdfs:label "Has Provenance" ;
                    skos:definition "An object property used to relate a resource to its dwc:Provenance." .


###  http://rs.tdwg.org/dwcdp/terms/hasUsagePolicy
dwcdp:hasUsagePolicy rdf:type owl:ObjectProperty ;
                     rdfs:label "Has Usage Policy" ;
                     skos:definition "An object property to relate entities to their respective rights and usage policies, represented by a dwc:UsagePolicy instance." .


###  http://rs.tdwg.org/dwcdp/terms/identifiedBy
dwcdp:identifiedBy rdf:type owl:ObjectProperty ;
                   rdfs:label "Identified By" ;
                   skos:definition "An object property used to relate a resource to the dcterms:Agent that identified it." .


###  http://rs.tdwg.org/dwcdp/terms/identifierFor
dwcdp:identifierFor rdf:type owl:ObjectProperty ;
                    rdfs:label "Identifier For" .


###  http://rs.tdwg.org/dwcdp/terms/inferredOrganism
dwcdp:inferredOrganism rdf:type owl:ObjectProperty ;
                       rdfs:label "Inferred Organism" ;
                       skos:definition "An object property to relate a dwc:Identification to the dwc:Organism that is inferred as a a result of the identification process." .


###  http://rs.tdwg.org/dwcdp/terms/interactionBy
dwcdp:interactionBy rdf:type owl:ObjectProperty ;
                    rdfs:label "Interaction By" ;
                    skos:definition "An object property to designate the subject resource in a dwc:OrganismInteraction." .


###  http://rs.tdwg.org/dwcdp/terms/interactionWith
dwcdp:interactionWith rdf:type owl:ObjectProperty ;
                      rdfs:label "Interaction With" ;
                      skos:definition "An object property to designate the object resource in a dwc:OrganismInteraction." .


###  http://rs.tdwg.org/dwcdp/terms/isMediaOf
dwcdp:isMediaOf rdf:type owl:ObjectProperty ;
                rdfs:label "Is Media Of" ;
                skos:definition "An object property to relate a dwc:Media instance to a resource it is a media of." .


###  http://rs.tdwg.org/dwcdp/terms/materialCollectedDuring
dwcdp:materialCollectedDuring rdf:type owl:ObjectProperty ;
                              rdfs:label "Material Collected During" ;
                              skos:definition "An object property used to relate a dwc:NucleotideAnalysis to the dwc:Event during which the dwc:MaterialEntity analyzed was collected." .


###  http://rs.tdwg.org/dwcdp/terms/metadataCreatedBy
dwcdp:metadataCreatedBy rdf:type owl:ObjectProperty ;
                        rdfs:label "Metadata Created By" ;
                        skos:definition "An object property used to related a dwc:Provenance to the dcterms:Agent responsible for creating the metadata about it." .


###  http://rs.tdwg.org/dwcdp/terms/metadataProvidedBy
dwcdp:metadataProvidedBy rdf:type owl:ObjectProperty ;
                         rdfs:label "Metadata Provided By" ;
                         skos:definition "An object property used to related a dwc:Provenance to the dcterms:Agent responsible for providing the metadata about it." .


###  http://rs.tdwg.org/dwcdp/terms/ownedBy
dwcdp:ownedBy rdf:type owl:ObjectProperty ;
              rdfs:label "Owned By" ;
              skos:definition "An object property to relate a dwc:UsagePolicy to a dcterms:Agent that owns it." .


###  http://rs.tdwg.org/dwcdp/terms/partOf
dwcdp:partOf rdf:type owl:ObjectProperty ;
             rdfs:label "Part Of" ;
             skos:definition "An object property to relate a resource to the resource it is a part of." .


###  http://rs.tdwg.org/dwcdp/terms/partOfTransitive
dwcdp:partOfTransitive rdf:type owl:ObjectProperty ;
                       rdfs:label "Part Of Transitive" .


###  http://rs.tdwg.org/dwcdp/terms/partOfTransitiveReflexive
dwcdp:partOfTransitiveReflexive rdf:type owl:ObjectProperty ;
                                rdfs:label "Part Of Transitive Reflexive" .


###  http://rs.tdwg.org/dwcdp/terms/produced
dwcdp:produced rdf:type owl:ObjectProperty ;
               rdfs:label "Produced" ;
               skos:definition "An object property to relate a dwc:NucleotideAnalysis to the dwc:NucleotideSequence it produced." .


###  http://rs.tdwg.org/dwcdp/terms/provenanceFor
dwcdp:provenanceFor rdf:type owl:ObjectProperty ;
                    rdfs:label "Provenance For" ;
                    skos:definition "An object property used to relate a dwc:Provenance to the resources it is a provenance for." .


###  http://rs.tdwg.org/dwcdp/terms/providedBy
dwcdp:providedBy rdf:type owl:ObjectProperty ;
                 rdfs:label "Provided By" ;
                 skos:definition "An object property used to relate a dwc:Provenance to the dcterms:Agent responsible for providing it." .


###  http://rs.tdwg.org/dwcdp/terms/publishedBy
dwcdp:publishedBy rdf:type owl:ObjectProperty ;
                  rdfs:label "Published By" ;
                  skos:definition "An object property to relate a dcterms:BibliographicResource to the dcterms:Agent that published it." .


###  http://rs.tdwg.org/dwcdp/terms/relationshipOf
dwcdp:relationshipOf rdf:type owl:ObjectProperty ;
                     rdfs:label "Relationship Of" ;
                     skos:definition "An object property to relate a dwc:ResourceRelationship to the subject resource in it." .


###  http://rs.tdwg.org/dwcdp/terms/relationshipTo
dwcdp:relationshipTo rdf:type owl:ObjectProperty ;
                     rdfs:label "Relationship To" ;
                     skos:definition "An object property to relate a dwc:ResourceRelationship to the object resource in it." .


###  http://rs.tdwg.org/dwcdp/terms/reviewedBy
dwcdp:reviewedBy rdf:type owl:ObjectProperty ;
                 rdfs:label "Reviewed By" .


###  http://rs.tdwg.org/dwcdp/terms/rightsHeldBy
dwcdp:rightsHeldBy rdf:type owl:ObjectProperty ;
                   rdfs:label "Rights Held By" ;
                   skos:definition "An object property to relate a dwc:UsagePolicy to the dcterms:Agent that holds the rights to it." .


###  http://rs.tdwg.org/dwcdp/terms/satisfied
dwcdp:satisfied rdf:type owl:ObjectProperty ;
                rdfs:label "Satisfied" ;
                skos:definition "An object property to relate a dwc:Occurrence to the dwc:Survey target it satisfied." .


###  http://rs.tdwg.org/dwcdp/terms/spatialLocation
dwcdp:spatialLocation rdf:type owl:ObjectProperty ;
                      rdfs:label "Spatial Location" ;
                      skos:definition "An object property to link a dwc:Event to the dcterms:Location where it took place." .


###  http://rs.tdwg.org/dwcdp/terms/targetFor
dwcdp:targetFor rdf:type owl:ObjectProperty ;
                rdfs:label "Target For" ;
                skos:definition "An object property to relate a dwc:SurveyTarget to the dwc:Survey it is a target for." .


###  http://rs.tdwg.org/dwcdp/terms/usagePolicyFor
dwcdp:usagePolicyFor rdf:type owl:ObjectProperty ;
                     rdfs:label "Usage Policy For" ;
                     skos:definition "An object property used to relate a dwc:UsagePolicy to a resource." .


###  http://rs.tdwg.org/dwcdp/terms/withinContext
dwcdp:withinContext rdf:type owl:ObjectProperty ;
                    rdfs:label "Within Context" ;
                    skos:definition "An object property to link a dcterms:Location or a dwc:MaterialEntity to the dwc:GeologicalContext within which it is situated." .


###  http://rs.tdwg.org/eco/iri/samplingEffortProtocol
ecoiri:samplingEffortProtocol rdf:type owl:ObjectProperty ;
                              rdfs:label "Sampling Effort Protocol" ;
                              skos:definition "An identifier for a dwc:Protocol used to determine a eco:samplingEffortValue." .


#################################################################
#    Data properties
#################################################################

###  http://data.ggbn.org/schemas/ggbn/terms/concentration
ggbn:concentration rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:decimal ;
                   rdfs:label "Concentration (DNA)" ;
                   skos:definition "Concentration of DNA (weight ng/volume µl)." ;
                   skos:example 67.5 .


###  http://data.ggbn.org/schemas/ggbn/terms/concentrationUnit
ggbn:concentrationUnit rdf:type owl:DatatypeProperty ;
                       rdfs:label "Unit Of Concentration (DNA)" ;
                       skos:definition "Unit used for concentration measurement (DNA)." ;
                       skos:example "ng/µl" .


###  http://data.ggbn.org/schemas/ggbn/terms/methodDeterminationConcentrationAndRatios
ggbn:methodDeterminationConcentrationAndRatios rdf:type owl:DatatypeProperty ;
                                               rdfs:label "Method Used For Determination of Concentration And Ratios Of Absorbance (DNA)" ;
                                               skos:definition "Description of method used for concentration measurement (DNA)." ;
                                               skos:example "Nanodrop" ,
                                                            "Qubit" .


###  http://data.ggbn.org/schemas/ggbn/terms/ratioOfAbsorbance260_230
ggbn:ratioOfAbsorbance260_230 rdf:type owl:DatatypeProperty ;
                              rdfs:range xsd:decimal ;
                              rdfs:label "Ratio Of Absorbance 260/230 (DNA)" ,
                                         "Ratio of absorbance at 260 nm and 230 nm assessing DNA purity (mostly secondary measure, indicates mainly EDTA, carbohydrates, phenol), (DNA samples only)." ;
                              skos:example 1.89 .


###  http://data.ggbn.org/schemas/ggbn/terms/ratioOfAbsorbance260_280
ggbn:ratioOfAbsorbance260_280 rdf:type owl:DatatypeProperty ;
                              rdfs:range xsd:decimal ;
                              rdfs:label "Ratio Of Absorbance 260/280 (DNA)" ;
                              skos:definition "Ratio of absorbance at 260 nm and 280 nm assessing DNA purity (mostly secondary measure, indicates mainly EDTA, carbohydrates, phenol), (DNA samples only)." ;
                              skos:example 1.8 .


###  http://ns.adobe.com/exif/1.0/PixelXDimension
exif:PixelXDimension rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:integer ;
                     rdfs:label "Image Width" ;
                     skos:definition "Information specific to compressed data. When a compressed file is recorded, the valid width of the meaningful image shall be recorded in this tag, whether or not there is padding data or a restart marker." .


###  http://ns.adobe.com/exif/1.0/PixelYDimension
exif:PixelYDimension rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:integer ;
                     rdfs:label "Image Height" ;
                     skos:definition "Information specific to compressed data. When a compressed file is recorded, the valid height of the meaningful image shall be recorded in this tag, whether or not there is padding data or a restart marker." .


###  http://ns.adobe.com/photoshop/1.0/Credit
photoshop:Credit rdf:type owl:DatatypeProperty ;
                 rdfs:label "Credit" ;
                 skos:definition "Free text describing how credit should be attributed." ;
                 skos:example "For example, `Please cite this as …" .


###  http://ns.adobe.com/xap/1.0/CreateDate
xmp:CreateDate rdf:type owl:DatatypeProperty ;
               rdfs:label "Original Date and Time" ;
               skos:example "The date and time a resource was created. For a digital file, this need not match a file-system creation time. For a freshly created resource, it should be close to that time, modulo the time taken to write the file. Later file transfer, copying, and so on, can make the file-system time arbitrarily different." .


###  http://ns.adobe.com/xap/1.0/MetadataDate
xmp:MetadataDate rdf:type owl:DatatypeProperty ;
                 rdfs:label "Metadata Date" ;
                 skos:definition "The date and time that any metadata for this resource was last changed. It should be the same as or more recent than dcterms:modified." .


###  http://ns.adobe.com/xap/1.0/Rating
xmp:Rating rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:label "A user-assigned rating for this file. The value shall be -1 or in the range [0..5], where -1 indicates \\\"rejected\\\" and 0 indicates \\\"unrated\\\". If xmp:Rating is not present, a value of 0 should be assumed." ,
                      "Rating" ;
           skos:example "1" ,
                        "5" .


###  http://ns.adobe.com/xap/1.0/rights/Owner
xmprights:Owner rdf:type owl:DatatypeProperty ;
                rdfs:label "Owner" ;
                skos:definition "An identifier for a dcterms:Agent that owns the copyright for a resource." .


###  http://ns.adobe.com/xap/1.0/rights/UsageTerms
xmprights:UsageTerms rdf:type owl:DatatypeProperty ;
                     rdfs:label "Usage Terms" ;
                     skos:definition "A license statement defining how resources may be used. Information on a collection applies to all contained objects unless an object has a different statement." .


###  http://ns.adobe.com/xap/1.0/rights/WebStatement
xmprights:WebStatement rdf:type owl:DatatypeProperty ;
                       rdfs:label "Web Statement" ;
                       skos:definition "A URL defining or further elaborating on a license statement (e.g., a web page explaining the precise terms of use)" ;
                       skos:example "http://creativecommons.org/licenses/by-nc-sa/3.0/us/" .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:DatatypeProperty ;
           rdfs:label "Creator" ;
           skos:definition "An entity responsible for making the resource." .


###  http://purl.org/dc/elements/1.1/format
dc:format rdf:type owl:DatatypeProperty ;
          rdfs:label "Format" ;
          skos:definition "The file format, physical medium, or dimensions of the resource, denoted by a controlled value string." .


###  http://purl.org/dc/elements/1.1/language
dc:language rdf:type owl:DatatypeProperty ;
            rdfs:label "Language" ;
            skos:definition "A language of the resource." .


###  http://purl.org/dc/elements/1.1/publisher
dc:publisher rdf:type owl:DatatypeProperty ;
             rdfs:label "Publisher" ;
             skos:definition "An entity responsible for making the resource available." .


###  http://purl.org/dc/elements/1.1/rights
dc:rights rdf:type owl:DatatypeProperty ;
          rdfs:label "Rights" ;
          skos:definition "Information about rights held in and over the resource." .


###  http://purl.org/dc/elements/1.1/source
dc:source rdf:type owl:DatatypeProperty ;
          rdfs:label "Source" ;
          skos:definition "A related resource from which the described resource is derived." .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/elements/1.1/type
dc:type rdf:type owl:DatatypeProperty ;
        rdfs:label "Type" ;
        skos:definition "The nature or genre of the resource." .


###  http://purl.org/dc/terms/available
dcterms:available rdf:type owl:DatatypeProperty ;
                  rdfs:label "Available" ;
                  skos:definition "Date (often a range) that the resource became or will become available." .


###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:DatatypeProperty ;
                              rdfs:comment "Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible. The intended usage of this term in Darwin Core is to provide the preferred way to cite the resource itself. Note that the intended usage of dcterms:references in Darwin Core, by contrast, is to point to the definitive source representation of the resource, if one is available." ;
                              rdfs:label "Bibliographic Citation" ;
                              skos:definition "A bibliographic reference for a dcterms:BibliographicResource." .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:DatatypeProperty ;
                    rdfs:label "Description" ;
                    skos:definition "An account of the resource." .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:DatatypeProperty ;
                   rdfs:label "Identifier" ;
                   skos:definition "An unambiguous reference to the resource within a given context." .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:DatatypeProperty ;
               rdfs:label "Issued" ;
               skos:definition "Date of formal issuance of the resource." .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:DatatypeProperty ;
                 rdfs:label "Modified" ;
                 skos:definition "Date on which the resource was changed." .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:DatatypeProperty ;
              rdfs:label "Title" ;
              skos:definition "A name given to a resource." .


###  http://purl.org/ontology/bibo/edition
bibo:edition rdf:type owl:DatatypeProperty ;
             rdfs:label "Edition" ;
             skos:definition "An edition of a dcterms:BibliographicResource." .


###  http://purl.org/ontology/bibo/issue
bibo:issue rdf:type owl:DatatypeProperty ;
           rdfs:label "Issue" ;
           skos:definition "An issue number of a dcterms:BibliographicResource." .


###  http://purl.org/ontology/bibo/pages
bibo:pages rdf:type owl:DatatypeProperty ;
           rdfs:label "Pages" ;
           skos:definition "A range of pages within a dcterms:BibliographicResource." .


###  http://purl.org/ontology/bibo/volume
bibo:volume rdf:type owl:DatatypeProperty ;
            rdfs:label "A volume number of a dcterms:BibliographicResource." ,
                       "Volume" .


###  http://purl.org/ontology/mo/sample_rate
mo:sample_rate rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:decimal ;
               rdfs:label "Sample Rate" ;
               skos:definition "Associates a digital signal to its sample rate." .


###  http://purl.org/pav/sourceAccessedOn
pav:sourceAccessedOn rdf:type owl:DatatypeProperty ;
                     rdfs:label "Accessed" ;
                     skos:definition "The resource is related to a source which was originally accessed or consulted on the given date as part of creating or authoring the resource." .


###  http://purl.org/pav/version
pav:version rdf:type owl:DatatypeProperty ;
            rdfs:label "Version" ;
            skos:definition "A version number of a dcterms:BibliographicResource." .


###  http://rs.gbif.org/terms/pcr_primer_forward
gbif:pcr_primer_forward rdf:type owl:DatatypeProperty ;
                        rdfs:label "Forward PCR Primer" ;
                        skos:definition "Forward PCR primer that were used to amplify the sequence of the targeted gene, locus or subfragment. If multiple multiple forward or reverse primers are present in a single PCR reaction, there should be a full row for each of these linked to the same DWC Occurrence. The primer sequence should be reported in uppercase letters" ;
                        skos:example "GGACTACHVGGGTWTCTAAT" .


###  http://rs.gbif.org/terms/pcr_primer_name_forward
gbif:pcr_primer_name_forward rdf:type owl:DatatypeProperty ;
                             rdfs:label "Forward PCR Primer Name" ;
                             skos:definition "Name of the forward PCR primer that were used to amplify the sequence of the targeted gene, locus or subfragment. If multiple multiple forward or reverse primers are present in a single PCR reaction, there should be a full row for each of these linked to the same dwc:Occurrence." ;
                             skos:example "jgLCO1490" .


###  http://rs.gbif.org/terms/pcr_primer_name_reverse
gbif:pcr_primer_name_reverse rdf:type owl:DatatypeProperty ;
                             rdfs:label "Reverse PCR Primer Name" ;
                             skos:definition "Name of the reverse PCR primer that were used to amplify the sequence of the targeted gene, locus or subfragment. If multiple multiple forward or reverse primers are present in a single PCR reaction, there should be a full row for each of these linked to the same dwc:Occurrence." ;
                             skos:example "jgHCO2198" .


###  http://rs.gbif.org/terms/pcr_primer_reference
gbif:pcr_primer_reference rdf:type owl:DatatypeProperty ;
                          rdfs:label "PCR Primer Reference" ;
                          skos:definition "Reference for the PCR primers that were used to amplify the sequence of the targeted gene, locus or subfragment." ;
                          skos:example "https://doi.org/10.1186/1742-9994-10-34" .


###  http://rs.gbif.org/terms/pcr_primer_reverse
gbif:pcr_primer_reverse rdf:type owl:DatatypeProperty ;
                        rdfs:label "Reverse PCR Primer" ;
                        skos:definition "Reverse PCR primer that were used to amplify the sequence of the targeted gene, locus or subfragment. If multiple multiple forward or reverse primers are present in a single PCR reaction, there should be a full row for each of these linked to the same DWC Occurrence. The primer sequence should be reported in uppercase letters" ;
                        skos:example "GGACTACHVGGGTWTCTAAT" .


###  http://rs.gbif.org/terms/typeDesignationType
gbif:typeDesignationType rdf:type owl:DatatypeProperty ;
                         rdfs:label "Type Designation Type" ;
                         skos:definition "A category that best matches the nature of a type designation." .


###  http://rs.gbif.org/terms/miqe/ampliconSize
miqe:ampliconSize rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:integer ;
                  rdfs:label "Amplicon Size" ;
                  skos:definition "The length of the amplicon in basepairs." ;
                  skos:example 83 .


###  http://rs.gbif.org/terms/miqe/amplificationReactionVolume
miqe:amplificationReactionVolume rdf:type owl:DatatypeProperty ;
                                 rdfs:range xsd:decimal ;
                                 rdfs:label "Amplification Reaction Volume" ;
                                 skos:definition "PCR reaction volume" ;
                                 skos:example 22 .


###  http://rs.gbif.org/terms/miqe/amplificationReactionVolumeUnit
miqe:amplificationReactionVolumeUnit rdf:type owl:DatatypeProperty ;
                                     rdfs:range xsd:string ;
                                     rdfs:label "Amplification Reaction Volume Unit" ;
                                     skos:definition "Unit used for PCR reaction volume. Many of the instruments require preparation of a much larger initial sample volume than is actually analyzed." ;
                                     skos:example "µl" .


###  http://rs.gbif.org/terms/miqe/annealingTemp
miqe:annealingTemp rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:decimal ;
                   rdfs:label "Annealing Phase Temperature" ;
                   skos:definition "The reaction temperature during the annealing phase of PCR." ;
                   skos:example 60 .


###  http://rs.gbif.org/terms/miqe/annealingTempUnit
miqe:annealingTempUnit rdf:type owl:DatatypeProperty ;
                       rdfs:label "Annealing Phase Temperature Unit" ;
                       skos:definition "Measurement unit of the reaction temperature during the annealing phase of PCR." ;
                       skos:example "Degrees celsius" .


###  http://rs.gbif.org/terms/miqe/automaticBaselineValue
miqe:automaticBaselineValue rdf:type owl:DatatypeProperty ;
                            rdfs:label "Automatic Baseline Value" ;
                            skos:definition "Whether the baseline value was set by the instrument or manually." ;
                            skos:example "true"^^xsd:boolean .


###  http://rs.gbif.org/terms/miqe/automaticThresholdQuantificationCycle
miqe:automaticThresholdQuantificationCycle rdf:type owl:DatatypeProperty ;
                                           rdfs:label "Automatic Threshold Quantification Cycle" ;
                                           skos:definition "Whether the threshold was set by the instrument or manually." ;
                                           skos:example "true"^^xsd:boolean .


###  http://rs.gbif.org/terms/miqe/baselineValue
miqe:baselineValue rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:integer ;
                   rdfs:label "Baseline Value" ;
                   skos:definition "The number of cycles when fluorescence signal from the target amplification is below background fluorescence not originated from the real target amplification." ;
                   skos:example 15 .


###  http://rs.gbif.org/terms/miqe/contaminationAssessment
miqe:contaminationAssessment rdf:type owl:DatatypeProperty ;
                             rdfs:label "Contamination Assessment" ;
                             skos:definition "true"^^xsd:boolean ,
                                             "Whether DNA or RNA contamination assessment was done or not." .


###  http://rs.gbif.org/terms/miqe/estimatedNumberOfCopies
miqe:estimatedNumberOfCopies rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:integer ;
                             rdfs:label "Estimated Number Of Copies" ;
                             skos:definition "Number of target molecules per µl. Mean copies per partition (?) can be calculated using the number of partitions (n) and the estimated copy number in the total volume of all partitions (m) with a formula ?=m/n." ;
                             skos:example 10300 .


###  http://rs.gbif.org/terms/miqe/experimentalVariance
miqe:experimentalVariance rdf:type owl:DatatypeProperty ;
                          rdfs:label "Experimental Variance" ;
                          skos:definition "Multiple biological replicates are encouraged to assess total experimental variation. When single dPCR experiments are performed, a minimal estimate of variance due to counting error alone must be calculated from the binomial (or suitable equivalent) distribution." .


###  http://rs.gbif.org/terms/miqe/partitionVolume
miqe:partitionVolume rdf:type owl:DatatypeProperty ;
                     rdfs:label "Partition Volume" ;
                     skos:definition "An accurate estimation of partition volume. The sum of the partitions multiplied by the partition volume will enable the total volume of the reaction to be calculated." ;
                     skos:example 1 .


###  http://rs.gbif.org/terms/miqe/partitionVolumeUnit
miqe:partitionVolumeUnit rdf:type owl:DatatypeProperty ;
                         rdfs:label "Partition Volume Unit" ;
                         skos:definition "Unit used for partition volume." ;
                         skos:example "nl" .


###  http://rs.gbif.org/terms/miqe/pcr_analysis_software
miqe:pcr_analysis_software rdf:type owl:DatatypeProperty ;
                           rdfs:label "PCR Analysis Software" ;
                           skos:definition "The program used to analyse the d(d)PCR runs." ;
                           skos:example "BIO-RAD QuantaSoft" .


###  http://rs.gbif.org/terms/miqe/pcr_primer_lod
miqe:pcr_primer_lod rdf:type owl:DatatypeProperty ;
                    rdfs:label "pcr_primer_lod" ;
                    skos:definition "The assay’s ability to detect the target at low levels." .


###  http://rs.gbif.org/terms/miqe/pcr_primer_loq
miqe:pcr_primer_loq rdf:type owl:DatatypeProperty ;
                    rdfs:label "pcr_primer_loq" ;
                    skos:definition "The assay’s ability to quantify copy number at low levels." .


###  http://rs.gbif.org/terms/miqe/probeQuencher
miqe:probeQuencher rdf:type owl:DatatypeProperty ;
                   rdfs:label "Fluoroprobe Quencher" ;
                   skos:definition "Type of quencher used. The quencher molecule quenches the fluorescence emitted by the fluorophore when excited by the cycler’s light source As long as fluorophore and the quencher are in proximity, quenching inhibits any fluorescence signals." ;
                   skos:example "NFQ-MGB" .


###  http://rs.gbif.org/terms/miqe/probeReporter
miqe:probeReporter rdf:type owl:DatatypeProperty ;
                   rdfs:label "Fluoroprobe Reporter" ;
                   skos:definition "Type of fluorophore (reporter) used. Probe anneals within amplified target DNA. Polymerase activity degrades the probe that has annealed to the template, and the probe releases the fluorophore from it and breaks the proximity to the quencher, thus allowing fluorescence of the fluorophore." ;
                   skos:example "FAM" .


###  http://rs.gbif.org/terms/miqe/quantificationCycle
miqe:quantificationCycle rdf:type owl:DatatypeProperty ;
                         rdfs:label "Quantification Cycle" ;
                         skos:definition "The number of cycles required for the fluorescent signal to cross a given value threshold above the baseline. Quantification cycle (Cq), threshold cycle (Ct), crossing point (Cp), and take-off point (TOP) refer to the same value from the real-time instrument. Use of quantification cycle (Cq), is preferable according to the RDML (Real-Time PCR Data Markup Language) data standard (http://www.rdml.org)." ;
                         skos:example 37.9450950622558 .


###  http://rs.gbif.org/terms/miqe/thresholdQuantificationCycle
miqe:thresholdQuantificationCycle rdf:type owl:DatatypeProperty ;
                                  rdfs:range xsd:decimal ;
                                  rdfs:label "Quantification Cycle Threshold" ;
                                  skos:definition "Threshold for change in fluorescence signal between cycles." ;
                                  skos:example 0.3 .


###  http://rs.tdwg.org/ac/terms/MetadataLanguageLiteral
ac:MetadataLanguageLiteral rdf:type owl:DatatypeProperty ;
                           rdfs:label "Metadata Language Literal" ;
                           skos:definition "Language of description and other metadata (but not necessarily of the image itself) represented as an ISO639-2 three letter language code." .


###  http://rs.tdwg.org/ac/terms/attributionLinkURL
ac:attributionLinkURL rdf:type owl:DatatypeProperty ;
                      rdfs:label "Attribution Link URL" ;
                      skos:definition "The URL where information about ownership, attribution, etc. of the resource may be found." .


###  http://rs.tdwg.org/ac/terms/attributionLogoURL
ac:attributionLogoURL rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:string ;
                      rdfs:label "Attribution Logo URL" ;
                      skos:definition "The URL of the icon or logo image to appear in source attribution." ;
                      skos:example "http://www.morphbank.net/images/userLogos/11a.jpg" .


###  http://rs.tdwg.org/ac/terms/caption
ac:caption rdf:type owl:DatatypeProperty ;
           rdfs:label "Caption" ;
           skos:definition "Free-form text to be displayed together with (rather than instead of) a resource that is suitable for captions (especially images)." .


###  http://rs.tdwg.org/ac/terms/captureDevice
ac:captureDevice rdf:type owl:DatatypeProperty ;
                 rdfs:label "Capture Device" ;
                 skos:definition "Free form text describing the device or devices used to create the resource." ;
                 skos:example "Canon Supershot 2000" ,
                              "Makroscan Scanner 2000" ,
                              "SEM (Scanning Electron Microscope)" ,
                              "Zeiss Axioscope with Camera IIIu" .


###  http://rs.tdwg.org/ac/terms/commenterLiteral
ac:commenterLiteral rdf:type owl:DatatypeProperty ;
                    rdfs:label "Commenter Literal" ;
                    skos:definition "A name of a dcterms:Agent primarily responsible for providing the ac:comments" .


###  http://rs.tdwg.org/ac/terms/comments
ac:comments rdf:type owl:DatatypeProperty ;
            rdfs:label "Comments" ;
            skos:definition "Any comment provided on the dwc:Media resource, as free-form text." .


###  http://rs.tdwg.org/ac/terms/digitizationDate
ac:digitizationDate rdf:type owl:DatatypeProperty ;
                    rdfs:label "Digitization Date" ;
                    skos:definition "A date on which the first digital version of a resource was created, if different from xmp:CreateDate." .


###  http://rs.tdwg.org/ac/terms/endTime
ac:endTime rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:decimal ;
           rdfs:label "End Time In Seconds" ;
           skos:definition "The end of a temporal region, specified as an absolute offset relative to the beginning of a dwc:Media resource (this corresponds to Normal Play Time RFC 2326), specified as seconds, with an optional fractional part to indicate milliseconds or finer." .


###  http://rs.tdwg.org/ac/terms/endTimestamp
ac:endTimestamp rdf:type owl:DatatypeProperty ;
                rdfs:label "End Time Stamp" ;
                skos:definition "The end of a temporal region, specified as real-world clock time ISO 8601 timestamps, using UTC timezone, with an optional fractional part to indicate milliseconds or finer. There is no limit on the number of decimal places for the decimal fraction." .


###  http://rs.tdwg.org/ac/terms/frameRate
ac:frameRate rdf:type owl:DatatypeProperty ;
             rdfs:label "Frame Rate" ;
             skos:definition "The decimal fraction representing the frequency (rate) at which consecutive images (frames) were captured in real time for a dcmi:MovingImage, expressed as the number of frames per second." ;
             skos:example 0.2 ,
                          60 .


###  http://rs.tdwg.org/ac/terms/freqHigh
ac:freqHigh rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:decimal ;
            rdfs:label "Upper Frequency Bound" ;
            skos:definition 60 ,
                            "The highest frequency of the phenomena reflected in the multimedia item or Region of Interest." .


###  http://rs.tdwg.org/ac/terms/freqLow
ac:freqLow rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:decimal ;
           rdfs:label "Lower Frequency Bound" ;
           skos:definition 60 ,
                           "The lowest frequency of the phenomena reflected in the multimedia item or Region of Interest." .


###  http://rs.tdwg.org/ac/terms/fundingAttribution
ac:fundingAttribution rdf:type owl:DatatypeProperty ;
                      rdfs:label "Funding Attribution" ;
                      skos:definition "A list (concatenated and separated) of names of the funding organizations or agencies that provided funding for a project." ;
                      skos:example "Artsdatabanken" ,
                                   "National Science Foundation" ,
                                   "Norges forskningsråd" ,
                                   "Ocean Census | Nippon Foundation" .


###  http://rs.tdwg.org/ac/terms/furtherInformationURL
ac:furtherInformationURL rdf:type owl:DatatypeProperty ;
                         rdfs:label "Further Information URL" ;
                         skos:definition "A URL of a website that provides additional information about the version of the dwc:Media resource that is provided by the Service Access Point." .


###  http://rs.tdwg.org/ac/terms/hashFunction
ac:hashFunction rdf:type owl:DatatypeProperty ;
                rdfs:label "Hash Function" ;
                skos:definition "The cryptographic hash function used to compute the value given in the ac:hashValue." ;
                skos:example "MD5" ,
                             "SHA-1" ,
                             "SHA-224" ,
                             "SHA-256" ,
                             "SHA-384" ,
                             "SHA-512" ,
                             "SHA-512/224" ,
                             "SHA-512/256" .


###  http://rs.tdwg.org/ac/terms/hashValue
ac:hashValue rdf:type owl:DatatypeProperty ;
             rdfs:label "Hash Value" ;
             skos:definition "The value computed by an ac:hashFunction applied to the media that will be delivered at the access point." .


###  http://rs.tdwg.org/ac/terms/heightFrac
ac:heightFrac rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:decimal ;
              rdfs:label "Fractional Height" ;
              skos:definition "The height of the bounding rectangle, expressed as a decimal fraction of the height of a dwc:Media resource." ;
              skos:example 0.5 ,
                           1 .


###  http://rs.tdwg.org/ac/terms/licenseLogoURL
ac:licenseLogoURL rdf:type owl:DatatypeProperty ;
                  rdfs:label "License Logo URL" ;
                  skos:definition "A URL providing access to a logo that symbolizes a dcterms:license." ;
                  skos:example "http://i.creativecommons.org/l/by-nc-sa/3.0/us/88x31.png" .


###  http://rs.tdwg.org/ac/terms/licensingException
ac:licensingException rdf:type owl:DatatypeProperty ;
                      rdfs:label "Licensing Exception" ;
                      skos:definition "The licensing statement for this variant of the dwc:Media resource if different from that given in the dcterms:license property of the resource." .


###  http://rs.tdwg.org/ac/terms/mediaDuration
ac:mediaDuration rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:decimal ;
                 rdfs:label "Media Duration" ;
                 skos:definition "The playback duration of an audio or video file in seconds." .


###  http://rs.tdwg.org/ac/terms/mediaSpeed
ac:mediaSpeed rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:decimal ;
              rdfs:label "Media Speed" ;
              skos:definition "The decimal fraction representing the natural speed over the encoded speed." ;
              skos:example 0.2 ,
                           60 .


###  http://rs.tdwg.org/ac/terms/metadataCreator
ac:metadataCreator rdf:type owl:DatatypeProperty ;
                   rdfs:label "Metadata Creator ID" ;
                   skos:definition "An identifier for a dcterms:Agent that created the resource metadata." .


###  http://rs.tdwg.org/ac/terms/metadataCreatorLiteral
ac:metadataCreatorLiteral rdf:type owl:DatatypeProperty ;
                          rdfs:label "Metadata Creator" ;
                          skos:definition "A name of a dcterms:Agent that created the resource metadata." .


###  http://rs.tdwg.org/ac/terms/metadataLanguageLiteral
ac:metadataLanguageLiteral rdf:type owl:DatatypeProperty ;
                           rdfs:label "Language of description and other metadata (but not necessarily of the image itself) represented as an ISO639-2 three letter language code." ,
                                      "Metadata Language Literal" .


###  http://rs.tdwg.org/ac/terms/metadataProvider
ac:metadataProvider rdf:type owl:DatatypeProperty ;
                    rdfs:label "Metdata Provider ID" ;
                    skos:definition "An identifier for a dcterms:Agent that provided the resource metadata." .


###  http://rs.tdwg.org/ac/terms/metadataProviderLiteral
ac:metadataProviderLiteral rdf:type owl:DatatypeProperty ;
                           rdfs:label "Metadata Provider" ;
                           skos:definition "A name of a dcterms:Agent that provided the resource metadata." .


###  http://rs.tdwg.org/ac/terms/physicalSetting
ac:physicalSetting rdf:type owl:DatatypeProperty ;
                   rdfs:label "Physical Setting" ;
                   skos:definition "The setting of the content represented in a dwc:Media resource, such as images, sounds, and movies if the provider deems them relevant." ;
                   skos:example "Artificial" ,
                                "Edited" ,
                                "Natural" .


###  http://rs.tdwg.org/ac/terms/provider
ac:provider rdf:type owl:DatatypeProperty ;
            rdfs:label "Provider ID" ;
            skos:definition "An identifier for a dcterms:Agent responsible for presenting the dwc:Media resource." .


###  http://rs.tdwg.org/ac/terms/providerLiteral
ac:providerLiteral rdf:type owl:DatatypeProperty ;
                   rdfs:label "Provider" ;
                   skos:definition "A name of a dcterms:Agent responsible for presenting the dwc:Media resource." .


###  http://rs.tdwg.org/ac/terms/providerManagedID
ac:providerManagedID rdf:type owl:DatatypeProperty ;
                     rdfs:label "Provider Managed ID" ;
                     skos:definition "A free-form identifier (a simple number, an alphanumeric code, a URL, etc.) for the resource that is unique and meaningful primarily for the data provider." .


###  http://rs.tdwg.org/ac/terms/radius
ac:radius rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:integer ;
          rdfs:label "Radius" ;
          skos:definition "The radius of a bounding circle or arc, expressed as a fraction of the width of a dwc:Media resource." ;
          skos:example 100 .


###  http://rs.tdwg.org/ac/terms/resourceCreationTechnique
ac:resourceCreationTechnique rdf:type owl:DatatypeProperty ;
                             rdfs:label "Resource Creation Technique" ;
                             skos:definition "Information about technical aspects of the creation and digitization process of the resource. This includes modification steps (\\\"retouching\\\") after the initial resource capture." .


###  http://rs.tdwg.org/ac/terms/reviewerComments
ac:reviewerComments rdf:type owl:DatatypeProperty ;
                    rdfs:label "Reviewer Comments" ;
                    skos:definition "Any comment provided by a reviewer with expertise in the subject, as free-form text." .


###  http://rs.tdwg.org/ac/terms/reviewerLiteral
ac:reviewerLiteral rdf:type owl:DatatypeProperty ;
                   rdfs:label "Reviewer Literal" ;
                   skos:definition "A name of a dcterms:Agent primarily responsible for providing the ac:reviewerComments" .


###  http://rs.tdwg.org/ac/terms/startTime
ac:startTime rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:decimal ;
             rdfs:label "Start Time In Seconds" ;
             skos:definition "The beginning of a temporal region, specified as an absolute offset relative to the beginning of a dwc:Media resource (this corresponds to Normal Play Time RFC 2326), specified as seconds, with an optional fractional part to indicate milliseconds or finer." .


###  http://rs.tdwg.org/ac/terms/startTimestamp
ac:startTimestamp rdf:type owl:DatatypeProperty ;
                  rdfs:label "Start Time Stamp" ;
                  skos:definition "The beginning of a temporal region, specified as real-world clock time ISO 8601 timestamps, using UTC timezone, with an optional fractional part to indicate milliseconds or finer. There is no limit on the number of decimal places for the decimal fraction." .


###  http://rs.tdwg.org/ac/terms/subjectOrientationLiteral
ac:subjectOrientationLiteral rdf:type owl:DatatypeProperty ;
                             rdfs:label "Subject Orientation Literal" ;
                             skos:definition "Specific orientation (= direction, view angle) of the subject represented in the dwc:Media resource with respect to the acquisition device, denoted by a controlled value string." .


###  http://rs.tdwg.org/ac/terms/subjectPartLiteral
ac:subjectPartLiteral rdf:type owl:DatatypeProperty ;
                      rdfs:label "Subject Part Literal" ;
                      skos:definition "The portion or product of organism morphology, behaviour, environment, etc. that is either predominantly shown or particularly well exemplified by the dwc:Media resource, denoted by a controlled value string." .


###  http://rs.tdwg.org/ac/terms/subtypeLiteral
ac:subtypeLiteral rdf:type owl:DatatypeProperty ;
                  rdfs:label "Subtype Literal" ;
                  skos:definition "A subcategory that allows further specialization of a dwc:Media resource type than mediaType." .


###  http://rs.tdwg.org/ac/terms/tag
ac:tag rdf:type owl:DatatypeProperty ;
       rdfs:label "Tag" ;
       skos:definition "General keywords or tags." ;
       skos:example "flower color" ,
                    "flower diagram" ,
                    "leaf" .


###  http://rs.tdwg.org/ac/terms/timeOfDay
ac:timeOfDay rdf:type owl:DatatypeProperty ;
             rdfs:label "Time Of Day" ;
             skos:definition "Free text information beyond exact clock times." ;
             skos:example "afternoon" ,
                          "twilight" .


###  http://rs.tdwg.org/ac/terms/variantDescription
ac:variantDescription rdf:type owl:DatatypeProperty ;
                      rdfs:label "Variant Description" ;
                      skos:definition "Text that describes this Service Access Point variant." .


###  http://rs.tdwg.org/ac/terms/variantLiteral
ac:variantLiteral rdf:type owl:DatatypeProperty ;
                  rdfs:label "Variant Literal" ;
                  skos:definition "The category describing this Service Access Point variant, denoted by a controlled value string." .


###  http://rs.tdwg.org/ac/terms/widthFrac
ac:widthFrac rdf:type owl:DatatypeProperty ;
             rdfs:label "Fractional Width" ;
             skos:definition "The width of the bounding rectangle, expressed as a decimal fraction of the width of a dwc:Media resource." ;
             skos:example 0.5 ,
                          1 .


###  http://rs.tdwg.org/ac/terms/xFrac
ac:xFrac rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:decimal ;
         rdfs:label "Fractional X" ;
         skos:definition "The horizontal position of a reference point, measured from the left side of a dwc:Media resource and expressed as a decimal fraction of the width of a dwc:Media resource." ;
         skos:example 0.5 ,
                      1 .


###  http://rs.tdwg.org/ac/terms/yFrac
ac:yFrac rdf:type owl:DatatypeProperty ;
         rdfs:label "Fractional Y" ;
         skos:definition "The vertical position of a reference point, measured from the top of a dwc:Media resource and expressed as a decimal fraction of the height of a dwc:Media resource." ;
         skos:example 0.5 ,
                      1 .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeConversionProtocol
chrono:chronometricAgeConversionProtocol rdf:type owl:DatatypeProperty ;
                                         rdfs:label "Chronometric Age Conversion Protocol" ;
                                         skos:definition "A description of or reference to a dwc:Protocol used to convert a chrono:uncalibratedChronometricAge into a chronometric age in years, as captured in the chrono:earliestChronometricAge, chrono:earliestChronometricAgeReferenceSystem, chrono:latestChronometricAge, and chrono:latestChronometricAgeReferenceSystem fields." ;
                                         skos:example "INTCAL13" ,
                                                      "sequential 6 phase Bayesian model and IntCal13 calibration" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeDeterminedBy
chrono:chronometricAgeDeterminedBy rdf:type owl:DatatypeProperty ;
                                   rdfs:label "Chronometric Age Determined By" ;
                                   skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for determining the chrono:ChronometricAge." ;
                                   skos:example "Michelle LeFebvre | Neill Wallis" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeDeterminedDate
chrono:chronometricAgeDeterminedDate rdf:type owl:DatatypeProperty ;
                                     rdfs:label "Chronometric Age Determined Date" ;
                                     skos:definition "A date on which a chrono:ChronometricAge was determined." ;
                                     skos:example "1809-02-12" ,
                                                  "1906-06" ,
                                                  "1963-03-08T14:07-0600" ,
                                                  "1971" ,
                                                  "2009-02-20T08:40Z" ,
                                                  "2018-08-29T15:19" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeID
chrono:chronometricAgeID rdf:type owl:DatatypeProperty ;
                         rdfs:label "Chronometric Age ID" ;
                         skos:definition "An identifier for a chrono:ChronometricAge." ;
                         skos:example "https://www.canadianarchaeology.ca/samples/70673" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeProtocol
chrono:chronometricAgeProtocol rdf:type owl:DatatypeProperty ;
                               rdfs:label "Chronometric Age Protocol" ;
                               skos:definition "A description of or reference to a dwc:Protocol used to determine a chrono:ChronometricAge." ;
                               skos:example "K-Ar dates for the lower most marker tuff" ,
                                            "ceramic seriation" ,
                                            "historic documentation" ,
                                            "radiocarbon AMS" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeReferences
chrono:chronometricAgeReferences rdf:type owl:DatatypeProperty ;
                                 rdfs:label "Chronometric Age References" ;
                                 skos:definition "A list (concatenated and separated) of dcterms:BibliographicResources associated with a chrono:ChronometricAge." ;
                                 skos:example "Pluckhahn, Thomas J., Neill J. Wallis, and Victor D. Thompson. 2020 The History and Future of Migrationist Explanation in the Archaeology of the Eastern Woodlands: A Review and Case Study of the Woodland Period Gulf Coast. Journal of Archaeological Research. https://doi.org/10.1007/s10814-019-09140-x" .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeRemarks
chrono:chronometricAgeRemarks rdf:type owl:DatatypeProperty ;
                              rdfs:label "Chronometric Age Remarks" ;
                              skos:definition "Comments or notes about a chrono:ChronometricAge." ;
                              skos:example "Beta Analytic number: 323913 | One of the Crassostrea virginica right valve specimens from North Midden Feature 17 was chosen for AMS dating, but it is unclear exactly which specimen it was." .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeUncertaintyInYears
chrono:chronometricAgeUncertaintyInYears rdf:type owl:DatatypeProperty ;
                                         rdfs:label "Chronometric Age Uncertainty In Years" ;
                                         skos:definition "A temporal uncertainty of a chrono:earliestChronometricAge and chrono:latestChronometricAge in years." ;
                                         skos:example 100 .


###  http://rs.tdwg.org/chrono/terms/chronometricAgeUncertaintyMethod
chrono:chronometricAgeUncertaintyMethod rdf:type owl:DatatypeProperty ;
                                        rdfs:label "Chronometric Age Uncertainty Method" ;
                                        skos:definition "A method used to generate a value of chrono:ChronometricAgeUncertaintyInYears." ;
                                        skos:example "2-sigma calibrated range" ,
                                                     "Half of 95% confidence interval" .


###  http://rs.tdwg.org/chrono/terms/earliestChronometricAge
chrono:earliestChronometricAge rdf:type owl:DatatypeProperty ;
                               rdfs:label "Earliest Chronometric Age" ;
                               skos:definition "A maximum/earliest/oldest possible age of a dwc:MaterialEntity as determined by a dating method." ;
                               skos:example "100" .


###  http://rs.tdwg.org/chrono/terms/earliestChronometricAgeReferenceSystem
chrono:earliestChronometricAgeReferenceSystem rdf:type owl:DatatypeProperty ;
                                              rdfs:label "Earliest Chronometric Age Reference System" ;
                                              skos:definition "A reference system associated with a chrono:earliestChronometricAge." ;
                                              skos:example "AD" ,
                                                           "BCE" ,
                                                           "BP" ,
                                                           "Ga" ,
                                                           "Ma" ,
                                                           "ka" ,
                                                           "kya" ,
                                                           "mya" .


###  http://rs.tdwg.org/chrono/terms/latestChronometricAge
chrono:latestChronometricAge rdf:type owl:DatatypeProperty ;
                             rdfs:label "Latest Chronometric Age" ;
                             skos:definition "A minimum/latest/youngest possible age of a dwc:MaterialEntity as determined by a dating method." ;
                             skos:example "27" .


###  http://rs.tdwg.org/chrono/terms/latestChronometricAgeReferenceSystem
chrono:latestChronometricAgeReferenceSystem rdf:type owl:DatatypeProperty ;
                                            rdfs:label "Latest Chronometric Age Reference System" ;
                                            skos:definition "A reference system associated with a chrono:latestChronometricAge." ;
                                            skos:example "AD" ,
                                                         "BCE" ,
                                                         "BP" ,
                                                         "Ga" ,
                                                         "Ma" ,
                                                         "ka" ,
                                                         "kya" ,
                                                         "mya" .


###  http://rs.tdwg.org/chrono/terms/materialDated
chrono:materialDated rdf:type owl:DatatypeProperty ;
                     rdfs:label "Material Dated" ;
                     skos:definition "A description of a dwc:MaterialEntity on which a chrono:ChronometricAgeProtocol was actually performed, if known." ;
                     skos:example "Charcoal found in Stratum V" ,
                                  "Double Tuff" ,
                                  "charred wood" ,
                                  "tooth" .


###  http://rs.tdwg.org/chrono/terms/materialDatedID
chrono:materialDatedID rdf:type owl:DatatypeProperty ;
                       rdfs:label "Material Dated ID" ;
                       skos:definition "An identifier for a dwc:MaterialEntity on which a chrono:ChronometricAgeProtocol was performed, if applicable." ;
                       skos:example "https://www.ebi.ac.uk/metagenomics/samples/SRS1930158" .


###  http://rs.tdwg.org/chrono/terms/materialDatedRelationship
chrono:materialDatedRelationship rdf:type owl:DatatypeProperty ;
                                 rdfs:label "Material Dated Relationship" ;
                                 skos:definition "A relationship of a chrono:materialDated to a dwc:MaterialEntity, from which a chrono:ChronometricAge of the related dwc:MaterialEntity and any related dwc:Occurrence is inferred." ;
                                 skos:example "inContextWith" ,
                                              "sameAs" ,
                                              "stratigraphicallyCorrelatedWith" ,
                                              "subsampleOf" .


###  http://rs.tdwg.org/chrono/terms/uncalibratedChronometricAge
chrono:uncalibratedChronometricAge rdf:type owl:DatatypeProperty ;
                                   rdfs:label "Uncalibrated Chronometric Age" ;
                                   skos:definition "An output of a dating assay before it is calibrated into an age using a specific conversion protocol." ;
                                   skos:example "1510 +/- 25 14C yr BP, 16.26 Ma +/- 0.016" .


###  http://rs.tdwg.org/chrono/terms/verbatimChronometricAge
chrono:verbatimChronometricAge rdf:type owl:DatatypeProperty ;
                               rdfs:label "Verbatim Chronometric Age" ;
                               skos:definition "A verbatim age for a dwc:Event, whether reported by a dating assay, associated references, or legacy information." ;
                               skos:example "27 BC to 14 AD, stratigraphically pre-1104" .


###  http://rs.tdwg.org/dwc/terms/agentID
dwc:agentID rdf:type owl:DatatypeProperty ;
            rdfs:label "Agent ID" ;
            skos:definition "An identifier for a dcterms:Agent." .


###  http://rs.tdwg.org/dwc/terms/agentRemarks
dwc:agentRemarks rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:label "Agent Remarks" ;
                 skos:definition "Comments or notes about a dcterms:Agent." .


###  http://rs.tdwg.org/dwc/terms/agentType
dwc:agentType rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "Recommended best practice is to use a controlled vocabulary." ;
              rdfs:label "Agent Type" ;
              skos:definition "A category that best matches the nature of a dcterms:Agent." ;
              skos:example "camera" ,
                           "group" ,
                           "organization" ,
                           "person" .


###  http://rs.tdwg.org/dwc/terms/assayType
dwc:assayType rdf:type owl:DatatypeProperty ;
              rdfs:label "Assay Type" ;
              skos:definition "A method used in the study to detect taxon/taxa of interest in the sample." ;
              skos:example "metabarcoding" ,
                           "other" ,
                           "targeted" .


###  http://rs.tdwg.org/dwc/terms/assertionBy
dwc:assertionBy rdf:type owl:DatatypeProperty ;
                rdfs:label "Assertion By" ;
                skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for making a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionByID
dwc:assertionByID rdf:type owl:DatatypeProperty ;
                  rdfs:label "Assertion By ID" ;
                  skos:definition "An identifier for a dcterms:Agent responsible for making a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionEffectiveDate
dwc:assertionEffectiveDate rdf:type owl:DatatypeProperty ;
                           rdfs:label "Assertion Effective Date" ;
                           skos:definition "A date on which a state or measurement of a dwc:Assertion was deemed to first be in effect." ;
                           skos:example "1809-02-12" ,
                                        "1900/1909" ,
                                        "1906-06" ,
                                        "1963-03-08T14:07-06:00" ,
                                        "1971" ,
                                        "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z" ,
                                        "2007-11-13/15" ,
                                        "2009-02-20T08:40Z" ,
                                        "2018-08-29T15:19" .


###  http://rs.tdwg.org/dwc/terms/assertionError
dwc:assertionError rdf:type owl:DatatypeProperty ;
                   rdfs:label "Assertion Error" ;
                   skos:definition "The description of the potential error associated with dwc:assertionValueNumeric." ;
                   skos:example "0.01" ,
                                "normal distribution with variation of 2 m" .


###  http://rs.tdwg.org/dwc/terms/assertionID
dwc:assertionID rdf:type owl:DatatypeProperty ;
                rdfs:label "Assertion ID" ;
                skos:definition "An identifier for a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionMadeDate
dwc:assertionMadeDate rdf:type owl:DatatypeProperty ;
                      rdfs:label "Assertion Made Date" ;
                      skos:definition "A date on which a dwc:Assertion was created." ;
                      skos:example "1809-02-12" ,
                                   "1900/1909" ,
                                   "1906-06" ,
                                   "1963-03-08T14:07-06:00" ,
                                   "1971" ,
                                   "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z" ,
                                   "2007-11-13/15" ,
                                   "2009-02-20T08:40Z" ,
                                   "2018-08-29T15:19" .


###  http://rs.tdwg.org/dwc/terms/assertionProtocolID
dwc:assertionProtocolID rdf:type owl:DatatypeProperty ;
                        rdfs:label "Assertion Protocol ID" ;
                        skos:definition "An identifier for a dwc:Protocol used to make a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionProtocols
dwc:assertionProtocols rdf:type owl:DatatypeProperty ;
                       rdfs:label "Assertion Protocols" ;
                       skos:definition "Names of, references to, or descriptions of dwc:Protocols used in making a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionReferences
dwc:assertionReferences rdf:type owl:DatatypeProperty ;
                        rdfs:label "Assertion References" ;
                        skos:definition "A list (concatenated and separated) of dcterms:BibliographicResources associated with a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionRemarks
dwc:assertionRemarks rdf:type owl:DatatypeProperty ;
                     rdfs:label "Assertion Remarks" ;
                     skos:definition "Comments or notes about a dwc:Assertion." .


###  http://rs.tdwg.org/dwc/terms/assertionType
dwc:assertionType rdf:type owl:DatatypeProperty ;
                  rdfs:label "Assertion Type" ;
                  skos:definition "A category that best matches the nature of a dwc:Assertion." ;
                  skos:example "survey area" ,
                               "tail length" ,
                               "temperature" ,
                               "trap line length" ,
                               "trap type" .


###  http://rs.tdwg.org/dwc/terms/assertionUnit
dwc:assertionUnit rdf:type owl:DatatypeProperty ;
                  rdfs:label "Assertion Unit" ,
                             "Unit associated with the value in dwc:assertionValue or dwc:assertionValueNumeric." ;
                  skos:example "g" ,
                               "m" ,
                               "ml" ,
                               "s" .


###  http://rs.tdwg.org/dwc/terms/assertionValue
dwc:assertionValue rdf:type owl:DatatypeProperty ;
                   rdfs:label "Assertion Value" ;
                   skos:definition "An asserted value, if it is not numeric." .


###  http://rs.tdwg.org/dwc/terms/assertionValueNumeric
dwc:assertionValueNumeric rdf:type owl:DatatypeProperty ;
                          rdfs:label "Assertion Value Numeric" ;
                          skos:definition "An asserted value, if it is numeric." .


###  http://rs.tdwg.org/dwc/terms/associatedOrganisms
dwc:associatedOrganisms rdf:type owl:DatatypeProperty ;
                        rdfs:label "Associated Organisms" ;
                        skos:definition "A list (concatenated and separated) of identifiers of other dwc:Organisms and the associations of this dwc:Organism to each of them." ;
                        skos:example "\"parent of\": \"http://arctos.database.museum/guid/MSB:Mamm:196208\" | \"parent of\": \"http://arctos.database.museum/guid/MSB:Mamm:196523\" | \"sibling of\": \"http://arctos.database.museum/guid/MSB:Mamm:142638\"" ,
                                     "\"sibling of\": \"http://arctos.database.museum/guid/DMNS:Mamm:14171\"" .


###  http://rs.tdwg.org/dwc/terms/associatedReferences
dwc:associatedReferences rdf:type owl:DatatypeProperty ;
                         rdfs:label "Associated References" ;
                         skos:definition "A list (concatenated and separated) of identifiers (publication, bibliographic reference, global unique identifier, URI) of literature associated with the dwc:Occurrence." ;
                         skos:example "Christopher J. Conroy, Jennifer L. Neuwald. 2008. Phylogeographic study of the California vole, Microtus californicus Journal of Mammalogy, 89(3):755-767." ,
                                      "Steven R. Hoofer and Ronald A. Van Den Bussche. 2001. Phylogenetic Relationships of Plecotine Bats and Allies Based on Mitochondrial Ribosomal Sequences. Journal of Mammalogy 82(1):131-137. | Walker, Faith M., Jeffrey T. Foster, Kevin P. Drees, Carol L. Chambers. 2014. Spotted bat (Euderma maculatum) microsatellite discovery using illumina sequencing. Conservation Genetics Resources." ,
                                      "http://www.sciencemag.org/cgi/content/abstract/322/5899/261" .


###  http://rs.tdwg.org/dwc/terms/associatedSequences
dwc:associatedSequences rdf:type owl:DatatypeProperty ;
                        rdfs:label "Associated Sequences" ;
                        skos:definition "A list (concatenated and separated) of identifiers (publication, global unique identifier, URI) of genetic sequence information associated with the dwc:MaterialEntity." ;
                        skos:example "http://www.ncbi.nlm.nih.gov/nuccore/GU328060 | http://www.ncbi.nlm.nih.gov/nuccore/AF326093" ,
                                     "http://www.ncbi.nlm.nih.gov/nuccore/U34853.1" .


###  http://rs.tdwg.org/dwc/terms/bed
dwc:bed rdf:type owl:DatatypeProperty ;
        rdfs:label "Bed" ;
        skos:definition "The full name of the lithostratigraphic bed from which the dwc:MaterialEntity was collected." ;
        skos:example "Harlem coal" .


###  http://rs.tdwg.org/dwc/terms/behavior
dwc:behavior rdf:type owl:DatatypeProperty ;
             rdfs:label "Behavior" ;
             skos:definition "The behavior shown by the subject at the time the dwc:Occurrence was recorded." ;
             skos:example "foraging" ,
                          "roosting" ,
                          "running" .


###  http://rs.tdwg.org/dwc/terms/caste
dwc:caste rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:string ;
          rdfs:label "Caste" ;
          skos:definition "Categorisation of individuals for eusocial species (including some mammals and arthropods)." ;
          skos:example "ergatoid" ,
                       "intercaste" ,
                       "male alate" ,
                       "minor worker" ,
                       "queen" ,
                       "soldier" .


###  http://rs.tdwg.org/dwc/terms/catalogNumber
dwc:catalogNumber rdf:type owl:DatatypeProperty ;
                  rdfs:label "Catalog Number" ;
                  skos:definition "An identifier (preferably unique) for a dwc:MaterialEntity within a collection." ;
                  skos:example "145732" ,
                               "145732a" ,
                               "2008.1334" ,
                               "R-4313" .


###  http://rs.tdwg.org/dwc/terms/causeOfDeath
dwc:causeOfDeath rdf:type owl:DatatypeProperty ;
                 rdfs:label "Cause Of Death" ;
                 skos:definition "An indication of the known or suspected cause of death of a dwc:Organism." ;
                 skos:example "burned" ,
                              "disease" ,
                              "drowned" ,
                              "herbicide" ,
                              "infanticide" ,
                              "old age" ,
                              "poisoned" ,
                              "roadkill" ,
                              "shot" ,
                              "starved" ,
                              "trapped" .


###  http://rs.tdwg.org/dwc/terms/chronometricAgeConversionProtocolID
dwc:chronometricAgeConversionProtocolID rdf:type owl:DatatypeProperty ;
                                        rdfs:label "Chronometric Age Conversion Protocol ID" ;
                                        skos:definition "An identifier for a dwc:Protocol used to convert a chrono:uncalibratedChronometricAge into a chronometric age in years, as captured in the chrono:earliestChronometricAge, chrono:earliestChronometricAgeReferenceSystem, chrono:latestChronometricAge, and chrono:latestChronometricAgeReferenceSystem fields." .


###  http://rs.tdwg.org/dwc/terms/chronometricAgeDeterminedByID
dwc:chronometricAgeDeterminedByID rdf:type owl:DatatypeProperty ;
                                  rdfs:label "Chronometric Age Determined By ID" ;
                                  skos:definition "An identifier for a dcterms:Agent responsible for determining a chrono:ChronometricAge." .


###  http://rs.tdwg.org/dwc/terms/chronometricAgeProtocolID
dwc:chronometricAgeProtocolID rdf:type owl:DatatypeProperty ;
                              rdfs:label "Chronometric Age Protocol ID" ;
                              skos:definition "An identifier for a dwc:Protocol used to determine a chrono:ChronometricAge." .


###  http://rs.tdwg.org/dwc/terms/class
dwc:class rdf:type owl:DatatypeProperty ;
          rdfs:label "Class" ;
          skos:definition "The full scientific name of the class in which the dwc:Taxon is classified." ;
          skos:example "Hepaticopsida" ,
                       "Mammalia" .


###  http://rs.tdwg.org/dwc/terms/collectedBy
dwc:collectedBy rdf:type owl:DatatypeProperty ;
                rdfs:label "Collected By" ;
                skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for collecting a dwc:MaterialEntity." ;
                skos:example "José E. Crespo" ,
                             "Oliver P. Pearson | Anita K. Pearson" .


###  http://rs.tdwg.org/dwc/terms/collectedByID
dwc:collectedByID rdf:type owl:DatatypeProperty ;
                  rdfs:label "Collected By ID" ;
                  skos:definition "An identifier for the dcterms:Agent responsible for collecting a dwc:MaterialEntity." ;
                  skos:example "https://orcid.org/0000-0002-1825-0097" ,
                               "https://ror.org/00mh9zx15" .


###  http://rs.tdwg.org/dwc/terms/collectionCode
dwc:collectionCode rdf:type owl:DatatypeProperty ;
                   rdfs:label "Collection Code" ;
                   skos:definition "A name, acronym, coden, or initialism identifying a collection." ;
                   skos:example "EBIRD" ,
                                "Hildebrandt" ,
                                "Mammals" ,
                                "VP" .


###  http://rs.tdwg.org/dwc/terms/collectionID
dwc:collectionID rdf:type owl:DatatypeProperty ;
                 rdfs:label "Collection ID" ;
                 skos:definition "An identifier for a collection." .


###  http://rs.tdwg.org/dwc/terms/collectorNumber
dwc:collectorNumber rdf:type owl:DatatypeProperty ;
                    rdfs:label "Collector Number" ;
                    skos:definition "An identifier given to a dwc:MaterialEntity at the time it was collected." ;
                    skos:example "OPP 7101" .


###  http://rs.tdwg.org/dwc/terms/continent
dwc:continent rdf:type owl:DatatypeProperty ;
              rdfs:label "Continent" ;
              skos:definition "The name of the continent in which the dcterms:Location occurs." ;
              skos:example "Africa" ,
                           "Antarctica" ,
                           "Asia" ,
                           "Europe" ,
                           "North America" ,
                           "Oceania" ,
                           "South America" .


###  http://rs.tdwg.org/dwc/terms/coordinatePrecision
dwc:coordinatePrecision rdf:type owl:DatatypeProperty ;
                        rdfs:label "Coordinate Precision" ;
                        skos:definition "A decimal representation of the precision of the coordinates given in the dwc:decimalLatitude and dwc:decimalLongitude." ;
                        skos:example 0.00001 ,
                                     0.000278 ,
                                     0.01667 ,
                                     1.0 .


###  http://rs.tdwg.org/dwc/terms/coordinateUncertaintyInMeters
dwc:coordinateUncertaintyInMeters rdf:type owl:DatatypeProperty ;
                                  rdfs:label "Coordinate Uncertainty In Meters" ;
                                  skos:definition "A horizontal distance (in meters) from a given dwc:decimalLatitude and dwc:decimalLongitude describing the smallest circle containing the whole of the dcterms:Location. Zero is not a valid value for this term." ;
                                  skos:example 100 ,
                                               30 ,
                                               71 .


###  http://rs.tdwg.org/dwc/terms/country
dwc:country rdf:type owl:DatatypeProperty ;
            rdfs:label "Country" ;
            skos:definition "The name of the country or major administrative unit in which the dcterms:Location occurs." ;
            skos:example "Colombia" ,
                         "Denmark" ,
                         "España" .


###  http://rs.tdwg.org/dwc/terms/countryCode
dwc:countryCode rdf:type owl:DatatypeProperty ;
                rdfs:label "Country Code" ;
                skos:definition "The standard code for the country in which the dcterms:Location occurs." ;
                skos:example "AR" ,
                             "SV" ,
                             "XZ" ,
                             "ZZ" .


###  http://rs.tdwg.org/dwc/terms/county
dwc:county rdf:type owl:DatatypeProperty ;
           rdfs:label "Second Order Division" ;
           skos:definition "The full, unabbreviated name of the next smaller administrative region than stateProvince (county, shire, department, etc.) in which the dcterms:Location occurs." ;
           skos:example "Los Lagos" ,
                        "Mataró" ,
                        "Missoula" .


###  http://rs.tdwg.org/dwc/terms/cultivarEpithet
dwc:cultivarEpithet rdf:type owl:DatatypeProperty ;
                    rdfs:label "Cultivar Epithet" ;
                    skos:definition "Part of the name of a cultivar, cultivar group or grex that follows the dwc:scientificName." ;
                    skos:example "Atlantis" ,
                                 "King Edward" ,
                                 "Mishmiense" .


###  http://rs.tdwg.org/dwc/terms/dataGeneralizations
dwc:dataGeneralizations rdf:type owl:DatatypeProperty ;
                        rdfs:label "Data Generalizations" ;
                        skos:definition "Actions taken to make the shared data less specific or complete than in its original form. Suggests that alternative data of higher quality may be available on request." ;
                        skos:example "Coordinates generalized from original GPS coordinates to the nearest half degree grid cell." .


###  http://rs.tdwg.org/dwc/terms/datasetID
dwc:datasetID rdf:type owl:DatatypeProperty ;
              rdfs:label "Dataset ID" ;
              skos:definition "An identifier for the set of data. May be a global unique identifier or an identifier specific to a collection or institution." ;
              skos:example "b15d4952-7d20-46f1-8a3e-556a512b04c5" .


###  http://rs.tdwg.org/dwc/terms/datasetName
dwc:datasetName rdf:type owl:DatatypeProperty ;
                rdfs:label "Dataset Name" ;
                skos:definition "The name identifying the data set from which the record was derived." ;
                skos:example "Grinnell Resurvey Mammals" ,
                             "Lacey Ctenomys Recaptures" .


###  http://rs.tdwg.org/dwc/terms/dateIdentified
dwc:dateIdentified rdf:type owl:DatatypeProperty ;
                   rdfs:label "Date Identified" ;
                   skos:definition "The date on which the subject was determined as representing the dwc:Taxon." ;
                   skos:example "1809-02-12" ,
                                "1900/1909" ,
                                "1906-06" ,
                                "1963-03-08T14:07-06:00" ,
                                "1971" ,
                                "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z" ,
                                "2007-11-13/15" ,
                                "2009-02-20T08:40Z" ,
                                "2018-08-29T15:19" .


###  http://rs.tdwg.org/dwc/terms/day
dwc:day rdf:type owl:DatatypeProperty ;
        rdfs:label "Day" ;
        skos:definition "The integer day of the month on which the dwc:Event occurred." ;
        skos:example 28 ,
                     9 .


###  http://rs.tdwg.org/dwc/terms/decimalLatitude
dwc:decimalLatitude rdf:type owl:DatatypeProperty ;
                    rdfs:range xsd:decimal ;
                    rdfs:label "Decimal Latitude" ;
                    skos:definition -41.0983423 ,
                                    "A geographic latitude (in decimal degrees, using the spatial reference system given in dwc:geodeticDatum) of a dcterms:Location." .


###  http://rs.tdwg.org/dwc/terms/decimalLongitude
dwc:decimalLongitude rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:decimal ;
                     rdfs:label "Decimal Longitude" ;
                     skos:definition -121.1761111 ,
                                     "A geographic longitude (in decimal degrees, using the spatial reference system given in dwc:geodeticDatum) of a dcterms:Location." .


###  http://rs.tdwg.org/dwc/terms/degreeOfEstablishment
dwc:degreeOfEstablishment rdf:type owl:DatatypeProperty ;
                          rdfs:label "Degree Of Establishment" ;
                          skos:definition "The degree to which a dwc:Organism survives, reproduces, and expands its range at the given place and time." ;
                          skos:example "captive" ,
                                       "casual" ,
                                       "colonising" ,
                                       "cultivated" ,
                                       "established" ,
                                       "failing" ,
                                       "invasive" ,
                                       "native" ,
                                       "released" ,
                                       "reproducing" ,
                                       "widespreadInvasive" .


###  http://rs.tdwg.org/dwc/terms/derivationEventID
dwc:derivationEventID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Derivation Event ID" ;
                      skos:definition "An identifier for a dwc:Event during which a dwc:MaterialEntity was derived from another dwc:MaterialEntity." .


###  http://rs.tdwg.org/dwc/terms/derivationType
dwc:derivationType rdf:type owl:DatatypeProperty ;
                   rdfs:label "Derivation Type" ;
                   skos:definition "A category that best matches the nature of the derivation of one dwc:MaterialEntity from another dwc:MaterialEntity." ;
                   skos:example "included" ,
                                "sampledFrom" .


###  http://rs.tdwg.org/dwc/terms/derivedFromMaterialEntityID
dwc:derivedFromMaterialEntityID rdf:type owl:DatatypeProperty ;
                                rdfs:label "Derived From Material Entity ID" ;
                                skos:definition "An identifier for a dwc:MaterialEntity from which this dwc:MaterialEntity was derived." .


###  http://rs.tdwg.org/dwc/terms/derivedFromMediaID
dwc:derivedFromMediaID rdf:type owl:DatatypeProperty ;
                       rdfs:label "Derived From Media ID" ;
                       skos:definition "An identifier for a dwc:Media resource from which this dwc:Media resource was derived." .


###  http://rs.tdwg.org/dwc/terms/digitalSpecimenID
dwc:digitalSpecimenID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Digital Specimen ID" ;
                      skos:definition "An identifier for a Digital Specimen resource." ;
                      skos:example "doi:10.3535/M42-Z4P-DRD" ,
                                   "https://doi.org/10.3535/M42-Z4P-DRD" ,
                                   "https://doi.org/10.3535/M42-Z4P-DRD?locatt=/1" ,
                                   "https://doi.org/10.3535/M42-Z4P-DRD?urlappend=/1" .


###  http://rs.tdwg.org/dwc/terms/discipline
dwc:discipline rdf:type owl:DatatypeProperty ;
               rdfs:label "Discipline" ;
               skos:definition "The primary branch or branches of knowledge represented by the dwc:MaterialEntity." ;
               skos:example "Botany" ,
                            "Botany | Virology | Taxonomy" .


###  http://rs.tdwg.org/dwc/terms/disposition
dwc:disposition rdf:type owl:DatatypeProperty ;
                rdfs:label "Disposition" ;
                skos:definition "A current state of a dwc:MaterialEntity with respect to where it can be found." ;
                skos:example "deaccessioned" ,
                             "destroyed" ,
                             "in collection" ,
                             "missing" ,
                             "on loan" ,
                             "used up" .


###  http://rs.tdwg.org/dwc/terms/earliestAgeOrLowestStage
dwc:earliestAgeOrLowestStage rdf:type owl:DatatypeProperty ;
                             rdfs:label "Earliest Age Or Lowest Stage" ;
                             skos:definition "The full name of the earliest possible geochronologic age or lowest chronostratigraphic stage attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                             skos:example "Atlantic" ,
                                          "Boreal" ,
                                          "Skullrockian" .


###  http://rs.tdwg.org/dwc/terms/earliestEonOrLowestEonothem
dwc:earliestEonOrLowestEonothem rdf:type owl:DatatypeProperty ;
                                rdfs:label "Earliest Eon Or Lowest Eonothem" ;
                                skos:definition "The full name of the earliest possible geochronologic eon or lowest chronostratigraphic eonothem or the informal name (Precambrian) attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                                skos:example "Phanerozoic" ,
                                             "Proterozoic" .


###  http://rs.tdwg.org/dwc/terms/earliestEpochOrLowestSeries
dwc:earliestEpochOrLowestSeries rdf:type owl:DatatypeProperty ;
                                rdfs:label "Earliest Epoch Or Lowest Series" ;
                                skos:definition "The full name of the earliest possible geochronologic epoch or lowest chronostratigraphic series attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                                skos:example "Holocene" ,
                                             "Ibexian Series" ,
                                             "Pleistocene" .


###  http://rs.tdwg.org/dwc/terms/earliestEraOrLowestErathem
dwc:earliestEraOrLowestErathem rdf:type owl:DatatypeProperty ;
                               rdfs:label "Earliest Era Or Lowest Erathem" ;
                               skos:definition "The full name of the earliest possible geochronologic era or lowest chronostratigraphic erathem attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                               skos:example "Cenozoic" ,
                                            "Mesozoic" .


###  http://rs.tdwg.org/dwc/terms/earliestPeriodOrLowestSystem
dwc:earliestPeriodOrLowestSystem rdf:type owl:DatatypeProperty ;
                                 rdfs:label "Earliest Period Or Lowest System" ;
                                 skos:definition "The full name of the earliest possible geochronologic period or lowest chronostratigraphic system attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                                 skos:example "Neogene" ,
                                              "Quaternary" ,
                                              "Tertiary" .


###  http://rs.tdwg.org/dwc/terms/editor
dwc:editor rdf:type owl:DatatypeProperty ;
           rdfs:label "Editor" ;
           skos:definition "A name of a dcterms:Agent having managerial and sometimes policy-making responsibility for the editorial part of a publishing firm or of a newspaper, magazine, or other publication." .


###  http://rs.tdwg.org/dwc/terms/endDayOfYear
dwc:endDayOfYear rdf:type owl:DatatypeProperty ;
                 rdfs:label "End Day Of Year" ;
                 skos:definition "The latest integer day of the year on which a dwc:Event occurred." ;
                 skos:example 1 ,
                              32 ,
                              365 ,
                              366 .


###  http://rs.tdwg.org/dwc/terms/establishmentMeans
dwc:establishmentMeans rdf:type owl:DatatypeProperty ;
                       rdfs:label "Establishment Means" ;
                       skos:definition "Statement about whether a dwc:Organism has been introduced to a given place and time through the direct or indirect activity of modern humans." ;
                       skos:example "introduced" ,
                                    "introducedAssistedColonisation" ,
                                    "native" ,
                                    "nativeReintroduced" ,
                                    "uncertain" ,
                                    "vagrant" .


###  http://rs.tdwg.org/dwc/terms/eventCategory
dwc:eventCategory rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Recommended best practice is to use a limited, tightly controlled vocabulary." ;
                  rdfs:label "Event Category" ;
                  skos:definition "A broad category that best matches the nature of a dwc:Event." ;
                  skos:example "material gathering" ,
                               "nucleotide analysis" ,
                               "occurrence" ,
                               "organism interaction" ,
                               "survey" ,
                               "varied" .


###  http://rs.tdwg.org/dwc/terms/eventConductedBy
dwc:eventConductedBy rdf:type owl:DatatypeProperty ;
                     rdfs:label "Event Conducted By" ;
                     skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for conducting or recording a dwc:Event." ;
                     skos:example "FMNH" ,
                                  "José E. Crespo" ,
                                  "Oliver P. Pearson | Anita K. Pearson" .


###  http://rs.tdwg.org/dwc/terms/eventConductedByID
dwc:eventConductedByID rdf:type owl:DatatypeProperty ;
                       rdfs:label "Event Conducted By ID" ;
                       skos:definition "An identifier for a dcterms:Agent responsible for conducting or recording a dwc:Event." ;
                       skos:example "https://orcid.org/0000-0002-1825-0097" ,
                                    "https://ror.org/00mh9zx15" .


###  http://rs.tdwg.org/dwc/terms/eventDate
dwc:eventDate rdf:type owl:DatatypeProperty ;
              rdfs:label "Event Date" ;
              skos:definition "A date-time or time interval during which a dwc:Event occurred." ;
              skos:example 1971 ,
                           "1809-02-12" ,
                           "1900/1909" ,
                           "1906-06" ,
                           "1963-03-08T14:07-06:00" ,
                           "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z" ,
                           "2007-11-13/15" ,
                           "2009-02-20T08:40Z" ,
                           "2018-08-29T15:19" .


###  http://rs.tdwg.org/dwc/terms/eventEffort
dwc:eventEffort rdf:type owl:DatatypeProperty ;
                rdfs:label "An amount of effort expended during a dwc:Event." ,
                           "Event Effort" ;
                skos:example "10 km by foot" ,
                             "10 observer-hours" ,
                             "30 km by car" ,
                             "40 trap-nights" .


###  http://rs.tdwg.org/dwc/terms/eventID
dwc:eventID rdf:type owl:DatatypeProperty ;
            rdfs:label "Event ID" ;
            skos:definition "An identifier for the set of information associated with a dwc:Event (something that occurs at a place and time)." ;
            skos:example "INBO:VIS:Ev:00009375" .


###  http://rs.tdwg.org/dwc/terms/eventReferences
dwc:eventReferences rdf:type owl:DatatypeProperty ;
                    rdfs:label "A list (concatenated and separated) of dcterms:BibliographicResources associated with a dwc:Event." ,
                               "Event References" ;
                    skos:example "Christopher J. Conroy, Jennifer L. Neuwald. 2008. Phylogeographic study of the California vole, Microtus californicus Journal of Mammalogy, 89(3):755-767." ,
                                 "Steven R. Hoofer and Ronald A. Van Den Bussche. 2001. Phylogenetic Relationships of Plecotine Bats and Allies Based on Mitochondrial Ribosomal Sequences. Journal of Mammalogy 82(1):131-137. | Walker, Faith M., Jeffrey T. Foster, Kevin P. Drees, Carol L. Chambers. 2014. Spotted bat (Euderma maculatum) microsatellite discovery using illumina sequencing. Conservation Genetics Resources" ,
                                 "http://www.sciencemag.org/cgi/content/abstract/322/5899/261" .


###  http://rs.tdwg.org/dwc/terms/eventRemarks
dwc:eventRemarks rdf:type owl:DatatypeProperty ;
                 rdfs:label "Event Remarks" ;
                 skos:definition "Comments or notes about the dwc:Event." ;
                 skos:example "After the recent rains the river is nearly at flood stage." .


###  http://rs.tdwg.org/dwc/terms/eventTime
dwc:eventTime rdf:type owl:DatatypeProperty ;
              rdfs:label "Event Time" ;
              skos:definition "The time or interval during which a dwc:Event occurred." ;
              skos:example "08:40:21Z" ,
                           "13:00:00Z/15:30:00Z" ,
                           "14:07-06:00" .


###  http://rs.tdwg.org/dwc/terms/eventType
dwc:eventType rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "Recommended best practice is to use a controlled vocabulary. This term has an equivalent in the dwciri: namespace that allows only an IRI as a value, whereas this term allows for any string literal value." ;
              rdfs:label "Event Type" ;
              skos:definition "A narrow category that best matches the nature of a dwc:Event." ;
              skos:example "BioBlitz" ,
                           "camera trap deployment" ,
                           "expedition" ,
                           "project" ,
                           "site visit" ,
                           "trawl" .


###  http://rs.tdwg.org/dwc/terms/evidenceForOccurrenceID
dwc:evidenceForOccurrenceID rdf:type owl:DatatypeProperty ;
                            rdfs:label "Evidence For Occurrence ID" ;
                            skos:definition "An identifier for a dwc:Occurrence for which a dwc:MaterialEntity provides evidence." .


###  http://rs.tdwg.org/dwc/terms/externalRelatedOccurrenceID
dwc:externalRelatedOccurrenceID rdf:type owl:DatatypeProperty ;
                                rdfs:label "External Related Occurrence ID" ;
                                skos:definition "An identifier for the related dwc:Occurrence (the object) of a dwc:ResourceRelationship that is not within the same dataset." .


###  http://rs.tdwg.org/dwc/terms/family
dwc:family rdf:type owl:DatatypeProperty ;
           rdfs:label "Family" ;
           skos:definition "The full scientific name of the family in which the dwc:Taxon is classified." ;
           skos:example "Felidae" ,
                        "Monocleaceae" .


###  http://rs.tdwg.org/dwc/terms/feedbackURL
dwc:feedbackURL rdf:type owl:DatatypeProperty ;
                rdfs:label "Feedback URL" ;
                skos:definition "A uniform resource locator (URL) that points to a webpage on which a form may be submitted to gather feedback about the record." ,
                                "https://example.com/new?title=New+issue&body=This+comment+is+about+CAN12345" .


###  http://rs.tdwg.org/dwc/terms/fieldNotes
dwc:fieldNotes rdf:type owl:DatatypeProperty ;
               rdfs:label "Field Notes" ;
               skos:definition "One of a) an indicator of the existence of, b) a reference to (publication, URI), or c) the text of notes taken in the field about the dwc:Event." ;
               skos:example "Notes available in the Grinnell-Miller Library." .


###  http://rs.tdwg.org/dwc/terms/fieldNumber
dwc:fieldNumber rdf:type owl:DatatypeProperty ;
                rdfs:label "Field Number" ;
                skos:definition "An identifier given to the dwc:Event in the field. Often serves as a link between field notes and the dwc:Event." ;
                skos:example "RV Sol 87-03-08" .


###  http://rs.tdwg.org/dwc/terms/footprintSRS
dwc:footprintSRS rdf:type owl:DatatypeProperty ;
                 rdfs:label "Footprint SRS" ;
                 skos:definition "The ellipsoid, geodetic datum, or spatial reference system (SRS) upon which the geometry given in dwc:footprintWKT is based." ;
                 skos:example "EPSG:4326" ,
                              "GEOGCS[\"GCS_WGS_1984\", DATUM[\"D_WGS_1984\", SPHEROID[\"WGS_1984\",6378137,298.257223563]], PRIMEM[\"Greenwich\",0], UNIT[\"Degree\",0.0174532925199433]]" ,
                              "not recorded" .


###  http://rs.tdwg.org/dwc/terms/footprintSpatialFit
dwc:footprintSpatialFit rdf:type owl:DatatypeProperty ;
                        rdfs:label "Footprint Spatial Fit" ;
                        skos:definition "A ratio of the area of a footprint (dwc:footprintWKT) to the area of a true (original, or most specific) spatial representation of a dcterms:Location." ;
                        skos:example 1.5708 ,
                                     0 ,
                                     1 .


###  http://rs.tdwg.org/dwc/terms/footprintWKT
dwc:footprintWKT rdf:type owl:DatatypeProperty ;
                 rdfs:label "Footprint WKT" ;
                 skos:definition "A Well-Known Text (WKT) representation of the shape (footprint, geometry) that defines a dcterms:Location." ;
                 skos:example "POLYGON ((10 20, 11 20, 11 21, 10 21, 10 20))" .


###  http://rs.tdwg.org/dwc/terms/formation
dwc:formation rdf:type owl:DatatypeProperty ;
              rdfs:label "Formation" ;
              skos:definition "The full name of the lithostratigraphic formation from which the dwc:MaterialEntity was collected." ;
              skos:example "Fillmore Formation" ,
                           "House Limestone" ,
                           "Notch Peak Formation" .


###  http://rs.tdwg.org/dwc/terms/fundingAttributionID
dwc:fundingAttributionID rdf:type owl:DatatypeProperty ;
                         rdfs:label "Funding Attribution ID" ;
                         skos:definition "An identifier for a dcterms:Agent that financially supported a project." ;
                         skos:example "https://ror.org/00epmv149" ,
                                      "https://ror.org/00epmv149 | https://ror.org/04jnzhb65" ,
                                      "https://www.wikidata.org/wiki/Q13102615" .


###  http://rs.tdwg.org/dwc/terms/genericName
dwc:genericName rdf:type owl:DatatypeProperty ;
                rdfs:label "Generic Name" ;
                skos:definition "The genus part of the dwc:scientificName without authorship." ;
                skos:example "Felis" .


###  http://rs.tdwg.org/dwc/terms/genus
dwc:genus rdf:type owl:DatatypeProperty ;
          rdfs:label "Genus" ;
          skos:definition "The full scientific name of the genus in which the dwc:Taxon is classified." ;
          skos:example "Monoclea" ,
                       "Puma" .


###  http://rs.tdwg.org/dwc/terms/geodeticDatum
dwc:geodeticDatum rdf:type owl:DatatypeProperty ;
                  rdfs:label "Geodetic Datum" ;
                  skos:definition "The ellipsoid, geodetic datum, or spatial reference system (SRS) upon which the geographic coordinates given in dwc:decimalLatitude and dwc:decimalLongitude are based." ;
                  skos:example "Campo Inchauspe" ,
                               "Clarke 1866" ,
                               "EPSG:4326" ,
                               "European 1950" ,
                               "NAD27" ,
                               "WGS84" ,
                               "not recorded" .


###  http://rs.tdwg.org/dwc/terms/geologicalContextID
dwc:geologicalContextID rdf:type owl:DatatypeProperty ;
                        rdfs:label "Geological Context ID" ;
                        skos:definition "An identifier for the set of information associated with a dwc:GeologicalContext (the location within a geological context, such as stratigraphy)." .


###  http://rs.tdwg.org/dwc/terms/georeferenceProtocol
dwc:georeferenceProtocol rdf:type owl:DatatypeProperty ;
                         rdfs:label "Georeference Protocol" ;
                         skos:definition "A description or reference to a dwc:Protocol used to determine a spatial footprint, coordinates, and uncertainties." ,
                                         "Georeferencing Quick Reference Guide (Zermoglio et al. 2020, https://doi.org/10.35035/e09p-h128)" .


###  http://rs.tdwg.org/dwc/terms/georeferenceProtocolID
dwc:georeferenceProtocolID rdf:type owl:DatatypeProperty ;
                           rdfs:label "Georeference Protocol ID" ;
                           skos:definition "An identifier for a dwc:Protocol used to determine a spatial footprint, coordinates, and uncertainties." ;
                           skos:example "https://doi.org/10.35035/e09p-h128" .


###  http://rs.tdwg.org/dwc/terms/georeferenceRemarks
dwc:georeferenceRemarks rdf:type owl:DatatypeProperty ;
                        rdfs:label "Georeference Remarks" ;
                        skos:definition "Comments or notes about the spatial description determination, explaining assumptions made in addition or opposition to the those formalized in the method referred to in dwc:georeferenceProtocol." ;
                        skos:example "Assumed distance by road (Hwy. 101)" .


###  http://rs.tdwg.org/dwc/terms/georeferenceSources
dwc:georeferenceSources rdf:type owl:DatatypeProperty ;
                        rdfs:label "Georeference Sources" ;
                        skos:definition "A list (concatenated and separated) of maps, gazetteers, or other resources used to georeference a dcterms:Location, described specifically enough to allow anyone in the future to use the same resources." ;
                        skos:example "GeoLocate" ,
                                     "GeoPick" ,
                                     "USGS 1:24000 Florence Montana Quad 1967 | Terrametrics 2008 on Google Earth" ,
                                     "https://www.geonames.org/" .


###  http://rs.tdwg.org/dwc/terms/georeferenceVerificationStatus
dwc:georeferenceVerificationStatus rdf:type owl:DatatypeProperty ;
                                   rdfs:label "Georeference Verification Status" ;
                                   skos:definition "A categorical description of the extent to which the georeference has been verified to represent the best possible spatial description for the dcterms:Location of the dwc:Occurrence" ,
                                                   "requires georeference" ,
                                                   "requires verification" ,
                                                   "unable to georeference" ,
                                                   "verified by contributor" ,
                                                   "verified by data custodian" .


###  http://rs.tdwg.org/dwc/terms/georeferencedBy
dwc:georeferencedBy rdf:type owl:DatatypeProperty ;
                    rdfs:label "Georeferenced By" ;
                    skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for determining a georeference (spatial representation) for a dcterms:Location." ;
                    skos:example "Brad Millen (ROM)" ,
                                 "Kristina Yamamoto | Janet Fang" .


###  http://rs.tdwg.org/dwc/terms/georeferencedByID
dwc:georeferencedByID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Georeferenced By ID" ;
                      skos:definition "An identifier for a dcterms:Agent responsible for determining a georeference for a dwc:Event." ;
                      skos:example "https://orcid.org/0000-0002-1825-0097" .


###  http://rs.tdwg.org/dwc/terms/georeferencedDate
dwc:georeferencedDate rdf:type owl:DatatypeProperty ;
                      rdfs:label "Georeferenced Date" ;
                      skos:definition "The date on which the dcterms:Location was georeferenced." ;
                      skos:example "1809-02-12" ,
                                   "1900/1909" ,
                                   "1906-06" ,
                                   "1963-03-08T14:07-06:00" ,
                                   "1971" ,
                                   "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z" ,
                                   "2007-11-13/15" ,
                                   "2009-02-20T08:40Z" ,
                                   "2018-08-29T15:19" .


###  http://rs.tdwg.org/dwc/terms/group
dwc:group rdf:type owl:DatatypeProperty ;
          rdfs:label "Group" ;
          skos:definition "The full name of the lithostratigraphic group from which the dwc:MaterialEntity was collected." ;
          skos:example "Bathurst" ,
                       "Lower Wealden" .


###  http://rs.tdwg.org/dwc/terms/habitat
dwc:habitat rdf:type owl:DatatypeProperty ;
            rdfs:label "Habitat" ;
            skos:definition "A category or description of the habitat in which the dwc:Event occurred." ,
                            "oak savanna" ,
                            "pre-cordilleran steppe" .


###  http://rs.tdwg.org/dwc/terms/higherGeography
dwc:higherGeography rdf:type owl:DatatypeProperty ;
                    rdfs:label "Higher Geography" ;
                    skos:definition "A list (concatenated and separated) of geographic names less specific than the information captured in the dwc:locality term." ;
                    skos:example "North Atlantic Ocean" ,
                                 "South America | Argentina | Patagonia | Parque Nacional Nahuel Huapi | Neuquén | Los Lagos" .


###  http://rs.tdwg.org/dwc/terms/higherGeographyID
dwc:higherGeographyID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Higher Geography ID" ;
                      skos:definition "An identifier for the geographic region within which the dcterms:Location occurred." ;
                      skos:example "http://vocab.getty.edu/tgn/1002002" .


###  http://rs.tdwg.org/dwc/terms/highestBiostratigraphicZone
dwc:highestBiostratigraphicZone rdf:type owl:DatatypeProperty ;
                                rdfs:label "Highest Biostratigraphic Zone" ;
                                skos:definition "The full name of the highest possible geological biostratigraphic zone of the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                                skos:example "Blancan" .


###  http://rs.tdwg.org/dwc/terms/identificationReferences
dwc:identificationReferences rdf:type owl:DatatypeProperty ;
                             rdfs:label "Identification References" ;
                             skos:definition "A list (concatenated and separated) of dcterms:BibliographicResources used in a dwc:Identification." ;
                             skos:example "Aves del Noroeste Patagonico. Christie et al. 2004." ,
                                          "Stebbins, R. Field Guide to Western Reptiles and Amphibians. 3rd Edition. 2003. | Irschick, D.J. and Shaffer, H.B. (1997). The polytypic species revisited: Morphological differentiation among tiger salamanders (Ambystoma tigrinum) (Amphibia: Caudata). Herpetologica, 53(1), 30-49." .


###  http://rs.tdwg.org/dwc/terms/identificationRemarks
dwc:identificationRemarks rdf:type owl:DatatypeProperty ;
                          rdfs:label "Identification Remarks" ;
                          skos:definition "Comments or notes about the dwc:Identification." ;
                          skos:example "Distinguished between Anthus correndera and Anthus hellmayri based on the comparative lengths of the uñas." .


###  http://rs.tdwg.org/dwc/terms/identificationVerificationStatus
dwc:identificationVerificationStatus rdf:type owl:DatatypeProperty ;
                                     rdfs:label "Identification VerificationStatus" ;
                                     skos:definition "A categorical indicator of the extent to which a taxonomic determination has been verified to be correct." ;
                                     skos:example 0 .


###  http://rs.tdwg.org/dwc/terms/identifiedBy
dwc:identifiedBy rdf:type owl:DatatypeProperty ;
                 rdfs:label "Identified By" ;
                 skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for making a taxonomic determination of a dwc:Organism." ;
                 skos:example "James L. Patton" ,
                              "Theodore Pappenfuss | Robert Macey" .


###  http://rs.tdwg.org/dwc/terms/identifiedByID
dwc:identifiedByID rdf:type owl:DatatypeProperty ;
                   rdfs:label "Identified By ID" ;
                   skos:definition "An identifier for a dcterms:Agent responsible for making a taxonomic determination of a dwc:Organism." .


###  http://rs.tdwg.org/dwc/terms/includeOrExclude
dwc:includeOrExclude rdf:type owl:DatatypeProperty ;
                     rdfs:label "Include Or Exclude" ;
                     skos:definition "Whether the combination of dwc:surveyTargetType and dwc:surveyTargetValue is included or excluded in a dwc:SurveyTarget." ;
                     skos:example "exclude" ,
                                  "include" .


###  http://rs.tdwg.org/dwc/terms/informationWithheld
dwc:informationWithheld rdf:type owl:DatatypeProperty ;
                        rdfs:label "Information Withheld" ;
                        skos:definition "Additional information that exists about a resource, but that is not shared publicly. Suggests that alternative data of higher quality may be available on request." ;
                        skos:example "collector identities withheld | ask about tissue samples" ,
                                     "location information not given for endangered species" .


###  http://rs.tdwg.org/dwc/terms/infragenericEpithet
dwc:infragenericEpithet rdf:type owl:DatatypeProperty ;
                        rdfs:label "Infrageneric Epithet" ;
                        skos:definition "The infrageneric part of a binomial name at ranks above species but below genus." ;
                        skos:example "Abacetillus" ,
                                     "Cracca" .


###  http://rs.tdwg.org/dwc/terms/infraspecificEpithet
dwc:infraspecificEpithet rdf:type owl:DatatypeProperty ;
                         rdfs:label "Infraspecific Epithet" ;
                         skos:definition "The name of the first or species epithet of the dwc:scientificName." ;
                         skos:example "concolor" ,
                                      "laxa" ,
                                      "oxyadenia" ,
                                      "scaberrima" .


###  http://rs.tdwg.org/dwc/terms/institutionCode
dwc:institutionCode rdf:type owl:DatatypeProperty ;
                    rdfs:label "Institution Code" ;
                    skos:definition "A name (or acronym) an organization." ;
                    skos:example "CLO" ,
                                 "FMNH" ,
                                 "MVZ" ,
                                 "UCMP" .


###  http://rs.tdwg.org/dwc/terms/institutionID
dwc:institutionID rdf:type owl:DatatypeProperty ;
                  rdfs:label "Institution ID" ;
                  skos:definition "An identifier for an organization." ;
                  skos:example "http://grscicoll.org/institution/museum-southwestern-biology" ,
                               "https://ror.org/015hz7p22" ,
                               "https://www.gbif.org/grscicoll/institution/e3d4dcc4-81e2-444c-8a5c-41d1044b5381" .


###  http://rs.tdwg.org/dwc/terms/isAcceptedIdentification
dwc:isAcceptedIdentification rdf:type owl:DatatypeProperty ;
                             rdfs:label "Is Accepted Identification" ;
                             skos:definition "An indicator that this dwc:Identification of a dwc:Organism is a currently an accepted or preferred one." .


###  http://rs.tdwg.org/dwc/terms/isPartOfMaterialEntityID
dwc:isPartOfMaterialEntityID rdf:type owl:DatatypeProperty ;
                             rdfs:label "Is Part Of Material Entity ID" ;
                             skos:definition "An identifier for a dwc:MaterialEntity of which this dwc:MaterialEntity is a part." .


###  http://rs.tdwg.org/dwc/terms/isPartOfOccurrenceID
dwc:isPartOfOccurrenceID rdf:type owl:DatatypeProperty ;
                         rdfs:label "Is Part Of Occurrence ID" ;
                         skos:definition "An identifier for a dwc:Occurrence of which this dwc:Occurrence is a part." .


###  http://rs.tdwg.org/dwc/terms/isSurveyTargetFullyReported
dwc:isSurveyTargetFullyReported rdf:type owl:DatatypeProperty ;
                                rdfs:label "Is Survey Target Fully Reported" ;
                                skos:definition "A declaration of whether the counts for an instance of the dwc:SurveyTarget report everything that matches the declared dwc:SurveyTarget." ;
                                skos:example "false"^^xsd:boolean ,
                                             "true"^^xsd:boolean .


###  http://rs.tdwg.org/dwc/terms/island
dwc:island rdf:type owl:DatatypeProperty ;
           rdfs:label "Island" ;
           skos:definition "The name of the island on or near which the dcterms:Location occurs." ;
           skos:example "Bikini Atoll" ,
                        "Nosy Be" ,
                        "Vancouver" ,
                        "Viti Levu" ,
                        "Zanzibar" .


###  http://rs.tdwg.org/dwc/terms/islandGroup
dwc:islandGroup rdf:type owl:DatatypeProperty ;
                rdfs:label "Island Group" ;
                skos:definition "The name of the island group in which the dcterms:Location occurs." ;
                skos:example "Alexander Archipelago" ,
                             "Archipiélago Diego Ramírez" ,
                             "Seychelles" .


###  http://rs.tdwg.org/dwc/terms/kingdom
dwc:kingdom rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:string ;
            rdfs:label "Kingdom" ;
            skos:definition "The full scientific name of the kingdom in which the dwc:Taxon is classified." ;
            skos:example "Animalia" ,
                         "Archaea" ,
                         "Bacteria" ,
                         "Chromista" ,
                         "Fungi" ,
                         "Plantae" ,
                         "Protozoa" ,
                         "Viruses" .


###  http://rs.tdwg.org/dwc/terms/latestAgeOrHighestStage
dwc:latestAgeOrHighestStage rdf:type owl:DatatypeProperty ;
                            rdfs:label "Latest Age Or Highest Stage" ;
                            skos:definition "The full name of the latest possible geochronologic age or highest chronostratigraphic stage attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                            skos:example "Atlantic" ,
                                         "Boreal" ,
                                         "Skullrockian" .


###  http://rs.tdwg.org/dwc/terms/latestEonOrHighestEonothem
dwc:latestEonOrHighestEonothem rdf:type owl:DatatypeProperty ;
                               rdfs:label "Latest Eon Or Highest Eonothem" ;
                               skos:definition "he full name of the latest possible geochronologic eon or highest chronostratigraphic eonothem or the informal name (Precambrian) attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                               skos:example "Phanerozoic" ,
                                            "Proterozoic" .


###  http://rs.tdwg.org/dwc/terms/latestEpochOrHighestSeries
dwc:latestEpochOrHighestSeries rdf:type owl:DatatypeProperty ;
                               rdfs:label "Latest Epoch Or Highest Series" ;
                               skos:definition "The full name of the latest possible geochronologic epoch or highest chronostratigraphic series attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                               skos:example "Holocene" ,
                                            "Ibexian Series" ,
                                            "Pleistocene" .


###  http://rs.tdwg.org/dwc/terms/latestEraOrHighestErathem
dwc:latestEraOrHighestErathem rdf:type owl:DatatypeProperty ;
                              rdfs:label "Latest Era Or Highest Erathem" ;
                              skos:definition "The full name of the latest possible geochronologic era or highest chronostratigraphic erathem attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                              skos:example "Cenozoic" ,
                                           "Mesozoic" .


###  http://rs.tdwg.org/dwc/terms/latestPeriodOrHighestSystem
dwc:latestPeriodOrHighestSystem rdf:type owl:DatatypeProperty ;
                                rdfs:label "Latest Period Or Highest System" ;
                                skos:definition "The full name of the latest possible geochronologic period or highest chronostratigraphic system attributable to the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                                skos:example "Neogene" ,
                                             "Quaternary" ,
                                             "Tertiary" .


###  http://rs.tdwg.org/dwc/terms/lifeStage
dwc:lifeStage rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:label "Life Stage" ;
              skos:definition "The age class or life stage of the dwc:Organism(s) at the time the dwc:Occurrence was recorded." ;
              skos:example "adult" ,
                           "flowering" ,
                           "fruiting" ,
                           "juvenile" ,
                           "larva" ,
                           "seedling" ,
                           "zygote" .


###  http://rs.tdwg.org/dwc/terms/lithostratigraphicTerms
dwc:lithostratigraphicTerms rdf:type owl:DatatypeProperty ;
                            rdfs:label "Lithostratigraphic Terms" ;
                            skos:definition "The combination of all lithostratigraphic names for the rock from which the dwc:MaterialEntity was collected." ;
                            skos:example "Pleistocene-Weichselien" .


###  http://rs.tdwg.org/dwc/terms/locality
dwc:locality rdf:type owl:DatatypeProperty ;
             rdfs:label "Locality" ;
             skos:definition "The specific description of the place." ;
             skos:example "Bariloche, 25 km NNE via Ruta Nacional 40 (=Ruta 237)" ,
                          "Queets Rainforest, Olympic National Park" .


###  http://rs.tdwg.org/dwc/terms/locationID
dwc:locationID rdf:type owl:DatatypeProperty ;
               rdfs:label "Location ID" ;
               skos:definition "An identifier for a dcterms:Location." ;
               skos:example "https://opencontext.org/subjects/768A875F-E205-4D0B-DE55-BAB7598D0FD1" .


###  http://rs.tdwg.org/dwc/terms/locationRemarks
dwc:locationRemarks rdf:type owl:DatatypeProperty ;
                    rdfs:label "Location Remarks" ;
                    skos:definition "Comments or notes about the dcterms:Location." ;
                    skos:example "under water since 2005" .


###  http://rs.tdwg.org/dwc/terms/lowestBiostratigraphicZone
dwc:lowestBiostratigraphicZone rdf:type owl:DatatypeProperty ;
                               rdfs:label "Lowest Biostratigraphic Zone" ;
                               skos:definition "The full name of the lowest possible geological biostratigraphic zone of the stratigraphic horizon from which the dwc:MaterialEntity was collected." ;
                               skos:example "Maastrichtian" .


###  http://rs.tdwg.org/dwc/terms/materialCategory
dwc:materialCategory rdf:type owl:DatatypeProperty ;
                     rdfs:label "Material Category" ;
                     skos:definition "A broad category that best matches the nature of a dwc:MaterialEntity." ;
                     skos:example "DNA extract" ,
                                  "fossilized" ,
                                  "human-made" ,
                                  "living" ,
                                  "non-biological" ,
                                  "preserved" ,
                                  "tissue" .


###  http://rs.tdwg.org/dwc/terms/materialEntityID
dwc:materialEntityID rdf:type owl:DatatypeProperty ;
                     rdfs:label "Material Entity ID" ;
                     skos:definition "An identifier for a dwc:MaterialEntity." ;
                     skos:example "06809dc5-f143-459a-be1a-6f03e63fc083" .


###  http://rs.tdwg.org/dwc/terms/materialEntityRemarks
dwc:materialEntityRemarks rdf:type owl:DatatypeProperty ;
                          rdfs:label "Material Entity Remarks" ;
                          skos:definition "Comments or notes about a dwc:MaterialEntity." ;
                          skos:example "found in association with charred remains" ,
                                       "some original fragments missing" .


###  http://rs.tdwg.org/dwc/terms/materialEntityType
dwc:materialEntityType rdf:type owl:DatatypeProperty ;
                       rdfs:label "Material Entity Type" ;
                       rdfs:seeAlso "Anthropogenic Artifact" ,
                                    "Blood sampling cards" ,
                                    "Macrofossil" ,
                                    "Mesofossil" ,
                                    "Microfossil" ,
                                    "Oversized fossil" ,
                                    "Pinned object/specimen" ,
                                    "Spore print" ,
                                    "Taxidermy mount" ;
                       skos:definition "A narrow category that best matches the nature of a dwc:MaterialEntity." ;
                       skos:example "Compound Specimen" ,
                                    "Core" ,
                                    "Cut/polished gemstone" ,
                                    "Environmental sample" ,
                                    "Macro-object" ,
                                    "Micro-object" ,
                                    "Microscope slide" ,
                                    "Mixed Materials" ,
                                    "Oversized object" .


###  http://rs.tdwg.org/dwc/terms/materialReferences
dwc:materialReferences rdf:type owl:DatatypeProperty ;
                       rdfs:label "Material References" ;
                       skos:definition "A list (concatenated and separated) of dcterms:BibliographicResources associated with a dwc:MaterialEntity." ;
                       skos:example "Christopher J. Conroy, Jennifer L. Neuwald. 2008. Phylogeographic study of the California vole, Microtus californicus Journal of Mammalogy, 89(3):755-767." ,
                                    "Steven R. Hoofer and Ronald A. Van Den Bussche. 2001. Phylogenetic Relationships of Plecotine Bats and Allies Based on Mitochondrial Ribosomal Sequences. Journal of Mammalogy 82(1):131-137. | Walker, Faith M., Jeffrey T. Foster, Kevin P. Drees, Carol L. Chambers. 2014. Spotted bat (Euderma maculatum) microsatellite discovery using illumina sequencing. Conservation Genetics Resources." ,
                                    "http://www.sciencemag.org/cgi/content/abstract/322/5899/261" .


###  http://rs.tdwg.org/dwc/terms/maximumDepthInMeters
dwc:maximumDepthInMeters rdf:type owl:DatatypeProperty ;
                         rdfs:label "Maximum Depth In Meters" ;
                         skos:definition "The greater depth of a range of depth below a dwc:verticalDatum." ;
                         skos:example 0 ,
                                      200 .


###  http://rs.tdwg.org/dwc/terms/maximumDistanceAboveSurfaceInMeters
dwc:maximumDistanceAboveSurfaceInMeters rdf:type owl:DatatypeProperty ;
                                        rdfs:label "Maximum Distance Above Surface In Meters" ;
                                        skos:definition "The greater distance in a range of distance from a reference surface in the vertical direction, in meters. Use positive values for locations above the surface, negative values for locations below. If depth measures are given, the reference surface is the location given by the depth, otherwise the reference surface is the location given by the elevation." ;
                                        skos:example -1.5 .


###  http://rs.tdwg.org/dwc/terms/maximumElevationInMeters
dwc:maximumElevationInMeters rdf:type owl:DatatypeProperty ;
                             rdfs:label "Maximum Elevation In Meters" ;
                             skos:definition "An upper limit of a range of elevation in meters above a dwc:verticalDatum." ;
                             skos:example -205 ,
                                          1236 .


###  http://rs.tdwg.org/dwc/terms/mediaID
dwc:mediaID rdf:type owl:DatatypeProperty ;
            rdfs:label "Media ID" ;
            skos:definition "An identifier for a dwc:Media resource." .


###  http://rs.tdwg.org/dwc/terms/member
dwc:member rdf:type owl:DatatypeProperty ;
           rdfs:label "Member" ;
           skos:definition "The full name of the lithostratigraphic member from which the dwc:MaterialEntity was collected." ;
           skos:example "Hellnmaria Member" ,
                        "Lava Dam Member" .


###  http://rs.tdwg.org/dwc/terms/minimumDepthInMeters
dwc:minimumDepthInMeters rdf:type owl:DatatypeProperty ;
                         rdfs:label "Minimum Depth In Meters" ;
                         skos:definition "The lesser depth of a range of depth below a dwc:verticalDatum." ;
                         skos:example 0 ,
                                      100 .


###  http://rs.tdwg.org/dwc/terms/minimumDistanceAboveSurfaceInMeters
dwc:minimumDistanceAboveSurfaceInMeters rdf:type owl:DatatypeProperty ;
                                        rdfs:label "Minimum Distance Above Surface In Meters" ;
                                        skos:definition "The lesser distance in a range of distance from a reference surface in the vertical direction, in meters. Use positive values for locations above the surface, negative values for locations below. If depth measures are given, the reference surface is the location given by the depth, otherwise the reference surface is the location given by the elevation." ;
                                        skos:example 0 .


###  http://rs.tdwg.org/dwc/terms/minimumElevationInMeters
dwc:minimumElevationInMeters rdf:type owl:DatatypeProperty ;
                             rdfs:label "Minimum Elevation In Meters" ;
                             skos:definition "A lower limit of a range of elevation in meters above a dwc:verticalDatum." ;
                             skos:example -100 ,
                                          802 .


###  http://rs.tdwg.org/dwc/terms/molecularProtocolID
dwc:molecularProtocolID rdf:type owl:DatatypeProperty ;
                        rdfs:label "Molecular Protocol ID" ;
                        skos:definition "An identifier for a dwc:MolecularProtocol." .


###  http://rs.tdwg.org/dwc/terms/month
dwc:month rdf:type owl:DatatypeProperty ;
          rdfs:label "Month" ;
          skos:definition "The integer month in which the dwc:Event occurred." ;
          skos:example 1 ,
                       10 .


###  http://rs.tdwg.org/dwc/terms/municipality
dwc:municipality rdf:type owl:DatatypeProperty ;
                 rdfs:label "Municipality" ;
                 skos:definition "The full, unabbreviated name of the next smaller administrative region than county (city, municipality, etc.) in which the dcterms:Location occurs. Do not use this term for a nearby named place that does not contain the actual dcterms:Location." ;
                 skos:example "Araçatuba" ,
                              "Ga-Segonyana" ,
                              "Holzminden" .


###  http://rs.tdwg.org/dwc/terms/nameAccordingTo
dwc:nameAccordingTo rdf:type owl:DatatypeProperty ;
                    rdfs:label "Name According To" ;
                    skos:definition "The reference to the source in which the specific taxon concept circumscription is defined or implied - traditionally signified by the Latin \\\"sensu\\\" or \\\"sec.\\\" (from secundum, meaning \\\"according to\\\"). For taxa that result from identifications, a reference to the keys, monographs, experts and other sources should be given." ;
                    skos:example "Franz NM, Cardona-Duque J (2013) Description of two new species and phylogenetic reassessment of Perelleschus Wibmer & O’Brien, 1986 (Coleoptera: Curculionidae), with a complete taxonomic concept history of Perelleschus sec. Franz & Cardona-Duque, 2013. Syst Biodivers. 11: 209–236." .


###  http://rs.tdwg.org/dwc/terms/namePublishedIn
dwc:namePublishedIn rdf:type owl:DatatypeProperty ;
                    rdfs:label "Name Published In" ;
                    skos:definition "A reference for the publication in which the dwc:scientificName was originally established under the rules of the associated dwc:nomenclaturalCode." ;
                    skos:example "Forel, Auguste, Diagnosies provisoires de quelques espèces nouvelles de fourmis de Madagascar, récoltées par M. Grandidier., Annales de la Societe Entomologique de Belgique, Comptes-rendus des Seances 30, 1886" ,
                                 "Pearson O. P., and M. I. Christie. 1985. Historia Natural, 5(37):388" .


###  http://rs.tdwg.org/dwc/terms/namePublishedInYear
dwc:namePublishedInYear rdf:type owl:DatatypeProperty ;
                        rdfs:label "Name Published In Year" ;
                        skos:definition "The four-digit year in which the dwc:scientificName was published." ;
                        skos:example "1915" ,
                                     "2008" .


###  http://rs.tdwg.org/dwc/terms/nomenclaturalCode
dwc:nomenclaturalCode rdf:type owl:DatatypeProperty ;
                      rdfs:label "Nomenclatural Code" ;
                      skos:definition "The nomenclatural code (or codes in the case of an ambiregnal name) under which the dwc:scientificName is constructed." ;
                      skos:example "BC" ,
                                   "BioCode" ,
                                   "ICN" ,
                                   "ICNCP" ,
                                   "ICZN" .


###  http://rs.tdwg.org/dwc/terms/nomenclaturalStatus
dwc:nomenclaturalStatus rdf:type owl:DatatypeProperty ;
                        rdfs:label "Nomenclatural Status" ;
                        skos:definition "The status related to the original publication of the name and its conformance to the relevant rules of nomenclature. It is based essentially on an algorithm according to the business rules of the code. It requires no taxonomic opinion." ;
                        skos:example "nom. ambig." ,
                                     "nom. illeg." ,
                                     "nom. subnud." .


###  http://rs.tdwg.org/dwc/terms/nucleotideAnalysisID
dwc:nucleotideAnalysisID rdf:type owl:DatatypeProperty ;
                         rdfs:label "Nucleotide Analysis ID" ;
                         skos:definition "An identifier for a dwc:NucleotideAnalysis." .


###  http://rs.tdwg.org/dwc/terms/nucleotideSequenceID
dwc:nucleotideSequenceID rdf:type owl:DatatypeProperty ;
                         rdfs:label "Nucleotide Sequence ID" ;
                         skos:definition "An identifier for a dwc:NucleotideSequence." .


###  http://rs.tdwg.org/dwc/terms/nucleotideSequenceRemarks
dwc:nucleotideSequenceRemarks rdf:type owl:DatatypeProperty ;
                              rdfs:label "Nucleotide Sequence Remarks" ;
                              skos:definition "Comments or notes about a dwc:NucleotideSequence." .


###  http://rs.tdwg.org/dwc/terms/objectQuantity
dwc:objectQuantity rdf:type owl:DatatypeProperty ;
                   rdfs:label "Object Quantity" ;
                   skos:definition "A number or enumeration value for the quantity of differentiable dwc:MaterialEntities comprising this dwc:MaterialEntity." ;
                   skos:example "27" ,
                                "many" .


###  http://rs.tdwg.org/dwc/terms/objectQuantityType
dwc:objectQuantityType rdf:type owl:DatatypeProperty ;
                       rdfs:label "Object Quantity Type" ;
                       skos:definition "The type of quantification system used for the quantity of dwc:MaterialEntities." ;
                       skos:example "individuals" .


###  http://rs.tdwg.org/dwc/terms/occurrenceID
dwc:occurrenceID rdf:type owl:DatatypeProperty ;
                 rdfs:label "Occurrence ID" ;
                 skos:definition "An identifier for a dwc:Occurrence." ;
                 skos:example "000866d2-c177-4648-a200-ead4007051b9" ,
                              "http://arctos.database.museum/guid/MSB:Mamm:233627" ,
                              "urn:catalog:UWBM:Bird:89776" .


###  http://rs.tdwg.org/dwc/terms/occurrenceRemarks
dwc:occurrenceRemarks rdf:type owl:DatatypeProperty ;
                      rdfs:label "Occurrence Remarks" ;
                      skos:definition "Comments or notes about the dwc:Occurrence." ;
                      skos:example "found dead on road" .


###  http://rs.tdwg.org/dwc/terms/occurrenceStatus
dwc:occurrenceStatus rdf:type owl:DatatypeProperty ;
                     rdfs:label "Occurrence Status" ;
                     skos:definition "A statement about the detection or non-detection of a dwc:Organism." ;
                     skos:example "detected" ,
                                  "notDetected" .


###  http://rs.tdwg.org/dwc/terms/order
dwc:order rdf:type owl:DatatypeProperty ;
          rdfs:label "Order" ;
          skos:definition "The full scientific name of the order in which the dwc:Taxon is classified." ;
          skos:example "Carnivora" ,
                       "Monocleaceae" .


###  http://rs.tdwg.org/dwc/terms/organismID
dwc:organismID rdf:type owl:DatatypeProperty ;
               rdfs:label "Organism ID" ;
               skos:definition "An identifier for a dwc:Organism." .


###  http://rs.tdwg.org/dwc/terms/organismInteractionDescription
dwc:organismInteractionDescription rdf:type owl:DatatypeProperty ;
                                   rdfs:label "Organism Interaction Description" ;
                                   skos:definition "A verbatim description of a dwc:OrganismInteraction." ;
                                   skos:example "Mallophora ruficauda capturing an Apis mellifera worker in flight." .


###  http://rs.tdwg.org/dwc/terms/organismInteractionID
dwc:organismInteractionID rdf:type owl:DatatypeProperty ;
                          rdfs:label "Organism Interaction ID" ;
                          skos:definition "An identifier for a dwc:OrganismInteraction." .


###  http://rs.tdwg.org/dwc/terms/organismInteractionType
dwc:organismInteractionType rdf:type owl:DatatypeProperty ;
                            rdfs:label "Organism Interaction Type" ;
                            skos:definition "A category that best matches the nature of a dwc:OrganismInteraction." ;
                            skos:example "mated with" ,
                                         "parasitoid of" ,
                                         "pollinated by" ,
                                         "visited flower of" ,
                                         "was attached to" .


###  http://rs.tdwg.org/dwc/terms/organismName
dwc:organismName rdf:type owl:DatatypeProperty ;
                 rdfs:label "Organism Name" ;
                 skos:definition "A name or label assigned to a dwc:Organism." ;
                 skos:example "Boab Prison Tree" ,
                              "Huberta" ,
                              "J pod" .


###  http://rs.tdwg.org/dwc/terms/organismQuantity
dwc:organismQuantity rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:string ;
                     rdfs:label "Organism Quantity" ;
                     skos:definition "A number or enumeration value for the quantity of dwc:Organisms." ;
                     skos:example "12.5" ,
                                  "27" ,
                                  "many" ,
                                  "r" .


###  http://rs.tdwg.org/dwc/terms/organismQuantityType
dwc:organismQuantityType rdf:type owl:DatatypeProperty ;
                         rdfs:label "Organism Quantity Type" ;
                         skos:definition "The type of quantification system used for the quantity of dwc:Organisms." ;
                         skos:example "% biomass" ,
                                      "Braun-Blanquet Scale" ,
                                      "individuals" .


###  http://rs.tdwg.org/dwc/terms/organismRemarks
dwc:organismRemarks rdf:type owl:DatatypeProperty ;
                    rdfs:label "Organism Remarks" ;
                    skos:definition "Comments or notes about a dwc:Organism." ;
                    skos:example "One of a litter of six" .


###  http://rs.tdwg.org/dwc/terms/organismScope
dwc:organismScope rdf:type owl:DatatypeProperty ;
                  rdfs:label "Organism Scope" ;
                  skos:definition "A description of the type of a dwc:Organism instance." ;
                  skos:example "clone" ,
                               "colony" ,
                               "multicellular organism" ,
                               "pack" ,
                               "virus" .


###  http://rs.tdwg.org/dwc/terms/otherCatalogNumbers
dwc:otherCatalogNumbers rdf:type owl:DatatypeProperty ;
                        rdfs:label "Other Catalog Numbers" ;
                        skos:definition "A list (concatenated and separated) of previous or alternate fully qualified catalog numbers or other human-used identifiers for the same dwc:MaterialEntity, whether in the current or any other data set or collection." ;
                        skos:example "FMNH:Mammal:1234" ,
                                     "NPS YELLO6778 | MBG 33424" .


###  http://rs.tdwg.org/dwc/terms/ownerID
dwc:ownerID rdf:type owl:DatatypeProperty ;
            rdfs:label "Owner ID" ;
            skos:definition "An identifier for a dcterms:Agent that owns the copyright for a resource." .


###  http://rs.tdwg.org/dwc/terms/ownerInstitutionCode
dwc:ownerInstitutionCode rdf:type owl:DatatypeProperty ;
                         rdfs:label "Owner Institution Code" ;
                         skos:definition "A name (or acronym) in use by an institution having ownership of a dwc:MaterialEntity." ;
                         skos:example "APN" ,
                                      "InBio" ,
                                      "NPS" .


###  http://rs.tdwg.org/dwc/terms/parentEventID
dwc:parentEventID rdf:type owl:DatatypeProperty ;
                  rdfs:label "Parent Event ID" ;
                  skos:definition "An identifier for a broader dwc:Event that contains this and potentially other dwc:Events." ;
                  skos:example "A1" .


###  http://rs.tdwg.org/dwc/terms/parentReferenceID
dwc:parentReferenceID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Parent Reference ID" ;
                      skos:definition "An identifier for a dcterms:BibliographicResource that this dcterms:BibliographicResource is a part of." .


###  http://rs.tdwg.org/dwc/terms/pathway
dwc:pathway rdf:type owl:DatatypeProperty ;
            rdfs:label "Pathway" ;
            skos:definition "The process by which a dwc:Organism came to be in a given place at a given time." ;
            skos:example "corridor" ,
                         "otherEscape" ,
                         "releasedForUse" ,
                         "transportContaminant" ,
                         "transportStowaway" ,
                         "unaided" .


###  http://rs.tdwg.org/dwc/terms/phylum
dwc:phylum rdf:type owl:DatatypeProperty ;
           rdfs:label "Phylum" ;
           skos:definition "The full scientific name of the phylum or division in which the dwc:Taxon is classified." ;
           skos:example "Bryophyta" ,
                        "Chordata" .


###  http://rs.tdwg.org/dwc/terms/pointRadiusSpatialFit
dwc:pointRadiusSpatialFit rdf:type owl:DatatypeProperty ;
                          rdfs:label "Point Radius Spatial Fit" ;
                          skos:definition "A ratio of the area of a point-radius (dwc:decimalLatitude, dwc:decimalLongitude, dwc:coordinateUncertaintyInMeters) to the area of a true (original, or most specific) spatial representation of a dcterms:Location." ;
                          skos:example 1.5708 ,
                                       0 ,
                                       1 .


###  http://rs.tdwg.org/dwc/terms/preferredSpatialRepresentation
dwc:preferredSpatialRepresentation rdf:type owl:DatatypeProperty ;
                                   rdfs:label "Preferred Spatial Representation" ;
                                   skos:definition "An indication of which spatial representation best represents the dcterms:Location." ;
                                   skos:example "footprint" ,
                                                "point-radius" .


###  http://rs.tdwg.org/dwc/terms/preparations
dwc:preparations rdf:type owl:DatatypeProperty ;
                 rdfs:label "Preparations" ;
                 skos:definition "A list (concatenated and separated) of preparations and preservation methods for a dwc:MaterialEntity." ;
                 skos:example "DNA extract" ,
                              "cast" ,
                              "fossil" ,
                              "photograph" ,
                              "skin | skull | skeleton" ,
                              "whole animal (EtOH) | tissue (EDTA)" .


###  http://rs.tdwg.org/dwc/terms/projectID
dwc:projectID rdf:type owl:DatatypeProperty ;
              rdfs:label "Project ID" ;
              skos:definition "A list (concatenated and separated) of identifiers for projects that contributed to a dwc:Event." ;
              skos:example "OC202405" ,
                           "RCN276730" ,
                           "RCN276730 | Artsproject_7-24" ,
                           "https://arvenetternansen.com/" ,
                           "https://doi.org/10.26259/3b15eca7" ,
                           "https://doi.org/10.3030/101180559" .


###  http://rs.tdwg.org/dwc/terms/projectTitle
dwc:projectTitle rdf:type owl:DatatypeProperty ;
                 rdfs:label "Project Title" ;
                 skos:definition "A list (concatenated and separated) of titles or names for projects that contributed to a dwc:Event." ;
                 skos:example "Arctic Deep" ,
                              "Scalidophora i Noreg" ,
                              "The Nansen Legacy" ,
                              "Underwater Oases of the Mar del Plata Canyon: Talud Continental IV" .


###  http://rs.tdwg.org/dwc/terms/protocolDescription
dwc:protocolDescription rdf:type owl:DatatypeProperty ;
                        rdfs:label "Protocol Description" ;
                        skos:definition "A detailed description of a dwc:Protocol." .


###  http://rs.tdwg.org/dwc/terms/protocolID
dwc:protocolID rdf:type owl:DatatypeProperty ;
               rdfs:label "Protocol ID" ;
               skos:definition "An identifier for a dwc:Protocol." .


###  http://rs.tdwg.org/dwc/terms/protocolRemarks
dwc:protocolRemarks rdf:type owl:DatatypeProperty ;
                    rdfs:label "Protocol Remarks" ;
                    skos:definition "Comments or notes about a dwc:Protocol." .


###  http://rs.tdwg.org/dwc/terms/protocolType
dwc:protocolType rdf:type owl:DatatypeProperty ;
                 rdfs:label "Protocol Type" ;
                 skos:definition "A category that best matches the nature of a dwc:Protocol." ;
                 skos:example "chronometric age" ,
                              "chronometric age conversion" ,
                              "georeference" ,
                              "measurement" ,
                              "sampling effort" .


###  http://rs.tdwg.org/dwc/terms/provenanceID
dwc:provenanceID rdf:type owl:DatatypeProperty ;
                 rdfs:label "Provenance ID" ;
                 skos:definition "An identifier for a dwc:Provenance." .


###  http://rs.tdwg.org/dwc/terms/readCount
dwc:readCount rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:integer ;
              rdfs:label "Read Count" ;
              skos:definition "A number of reads for a dwc:NucleotideSequence in a dwc:NucleotideAnalysis." .


###  http://rs.tdwg.org/dwc/terms/recordedBy
dwc:recordedBy rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:label "Recorded By" ;
               skos:definition "A list (concatenated and separated) of names of dcterms:Agents responsible for recording a dwc:Occurrence." ;
               skos:example "José E. Crespo" ,
                            "Oliver P. Pearson | Anita K. Pearson" .


###  http://rs.tdwg.org/dwc/terms/recordedByID
dwc:recordedByID rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:label "Recorded By ID" ;
                 skos:definition "An identifier for a dcterms:Agent responsible for recording a dwc:Occurrence." ;
                 skos:example "https://orcid.org/0000-0002-1825-0097" ,
                              "https://ror.org/00mh9zx15" .


###  http://rs.tdwg.org/dwc/terms/referenceID
dwc:referenceID rdf:type owl:DatatypeProperty ;
                rdfs:label "Reference ID" ;
                skos:definition "An identifier for a dcterms:BibliographicResource." .


###  http://rs.tdwg.org/dwc/terms/referenceRemarks
dwc:referenceRemarks rdf:type owl:DatatypeProperty ;
                     rdfs:label "Reference Remarks" ;
                     skos:definition "Comments or notes about a dcterms:BibliographicResource." .


###  http://rs.tdwg.org/dwc/terms/referenceType
dwc:referenceType rdf:type owl:DatatypeProperty ;
                  rdfs:label "Reference Type" ;
                  skos:definition "A category that best matches the nature of a dcterms:BibliographicResource." .


###  http://rs.tdwg.org/dwc/terms/relatedOccurrenceID
dwc:relatedOccurrenceID rdf:type owl:DatatypeProperty ;
                        rdfs:label "Related Occurrence ID" ;
                        skos:definition "An identifier for a related dwc:Occurrence in a dwc:OrganismInteraction." .


###  http://rs.tdwg.org/dwc/terms/relatedOrganismPart
dwc:relatedOrganismPart rdf:type owl:DatatypeProperty ;
                        rdfs:label "Related Organism Part" ;
                        skos:definition "A part of a object dwc:Organism involved in a dwc:OrganismInteraction." ;
                        skos:example "leaf" ,
                                     "leg" ,
                                     "stamen" ,
                                     "stomach" .


###  http://rs.tdwg.org/dwc/terms/relatedResourceID
dwc:relatedResourceID rdf:type owl:DatatypeProperty ;
                      rdfs:label "Related Resource ID" ;
                      skos:definition "An identifier for the related resource (the object) of a dwc:ResourceRelationship." ;
                      skos:example "dc609808-b09b-11e8-96f8-529269fb1459" .


###  http://rs.tdwg.org/dwc/terms/relationshipAccordingTo
dwc:relationshipAccordingTo rdf:type owl:DatatypeProperty ;
                            rdfs:label "Relationship According To" ;
                            skos:definition "A name of a dcterms:Agent responsible for asserting a dwc:ResourceRelationship." .


###  http://rs.tdwg.org/dwc/terms/relationshipAccordingToID
dwc:relationshipAccordingToID rdf:type owl:DatatypeProperty ;
                              rdfs:label "Relationship According To ID" ;
                              skos:definition "An identifier for a dcterms:Agent responsible for asserting a dwc:ResourceRelationship." .


###  http://rs.tdwg.org/dwc/terms/relationshipEstablishedDate
dwc:relationshipEstablishedDate rdf:type owl:DatatypeProperty ;
                                rdfs:label "Relationship Established Date" ;
                                skos:definition "A date on which a dwc:ResourceRelationship was established." .


###  http://rs.tdwg.org/dwc/terms/relationshipOfResource
dwc:relationshipOfResource rdf:type owl:DatatypeProperty ;
                           rdfs:label "Relationship Of Resource" ;
                           skos:definition "A relationship of a subject resource (identified by dwc:subjectResourceID) to a related resource (identified by dwc:relatedResourceID)." ;
                           skos:example "duplicate of" ,
                                        "host of" ,
                                        "located within" ,
                                        "mother of" ,
                                        "offspring of" ,
                                        "on slab with" ,
                                        "parasite of" ,
                                        "pollinated by members of taxon" ,
                                        "pollinated specific plant" ,
                                        "pollinator of members of taxon" ,
                                        "same as" ,
                                        "sibling of" ,
                                        "valid synonym of" .


###  http://rs.tdwg.org/dwc/terms/relationshipOfResourceID
dwc:relationshipOfResourceID rdf:type owl:DatatypeProperty ;
                             rdfs:label "Relationship Of Resource ID" ;
                             skos:definition "An IRI of a controlled vocabulary value for the type of a dwc:ResourceRelationship." ;
                             skos:example "http://purl.obolibrary.org/obo/RO_0002455" ,
                                          "http://purl.obolibrary.org/obo/RO_0002456" ,
                                          "https://www.inaturalist.org/observation_fields/879" .


###  http://rs.tdwg.org/dwc/terms/relationshipOrder
dwc:relationshipOrder rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:integer ;
                      rdfs:label "Relationship Order" ;
                      skos:definition "A numerical position of a dwc:ResourceRelationship in a set of dwc:ResourceRelationships that have the same combination of dwc:organismID, dwc:relatedOrganismID, dwc:relationshipType, dwc:relationshipTypeIRI, and dwc:relationshipTypeSource." .


###  http://rs.tdwg.org/dwc/terms/relationshipRemarks
dwc:relationshipRemarks rdf:type owl:DatatypeProperty ;
                        rdfs:label "Relationship Remarks" ;
                        skos:definition "Comments or notes about a dwc:ResourceRelationship." .


###  http://rs.tdwg.org/dwc/terms/relationshipType
dwc:relationshipType rdf:type owl:DatatypeProperty ;
                     rdfs:label "Relationship Of Resource" ;
                     skos:definition "The relationship of the subject (identified by dwc:resourceID) to the object (identified by dwc:relatedResourceID)." ;
                     skos:example "\\on slab with" ,
                                  "duplicate of" ,
                                  "host of" ,
                                  "located within" ,
                                  "mother of" ,
                                  "offspring of" ,
                                  "parasite of" ,
                                  "pollinated by members of taxon" ,
                                  "pollinated specific plant" ,
                                  "pollinator of members of taxon" ,
                                  "same as" ,
                                  "sibling of" ,
                                  "valid synonym of" .


###  http://rs.tdwg.org/dwc/terms/reproductiveCondition
dwc:reproductiveCondition rdf:type owl:DatatypeProperty ;
                          rdfs:label "Reproductive Condition" ;
                          skos:definition "The reproductive condition of the biological individual(s) represented in the dwc:Occurrence." ;
                          skos:example "fruit-bearing" ,
                                       "in bloom" ,
                                       "non-reproductive" ,
                                       "pregnant" .


###  http://rs.tdwg.org/dwc/terms/resourceID
dwc:resourceID rdf:type owl:DatatypeProperty ;
               rdfs:label "Resource ID" ;
               skos:definition "An identifier for the resource that is the subject of a dwc:ResourceRelationship." .


###  http://rs.tdwg.org/dwc/terms/resourceRelationshipID
dwc:resourceRelationshipID rdf:type owl:DatatypeProperty ;
                           rdfs:label "Resource Relationship ID" ;
                           skos:definition "An identifier for a dwc:ResourceRelationship." .


###  http://rs.tdwg.org/dwc/terms/rightsHolder
dwc:rightsHolder rdf:type owl:DatatypeProperty ;
                 rdfs:label "Rights Holder" ;
                 skos:definition "A name of a dcterms:Agent that owns or manages rights over a resource." .


###  http://rs.tdwg.org/dwc/terms/scientificName
dwc:scientificName rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:string ;
                   rdfs:label "Scientific Name" ;
                   skos:example "Agrostis stolonifera L. × Polypogon monspeliensis (L.) Desf." ,
                                "Ambystoma tigrinum diaboli" ,
                                "Coleoptera" ,
                                "Ctenomys sociabilis" ,
                                "Manis" ,
                                "Mentha ×smithiana R. A. Graham" ,
                                "Quercus agrifolia var. oxyadenia (Torr.) J.T. Howell" ,
                                "Roptrocerus typographi (Györfi, 1952)" ,
                                "Vespertilionidae" ,
                                "×Agropogon littoralis (Sm.) C. E. Hubb." .


###  http://rs.tdwg.org/dwc/terms/scientificNameAuthorship
dwc:scientificNameAuthorship rdf:type owl:DatatypeProperty ;
                             rdfs:label "Scientific Name Authorship" ;
                             skos:definition "The authorship information for the dwc:scientificName formatted according to the conventions of the applicable dwc:nomenclaturalCode." ;
                             skos:example "(Györfi, 1952)" ,
                                          "(Martinovský) Tzvelev" ,
                                          "(Torr.) J.T. Howell" .


###  http://rs.tdwg.org/dwc/terms/scientificNameID
dwc:scientificNameID rdf:type owl:DatatypeProperty ;
                     rdfs:label "Scientific Name ID" ;
                     skos:definition "An identifier for the nomenclatural (not taxonomic) details of a scientific name." ;
                     skos:example "urn:lsid:ipni.org:names:37829-1:1.3" .


###  http://rs.tdwg.org/dwc/terms/sequence
dwc:sequence rdf:type owl:DatatypeProperty ;
             rdfs:label "Sequence" ;
             skos:definition "A string representing nucleotide base pairs." .


###  http://rs.tdwg.org/dwc/terms/sex
dwc:sex rdf:type owl:DatatypeProperty ;
        rdfs:label "Sex" ;
        skos:definition "The sex of the biological individual(s) represented in the dwc:Occurrence." ;
        skos:example "female" ,
                     "hermaphrodite" ,
                     "male" .


###  http://rs.tdwg.org/dwc/terms/siteNumber
dwc:siteNumber rdf:type owl:DatatypeProperty ;
               rdfs:label "Site Number" ;
               skos:definition "An identifier (preferably globally unambiguous) for a named site." ;
               skos:example "USGS CENO LOC 21387" .


###  http://rs.tdwg.org/dwc/terms/specificEpithet
dwc:specificEpithet rdf:type owl:DatatypeProperty ;
                    rdfs:label "Specific Epithet" ;
                    skos:definition "The name of the first or species epithet of the dwc:scientificName." ;
                    skos:example "concolor" ,
                                 "gottschei" .


###  http://rs.tdwg.org/dwc/terms/startDayOfYear
dwc:startDayOfYear rdf:type owl:DatatypeProperty ;
                   rdfs:label "Start Day Of Year" ;
                   skos:definition "The earliest integer day of the year on which a dwc:Event occurred." ;
                   skos:example 1 ,
                                32 ,
                                365 ,
                                366 .


###  http://rs.tdwg.org/dwc/terms/stateProvince
dwc:stateProvince rdf:type owl:DatatypeProperty ;
                  rdfs:label "First Order Division" ;
                  skos:definition "The name of the next smaller administrative region than country (state, province, canton, department, region, etc.) in which the dcterms:Location occurs." ;
                  skos:example "Córdoba" ,
                               "Minas Gerais" ,
                               "Montana" .


###  http://rs.tdwg.org/dwc/terms/subfamily
dwc:subfamily rdf:type owl:DatatypeProperty ;
              rdfs:label "Subfamily" ;
              skos:definition "The full scientific name of the subfamily in which the dwc:Taxon is classified." ;
              skos:example "Orchidoideae" ,
                           "Periptyctinae" ,
                           "Sphindociinae" .


###  http://rs.tdwg.org/dwc/terms/subgenus
dwc:subgenus rdf:type owl:DatatypeProperty ;
             rdfs:label "Subgenus" ;
             skos:definition "The full scientific name of the subgenus in which the dwc:Taxon is classified." ;
             skos:example "Abacetus (Parastygis)" ,
                          "Dicranum subgen. Orthodicranum" .


###  http://rs.tdwg.org/dwc/terms/subjectCategory
dwc:subjectCategory rdf:type owl:DatatypeProperty ;
                    rdfs:label "Subject Category" ;
                    skos:definition "A category for the content of a dwc:Media resource." .


###  http://rs.tdwg.org/dwc/terms/subjectOccurrenceID
dwc:subjectOccurrenceID rdf:type owl:DatatypeProperty ;
                        rdfs:label "Subject Occurrence ID" ;
                        skos:definition "An identifier for a subject dwc:Occurrence in a dwc:OrganismInteraction." .


###  http://rs.tdwg.org/dwc/terms/subjectOrganismPart
dwc:subjectOrganismPart rdf:type owl:DatatypeProperty ;
                        rdfs:label "Subject Organism Part" ;
                        skos:definition "A part of a subject dwc:Organism involved in a dwc:OrganismInteraction." ;
                        skos:example "leaf" ,
                                     "leg" ,
                                     "stamen" ,
                                     "stomach" .


###  http://rs.tdwg.org/dwc/terms/substrate
dwc:substrate rdf:type owl:DatatypeProperty ;
              rdfs:label "Substrate" ;
              skos:definition "A biotic or abiotic material to which an dwc:Organism is attached when a dwc:Event occurs." ;
              skos:example "animal bones" ,
                           "decaying wood" ,
                           "stone" ,
                           "wall" ,
                           "wooden board fence" .


###  http://rs.tdwg.org/dwc/terms/surveyID
dwc:surveyID rdf:type owl:DatatypeProperty ;
             rdfs:label "Survey ID" ;
             skos:definition "An identifier for a dwc:Survey." .


###  http://rs.tdwg.org/dwc/terms/surveyTargetID
dwc:surveyTargetID rdf:type owl:DatatypeProperty ;
                   rdfs:label "Survey Target ID" ;
                   skos:definition "An identifier for a dwc:SurveyTarget." .


###  http://rs.tdwg.org/dwc/terms/surveyTargetType
dwc:surveyTargetType rdf:type owl:DatatypeProperty ;
                     rdfs:label "Survey Target Type" ;
                     skos:definition "A scope a dwc:SurveyTarget describes." ;
                     skos:example "establishmentMeans" ,
                                  "growthForm" ,
                                  "habitat" ,
                                  "lifeStage" ,
                                  "minimum length" ,
                                  "sex" ,
                                  "taxon" .


###  http://rs.tdwg.org/dwc/terms/surveyTargetUnit
dwc:surveyTargetUnit rdf:type owl:DatatypeProperty ;
                     rdfs:label "Survey Target Unit" ;
                     skos:definition "Unit associated with a value in dwc:surveyTargetValue." .


###  http://rs.tdwg.org/dwc/terms/surveyTargetValue
dwc:surveyTargetValue rdf:type owl:DatatypeProperty ;
                      rdfs:label "Survey Target Value" ;
                      skos:definition "A value of a characteristic to include or exclude in a dwc:SurveyTarget for a given dwc:surveyTargetType." ;
                      skos:example "Aves" ,
                                   "adult" ,
                                   "female" ,
                                   "height" ,
                                   "native" ,
                                   "oak savannah" ,
                                   "tree" ,
                                   "weight" .


###  http://rs.tdwg.org/dwc/terms/taxonAssignmentMethod
dwc:taxonAssignmentMethod rdf:type owl:DatatypeProperty ;
                          rdfs:label "Taxon Assignment Method" ;
                          skos:definition "Tool and thresholds used to compare sequences when computing 'species-level' OTUs." ;
                          skos:example "2.6.0+" ,
                                       "blastn" ,
                                       "e-value cutoff: 0.001" ,
                                       "identity cutoff: 0.97" .


###  http://rs.tdwg.org/dwc/terms/taxonID
dwc:taxonID rdf:type owl:DatatypeProperty ;
            rdfs:label "Taxon ID" ;
            skos:definition "An identifier for a dwc:Taxon." ;
            skos:example "32567" ,
                         "8fa58e08-08de-4ac1-b69c-1235340b7001" ,
                         "https://www.gbif.org/species/212" .


###  http://rs.tdwg.org/dwc/terms/taxonRank
dwc:taxonRank rdf:type owl:DatatypeProperty ;
              rdfs:label "Taxon Rank" ;
              skos:definition "The taxonomic rank of the most specific name in the dwc:scientificName." ;
              skos:example "forma" ,
                           "genus" ,
                           "nothogenus" ,
                           "nothospecies" ,
                           "nothosubspecies" ,
                           "species" ,
                           "subspecies" ,
                           "varietas" .


###  http://rs.tdwg.org/dwc/terms/taxonRemarks
dwc:taxonRemarks rdf:type owl:DatatypeProperty ;
                 rdfs:label "Taxon Remarks" ;
                 skos:definition "Comments or notes about the taxon or name." ;
                 skos:example "this name is a misspelling in common use" .


###  http://rs.tdwg.org/dwc/terms/totalReadCount
dwc:totalReadCount rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:integer ;
                   rdfs:label "Total Read Count" ;
                   skos:definition "A total number of reads in a dwc:NucleotideAnalysis." .


###  http://rs.tdwg.org/dwc/terms/typeStatus
dwc:typeStatus rdf:type owl:DatatypeProperty ;
               rdfs:label "Type Status" ;
               skos:definition "A list (concatenated and separated) of nomenclatural types (type status, typified scientific name, publication) applied to the resource." ;
               skos:example "holotype" .


###  http://rs.tdwg.org/dwc/terms/typifiedName
dwc:typifiedName rdf:type owl:DatatypeProperty ;
                 rdfs:label "Typified Name" ;
                 skos:definition "A scientific name for which a specimen or other name is the type." ;
                 skos:example "Polysiphonia amphibolis Womersley" .


###  http://rs.tdwg.org/dwc/terms/verbatimAssertionType
dwc:verbatimAssertionType rdf:type owl:DatatypeProperty ;
                          rdfs:label "Verbatim Assertion Type" ;
                          skos:definition "A string representing the type of dwc:Assertion as it appeared in the original record." ;
                          skos:example "Fish biomass" ,
                                       "sampling net mesh size" ,
                                       "water_temp" .


###  http://rs.tdwg.org/dwc/terms/verbatimCoordinateSystem
dwc:verbatimCoordinateSystem rdf:type owl:DatatypeProperty ;
                             rdfs:label "Verbatim Coordinate System" ;
                             skos:definition "A coordinate format for dwc:verbatimLatitude and dwc:verbatimLongitude or dwc:verbatimCoordinates." ;
                             skos:example "UTM" ,
                                          "decimal degrees" ,
                                          "degrees decimal minutes" ,
                                          "degrees minutes seconds" .


###  http://rs.tdwg.org/dwc/terms/verbatimCoordinates
dwc:verbatimCoordinates rdf:type owl:DatatypeProperty ;
                        rdfs:label "Verbatim Coordinates" ;
                        skos:definition "Verbatim original spatial coordinates of a dcterms:Location." ;
                        skos:example "17T 630000 4833400" ,
                                     "41 05 54S 121 05 34W" .


###  http://rs.tdwg.org/dwc/terms/verbatimDepth
dwc:verbatimDepth rdf:type owl:DatatypeProperty ;
                  rdfs:label "Verbatim Depth" ;
                  skos:definition "The original description of the depth below the local surface." ,
                                  "Verbatim Depth" ;
                  skos:example "100-200 m" .


###  http://rs.tdwg.org/dwc/terms/verbatimElevation
dwc:verbatimElevation rdf:type owl:DatatypeProperty ;
                      rdfs:label "Verbatim Elevation" ;
                      skos:definition "An original description of the elevation of a dcterms:Location." ;
                      skos:example "100-200 m" .


###  http://rs.tdwg.org/dwc/terms/verbatimEventDate
dwc:verbatimEventDate rdf:type owl:DatatypeProperty ;
                      rdfs:label "Verbatim Event Date" ;
                      skos:definition "The verbatim original representation of the date and time information for a dwc:Event." ;
                      skos:example "17IV1934" ,
                                   "1999-03-XX" ,
                                   "Marzo 2002" ,
                                   "spring 1910" .


###  http://rs.tdwg.org/dwc/terms/verbatimIdentification
dwc:verbatimIdentification rdf:type owl:DatatypeProperty ;
                           rdfs:label "Verbatim Identification" ;
                           skos:definition "A string representing a taxonomic identification as it appeared in the original record." ;
                           skos:example "Aconitum pilipes × A. variegatum" ,
                                        "Anser anser × Branta canadensis" ,
                                        "Lepomis auritus x cyanellus" ,
                                        "Ministrymon sp. nov. 1" ,
                                        "Pachyporidae?" ,
                                        "Peromyscus sp." ,
                                        "Potentilla × pantotricha Soják" .


###  http://rs.tdwg.org/dwc/terms/verbatimLabel
dwc:verbatimLabel rdf:type owl:DatatypeProperty ;
                  rdfs:label "Verbatim Label" ;
                  skos:definition "A verbatim original representation of the written information affixed or related to a dwc:MaterialEntity." .


###  http://rs.tdwg.org/dwc/terms/verbatimLatitude
dwc:verbatimLatitude rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:string ;
                     rdfs:label "Verbatim Latitude" ;
                     skos:definition "A verbatim original latitude of a dcterms:Location." ;
                     skos:example "41 05 54.03S" .


###  http://rs.tdwg.org/dwc/terms/verbatimLocality
dwc:verbatimLocality rdf:type owl:DatatypeProperty ;
                     rdfs:label "Verbatim Locality" ;
                     skos:definition "An original textual description of a dcterms:Location." ;
                     skos:example "25 km NNE Bariloche por R. Nac. 237" .


###  http://rs.tdwg.org/dwc/terms/verbatimLongitude
dwc:verbatimLongitude rdf:type owl:DatatypeProperty ;
                      rdfs:label "Verbatim Longitude" ;
                      skos:definition "A verbatim original longitude of a dcterms:Location." ;
                      skos:example "121d 10' 34\" W" .


###  http://rs.tdwg.org/dwc/terms/verbatimSRS
dwc:verbatimSRS rdf:type owl:DatatypeProperty ;
                rdfs:label "Verbatim SRS" ;
                skos:definition "The ellipsoid, geodetic datum, or spatial reference system (SRS) upon which coordinates given in dwc:verbatimLatitude and dwc:verbatimLongitude, or dwc:verbatimCoordinates are based." ;
                skos:example "Campo Inchauspe" ,
                             "Clarke 1866" ,
                             "EPSG:4326" ,
                             "European 1950" ,
                             "NAD27" ,
                             "WGS84" ,
                             "not recorded" .


###  http://rs.tdwg.org/dwc/terms/vernacularName
dwc:vernacularName rdf:type owl:DatatypeProperty ;
                   rdfs:label "Vernacular Name" ;
                   skos:definition "A common or vernacular name." ;
                   skos:example "Gänsegeier" ,
                                "cóndor andino" ,
                                "death cap" ,
                                "rainbow trout" ,
                                "smoky quartz" .


###  http://rs.tdwg.org/dwc/terms/verticalDatum
dwc:verticalDatum rdf:type owl:DatatypeProperty ;
                  rdfs:label "Vertical Datum" ;
                  skos:definition "EGM2008" ,
                                  "EGM84" ,
                                  "EGM96" ,
                                  "EPSG:7030" ,
                                  "PGM2000A" ,
                                  "PGM2004" ,
                                  "PGM2006" ,
                                  "PGM2007" ,
                                  "he vertical datum used as the reference upon which the values in the elevation terms are based." ,
                                  "not recorded" .


###  http://rs.tdwg.org/dwc/terms/vitality
dwc:vitality rdf:type owl:DatatypeProperty ;
             rdfs:label "Vitality" ;
             skos:definition "An indication of whether a dwc:Organism was alive or dead at the time of collection or observation." ;
             skos:example "alive" ,
                          "dead" ,
                          "mixedLot" ,
                          "notAssessed" ,
                          "uncertain" .


###  http://rs.tdwg.org/dwc/terms/waterBody
dwc:waterBody rdf:type owl:DatatypeProperty ;
              rdfs:label "Water Body" ;
              skos:definition "The name of the water body in which the dcterms:Location occurs." ;
              skos:example "Baltic Sea" ,
                           "Hudson River" ,
                           "Indian Ocean" ,
                           "Lago Nahuel Huapi" .


###  http://rs.tdwg.org/dwc/terms/year
dwc:year rdf:type owl:DatatypeProperty ;
         rdfs:label "Year" ;
         skos:definition "The four-digit year in which the dwc:Event occurred, according to the Common Era Calendar." ;
         skos:example 1160 ,
                      2008 .


###  http://rs.tdwg.org/dwcdp/terms/referenceType
dwcdp:referenceType rdf:type owl:DatatypeProperty ;
                    rdfs:comment "Recommended best practice is to use a controlled vocabulary." ;
                    rdfs:label "Reference Type" ;
                    skos:definition "A category that best matches the nature of a dcterms:BibliographicResource." .


###  http://rs.tdwg.org/eco/terms/absentTaxa
eco:absentTaxa rdf:type owl:DatatypeProperty ;
               rdfs:label "Absent Taxa" ;
               skos:definition "A list (concatenated and separated) of taxa reported absent during a dwc:Event." ;
               skos:example "Cetoniinae | Aclopinae | Cyclocephala modesta" ,
                            "Parabuteo unicinctus | Geranoaetus melanoleucus" .


###  http://rs.tdwg.org/eco/terms/abundanceCap
eco:abundanceCap rdf:type owl:DatatypeProperty ;
                 rdfs:label "Abundance Cap" ;
                 skos:definition "The reported maximum number of dwc:Organisms." ;
                 skos:example 300 ,
                              700 .


###  http://rs.tdwg.org/eco/terms/areNonTargetTaxaFullyReported
eco:areNonTargetTaxaFullyReported rdf:type owl:DatatypeProperty ;
                                  rdfs:label "Are Non Target Taxa Fully Reported" ;
                                  skos:definition "Every dwc:Organism that was outside of the target taxonomic scope (the combination of eco:targetTaxonomicScope and eco:excludedTaxonomicScope) and detected during a dwc:Event, and that was detectable using the given protocol (given in eco:protocolDescriptions and dwc:samplingProtocol), was reported." ;
                                  skos:example "false"^^xsd:boolean ,
                                               "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/compilationSourceTypes
eco:compilationSourceTypes rdf:type owl:DatatypeProperty ;
                           rdfs:label "Compilation Source Types" ;
                           skos:definition "The types of data sources contributing to the compilation reported." ;
                           skos:example "expertKnowledge | localKnowledge" ,
                                        "literature" ,
                                        "museumSpecimens" .


###  http://rs.tdwg.org/eco/terms/compilationTypes
eco:compilationTypes rdf:type owl:DatatypeProperty ;
                     rdfs:label "Compilation Types" ;
                     skos:definition "A statement specifying whether data reported are derived from sampling events, ancillary data compiled from other sources, or a combination of both." ;
                     skos:example "compilationOfExistingSources" ,
                                  "compilationOfExistingSourcesAndSamplingEvents" ,
                                  "compilationOfExistingSourcesAndSamplingEvents | compilationOfExistingSources" ,
                                  "samplingEvents" .


###  http://rs.tdwg.org/eco/terms/eventDurationUnit
eco:eventDurationUnit rdf:type owl:DatatypeProperty ;
                      rdfs:label "Event Duration Unit" ;
                      skos:definition "Units associated with a value in eco:eventDurationValue." ;
                      skos:example "days" ,
                                   "hours" ,
                                   "minutes" ,
                                   "months" ,
                                   "years" .


###  http://rs.tdwg.org/eco/terms/eventDurationValue
eco:eventDurationValue rdf:type owl:DatatypeProperty ;
                       rdfs:label "Event Duration Value" ;
                       skos:definition "The numeric value for the duration of a dwc:Event." ;
                       skos:example 1 ,
                                    30 .


###  http://rs.tdwg.org/eco/terms/geospatialScopeAreaUnit
eco:geospatialScopeAreaUnit rdf:type owl:DatatypeProperty ;
                            rdfs:label "Geospatial Scope Area Unit" ;
                            skos:definition "Units associated with a value in eco:geospatialScopeAreaValue." ;
                            skos:example "km²" .


###  http://rs.tdwg.org/eco/terms/geospatialScopeAreaValue
eco:geospatialScopeAreaValue rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:decimal ;
                             rdfs:label "Geospatial Scope Area Value" ;
                             skos:definition 25 ,
                                             "The numeric value for the total area of a geospatial scope of a dwc:Event." .


###  http://rs.tdwg.org/eco/terms/hasMaterialSamples
eco:hasMaterialSamples rdf:type owl:DatatypeProperty ;
                       rdfs:label "Has Material Samples" ;
                       skos:definition "Material samples were collected during a dwc:Event." ;
                       skos:example "false"^^xsd:boolean ,
                                    "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/hasNonTargetOrganisms
eco:hasNonTargetOrganisms rdf:type owl:DatatypeProperty ;
                          rdfs:label "Has Non Target Organisms" ;
                          skos:definition "One or more dwc:Organisms outside the target organismal scopes (eco:targetDegreeOfEstablishmentScope, eco:targetGrowthFormScope, and eco:targetLifeStageScope) were detected and reported for this dwc:Event." ;
                          skos:example "false"^^xsd:boolean ,
                                       "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/hasNonTargetTaxa
eco:hasNonTargetTaxa rdf:type owl:DatatypeProperty ;
                     rdfs:label "Has Non Target Taxa" ;
                     skos:definition "One or more dwc:Organisms of taxa outside the target taxonomic scope (the combination of eco:targetTaxonomicScope and eco:excludedTaxonomicScope) were detected and reported for this dwc:Event." ;
                     skos:example "false"^^xsd:boolean ,
                                  "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/hasVouchers
eco:hasVouchers rdf:type owl:DatatypeProperty ;
                rdfs:label "Has Vouchers" ;
                skos:definition "Specimen vouchers were collected during a dwc:Event." ;
                skos:example "false"^^xsd:boolean ,
                             "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/inventoryTypes
eco:inventoryTypes rdf:type owl:DatatypeProperty ;
                   rdfs:label "Inventory Types" ;
                   skos:definition "The types of search processes used to conduct the inventory." ;
                   skos:example "adventitious" ,
                                "compilation" ,
                                "openSearch" ,
                                "openSearch | opportunisticSearch" ,
                                "opportunisticSearch" ,
                                "restrictedSearch" .


###  http://rs.tdwg.org/eco/terms/isAbsenceReported
eco:isAbsenceReported rdf:type owl:DatatypeProperty ;
                      rdfs:label "Is Absence Reported" ;
                      skos:definition "Taxonomic absences were reported." ;
                      skos:example "false"^^xsd:boolean ,
                                   "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/isAbundanceCapReported
eco:isAbundanceCapReported rdf:type owl:DatatypeProperty ;
                           rdfs:label "Is Abundance Cap Reported" ;
                           skos:definition "A maximum number of dwc:Organisms was reported, as specified or restricted by the dwc:Protocol used." ;
                           skos:example "false"^^xsd:boolean ,
                                        "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/isAbundanceReported
eco:isAbundanceReported rdf:type owl:DatatypeProperty ;
                        rdfs:label "Is Abundance Reported" ;
                        skos:definition "The number of dwc:Organisms collected or observed was reported." ;
                        skos:example "false"^^xsd:boolean ,
                                     "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/isLeastSpecificTargetCategoryQuantityInclusive
eco:isLeastSpecificTargetCategoryQuantityInclusive rdf:type owl:DatatypeProperty ;
                                                   rdfs:label "Is Least Specific Target Category Quantity Inclusive" ;
                                                   skos:definition "The total detected quantity for a dwc:Taxon (including subcategories thereof) in a dwc:Event is given explicitly in a single record (dwc:organismQuantity value) for that dwc:Taxon." ;
                                                   skos:example "false"^^xsd:boolean ,
                                                                "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/isSamplingEffortReported
eco:isSamplingEffortReported rdf:type owl:DatatypeProperty ;
                             rdfs:label "Is Sampling Effort Reported" ;
                             skos:definition "The sampling effort associated with a dwc:Event was reported." ;
                             skos:example "false"^^xsd:boolean ,
                                          "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/isVegetationCoverReported
eco:isVegetationCoverReported rdf:type owl:DatatypeProperty ;
                              rdfs:label "Is Vegetation Cover Reported" ;
                              skos:definition "A vegetation cover metric was reported." ;
                              skos:example "false"^^xsd:boolean ,
                                           "true"^^xsd:boolean .


###  http://rs.tdwg.org/eco/terms/materialSampleTypes
eco:materialSampleTypes rdf:type owl:DatatypeProperty ;
                        rdfs:label "Material Sample Types" ;
                        skos:definition "A list (concatenated and separated) of material sample types collected during a dwc:Event." ;
                        skos:example "skeleton" ,
                                     "tissue | blood | fecal | stomachContent" ,
                                     "wholeOrganism" .


###  http://rs.tdwg.org/eco/terms/nonTargetTaxa
eco:nonTargetTaxa rdf:type owl:DatatypeProperty ;
                  rdfs:label "Non Target Taxa" ;
                  skos:definition "A list (concatenated and separated) of taxa reported during a dwc:Event that are outside of the target taxonomic scope (the combination of eco:targetTaxonomicScope and eco:excludedTaxonomicScope)." ;
                  skos:example "Cetoniinae | Aclopinae | Cyclocephala modesta" ,
                               "Parabuteo unicinctus | Geranoaetus melanoleucus" .


###  http://rs.tdwg.org/eco/terms/protocolDescriptions
eco:protocolDescriptions rdf:type owl:DatatypeProperty ;
                         rdfs:label "Protocol Descriptions" ;
                         skos:definition "A detailed description of the dwc:Protocols used during a dwc:Survey." ;
                         skos:example "Three conventional harp traps (3.2m ht x 2.2m w) were established in flight path zones for a period of 4 hrs at dawn and dusk for a total of 10 trap nights. Traps were visited on an hourly basis during each deployment period and the trap catch recorded for species, size, weight, sex, age and maternal status." .


###  http://rs.tdwg.org/eco/terms/protocolNames
eco:protocolNames rdf:type owl:DatatypeProperty ;
                  rdfs:label "Protocol Names" ;
                  skos:definition "Categorical descriptive names for the dwc:Protocols used during a dwc:Event." ;
                  skos:example "boxTrapping" ,
                               "boxTrapping | funnelTrapping" ,
                               "floraInventory" .


###  http://rs.tdwg.org/eco/terms/protocolReferences
eco:protocolReferences rdf:type owl:DatatypeProperty ;
                       rdfs:label "Protocol References" ;
                       skos:definition "A list (concatenated and separated) of dcterms:BibliographicResources used in a dwc:Protocol." ;
                       skos:example "Penguins from space: faecal stains reveal the location of emperor penguin colonies, https://doi.org/10.1111/j.1466-8238.2009.00467.x" .


###  http://rs.tdwg.org/eco/terms/reportedExtremeConditions
eco:reportedExtremeConditions rdf:type owl:DatatypeProperty ;
                              rdfs:label "Reported Extreme Conditions" ;
                              skos:definition "A description of any extreme weather or environmental conditions that may have affected a dwc:Event." ;
                              skos:example "flooding during week 3 of surveys" ,
                                           "rockslide at site 2" .


###  http://rs.tdwg.org/eco/terms/reportedWeather
eco:reportedWeather rdf:type owl:DatatypeProperty ;
                    rdfs:label "Reported Weather" ;
                    skos:definition "A list of weather or climatic conditions present during a dwc:Event." ;
                    skos:example "{\\\"minimumTemperatureInDegreesFahrenheit\\\": 18, \\\"maximumTemperatureInDegreesFahrenheit\\\": 32}" .


###  http://rs.tdwg.org/eco/terms/sampleSizeUnit
eco:sampleSizeUnit rdf:type owl:DatatypeProperty ;
                   rdfs:label "Sample Size Unit" ;
                   skos:definition "The unit of measurement of the size (time duration, length, area, or volume) of a sample in a sampling dwc:Event." ;
                   skos:example "cubic metre" ,
                                "day" ,
                                "hour" ,
                                "metre" ,
                                "minute" ,
                                "square metre" .


###  http://rs.tdwg.org/eco/terms/sampleSizeValue
eco:sampleSizeValue rdf:type owl:DatatypeProperty ;
                    rdfs:label "Sample Size Value" ;
                    skos:definition "A numeric value for a measurement of the size (time duration, length, area, or volume) of a sample in a sampling dwc:Event." ;
                    skos:example 5 .


###  http://rs.tdwg.org/eco/terms/samplingEffortProtocol
eco:samplingEffortProtocol rdf:type owl:DatatypeProperty ;
                           rdfs:label "Sampling Effort Protocol" .


###  http://rs.tdwg.org/eco/terms/samplingEffortUnit
eco:samplingEffortUnit rdf:type owl:DatatypeProperty ;
                       rdfs:label "Sampling Effort Unit" ;
                       skos:definition "Units associated with a value in eco:samplingEffortValue." ;
                       skos:example "personHours" ,
                                    "trapDays" ,
                                    "trapHours" .


###  http://rs.tdwg.org/eco/terms/samplingEffortValue
eco:samplingEffortValue rdf:type owl:DatatypeProperty ;
                        rdfs:range xsd:decimal ;
                        rdfs:label "Sampling Effort Value" ;
                        skos:definition "The numeric value for the sampling effort expended during a dwc:Event." ;
                        skos:example 5.5 ,
                                     1900 ,
                                     40 .


###  http://rs.tdwg.org/eco/terms/samplingPerformedBy
eco:samplingPerformedBy rdf:type owl:DatatypeProperty ;
                        rdfs:label "Sampling Performed By" ;
                        skos:definition "A dcterms:Agent responsible for sampling." ;
                        skos:example "JJ Green" ,
                                     "KK Wall" ,
                                     "LL Pink and FF Grey | Aspen Center for Environmental Studies" ,
                                     "North American Butterfly Association" .


###  http://rs.tdwg.org/eco/terms/siteCount
eco:siteCount rdf:type owl:DatatypeProperty ;
              rdfs:label "Site Count" ;
              skos:definition "Total number of individual sites surveyed during a dwc:Event." ;
              skos:example 1 ,
                           15 .


###  http://rs.tdwg.org/eco/terms/siteNestingDescription
eco:siteNestingDescription rdf:type owl:DatatypeProperty ;
                           rdfs:label "Site Nesting Description" ;
                           skos:definition "5 sampling sites of 3-5 plots each" ;
                           skos:example "Textual description of a hierarchical sampling design." .


###  http://rs.tdwg.org/eco/terms/taxonCompletenessProtocols
eco:taxonCompletenessProtocols rdf:type owl:DatatypeProperty ;
                               rdfs:label "Taxon Completenes Protocols" ;
                               skos:definition "A description of or reference to the dwc:Protocols used to determine eco:taxonCompletenessReported." ;
                               skos:example "based on species accumulation curves" ,
                                            "census | based on sampling effort" .


###  http://rs.tdwg.org/eco/terms/taxonCompletenessReported
eco:taxonCompletenessReported rdf:type owl:DatatypeProperty ;
                              rdfs:label "Taxon Completeness Reported" ;
                              skos:definition "Statement about whether the taxonomic completeness of a dwc:Event was assessed." ;
                              skos:example "notReported" ,
                                           "reportedComplete" ,
                                           "reportedIncomplete" .


###  http://rs.tdwg.org/eco/terms/totalAreaSampledUnit
eco:totalAreaSampledUnit rdf:type owl:DatatypeProperty ;
                         rdfs:label "Total Area Sampled Unit" ;
                         skos:definition "Units associated with a value in eco:totalAreaSampledValue." ;
                         skos:example "km²" .


###  http://rs.tdwg.org/eco/terms/totalAreaSampledValue
eco:totalAreaSampledValue rdf:type owl:DatatypeProperty ;
                          rdfs:label "Total Area Sampled Value" ;
                          skos:definition "The numeric value for the total area dwc:Surveyed during a dwc:Event." ;
                          skos:example 0.8 .


###  http://rs.tdwg.org/eco/terms/verbatimSiteDescriptions
eco:verbatimSiteDescriptions rdf:type owl:DatatypeProperty ;
                             rdfs:label "Verbatim Site Descriptions" ;
                             skos:definition "Original textual description of site(s)." ;
                             skos:example "Wet flatwoods | Wet depression surrounded by mesic longleaf pine flatwoods | Ground cover of thick Andropogon spp., Sporobolus floridanus, Vaccinium spp, Rhynchospora spp., Centella erecta, Panicum rigidulum." .


###  http://rs.tdwg.org/eco/terms/verbatimSiteNames
eco:verbatimSiteNames rdf:type owl:DatatypeProperty ;
                      rdfs:label "Verbatim Site Names" ;
                      skos:definition "A list (concatenated and separated) of original site names." ;
                      skos:example "East Coastal Fringe | St. Marks Wildlife Management Area" ,
                                   "S1 | S2 | C1 | C2 | R14 | R22 | W1" .


###  http://rs.tdwg.org/eco/terms/verbatimTargetScope
eco:verbatimTargetScope rdf:type owl:DatatypeProperty ;
                        rdfs:label "Verbatim Target Scope" ;
                        skos:definition "A verbatim original description of a dwc:Event scope." ;
                        skos:example "dead animals, ground-living insects" ,
                                     "freshwater macroinvertebrates" ,
                                     "small mammals" .


###  http://rs.tdwg.org/eco/terms/voucherInstitutions
eco:voucherInstitutions rdf:type owl:DatatypeProperty ;
                        rdfs:label "Voucher Institutions" ;
                        skos:definition "A list (concatenated and separated) of the names or acronyms of the institutions where vouchers collected during a dwc:Event were deposited." ;
                        skos:example "AMNH | MVZ" ,
                                     "FMNH" ,
                                     "Nairobi National Museum" .


###  http://rs.tdwg.org/mineralogy/terms/classificationCode
minext:classificationCode rdf:type owl:DatatypeProperty ;
                          rdfs:label "Geo Classification Code" ;
                          skos:definition "An identifier for a minext:classificationCode." ;
                          skos:example "71.02.02a.01" ,
                                       "9.AD.25" .


###  http://rs.tdwg.org/mineralogy/terms/name
minext:name rdf:type owl:DatatypeProperty ;
            rdfs:label "Geo Name" ;
            skos:definition "A human-readable lexical label assigned to a mineral includes both informal (e.g., variety, synonym) and formal (classification) forms." ;
            skos:example "Almandine" ,
                         "Fluorite" ,
                         "Garnet Group" ,
                         "Plagioclase (Series)" .


###  https://w3id.org/mixs/0000001
<https://w3id.org/mixs/0000001> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Amount Or Size Of Sample Collected" ;
                                skos:definition "The total amount or size (volume (ml), mass (g) or area (m2) ) of sample collected." ;
                                skos:example "5 liter" .


###  https://w3id.org/mixs/0000002
<https://w3id.org/mixs/0000002> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sample Collection Device" ;
                                skos:definition "The device used to collect an environmental sample. This field accepts terms listed under environmental sampling device (http://purl.obolibrary.org/obo/ENVO). This field also accepts terms listed under specimen collection device (http://purl.obolibrary.org/obo/GENEPIO_0002094)." .


###  https://w3id.org/mixs/0000003
<https://w3id.org/mixs/0000003> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Isolation And Growth Condition" ;
                                skos:definition "Publication reference in the form of pubmed ID (pmid), digital object identifier (doi) or url for isolation and growth condition specifications of the organism/material." ;
                                skos:example "doi:10.1016/j.syapm.2018.01.009" .


###  https://w3id.org/mixs/0000005
<https://w3id.org/mixs/0000005> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Contamination Screening Input" ;
                                skos:definition "The type of sequence data used as input." ;
                                skos:example "contigs" .


###  https://w3id.org/mixs/0000006
<https://w3id.org/mixs/0000006> rdf:type owl:DatatypeProperty ;
                                rdfs:label "WGA Amplification Kit" ;
                                skos:definition "Kit used to amplify genomic DNA in preparation for sequencing." ;
                                skos:example "qiagen repli-g" .


###  https://w3id.org/mixs/0000008
<https://w3id.org/mixs/0000008> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Experimental Factor" ;
                                skos:definition "Experimental factors are essentially the variable aspects of an experiment design which can be used to describe an experiment, or set of experiments, in an increasingly detailed manner. This field accepts ontology terms from Experimental Factor Ontology (EFO) and/or Ontology for Biomedical Investigations (OBI). For a browser of EFO (v 2.95) terms, please see http://purl.bioontology.org/ontology/EFO; for a browser of OBI (v 2018-02-12) terms please see http://purl.bioontology.org/ontology/OBI." ;
                                skos:example "time series design [EFO:0001779]" .


###  https://w3id.org/mixs/0000012
<https://w3id.org/mixs/0000012> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Broad-Scale Environmental Context" ;
                                skos:definition "In this field, report which major environmental system your sample or specimen came from. The systems identified should have a coarse spatial grain, to provide the general environmental context of where the sampling was done (e.g. were you in the desert or a rainforest?). We recommend using subclasses of ENVO’s biome class: http://purl.obolibrary.org/obo/ENVO_00000428. Format (one term): termLabel [termID], Format (multiple terms): termLabel [termID]|termLabel [termID]|termLabel [termID]. Example: Annotating a water sample from the photic zone in middle of the Atlantic Ocean, consider: oceanic epipelagic zone biome [ENVO:01000033]. Example: Annotating a sample from the Amazon rainforest consider: tropical moist broadleaf forest biome [ENVO:01000228]. If needed, request new terms on the ENVO tracker, identified here: http://www.obofoundry.org/ontology/envo.html." .


###  https://w3id.org/mixs/0000013
<https://w3id.org/mixs/0000013> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Local Environmental Context" ;
                                skos:definition "In this field, report the entity or entities which are in your sample or specimen’s local vicinity and which you believe have significant causal influences on your sample or specimen. Please use terms that are present in ENVO and which are of smaller spatial grain than your entry for env_broad_scale. Format (one term): termLabel [termID]; Format (multiple terms): termLabel [termID]|termLabel [termID]|termLabel [termID]. Example: Annotating a pooled sample taken from various vegetation layers in a forest consider: canopy [ENVO:00000047]|herb and fern layer [ENVO:01000337]|litter layer [ENVO:01000338]|understory [01000335]|shrub layer [ENVO:01000336]. If needed, request new terms on the ENVO tracker, identified here: http://www.obofoundry.org/ontology/envo.html." ;
                                skos:example "hillside [ENVO:01000333]" ,
                                             "rangeland biome [ENVO:01000247]" .


###  https://w3id.org/mixs/0000014
<https://w3id.org/mixs/0000014> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Environmental Medium" ;
                                skos:definition "In this field, report which environmental material or materials (pipe separated) immediately surrounded your sample or specimen prior to sampling, using one or more subclasses of ENVO’s environmental material class: http://purl.obolibrary.org/obo/ENVO_00010483. Format (one term): termLabel [termID]; Format (multiple terms): termLabel [termID]|termLabel [termID]|termLabel [termID]. Example: Annotating a fish swimming in the upper 100 m of the Atlantic Ocean, consider: ocean water [ENVO:00002151]. Example: Annotating a duck on a pond consider: pond water [ENVO:00002228]|air ENVO_00002005. If needed, request new terms on the ENVO tracker, identified here: http://www.obofoundry.org/ontology/envo.html." ;
                                skos:example "bluegrass field soil [ENVO:00005789]" .


###  https://w3id.org/mixs/0000015
<https://w3id.org/mixs/0000015> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Relationship To Oxygen" ;
                                skos:definition "Is this organism an aerobe, anaerobe? Please note that aerobic and anaerobic are valid descriptors for microbial environments." ;
                                skos:example "aerobe" .


###  https://w3id.org/mixs/0000016
<https://w3id.org/mixs/0000016> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sample Material Processing" ;
                                skos:definition "A brief description of any processing applied to the sample during or after retrieving the sample from environment, or a link to the relevant protocol(s) performed." ;
                                skos:example "filtering of seawater, storing samples in ethanol" .


###  https://w3id.org/mixs/0000017
<https://w3id.org/mixs/0000017> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Size Fraction Selected" ;
                                skos:definition "Filtering pore size used in sample preparation." ;
                                skos:example "0-0.22 micrometer" .


###  https://w3id.org/mixs/0000020
<https://w3id.org/mixs/0000020> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Subspecific Genetic Lineage" ;
                                skos:definition "This should provide further information about the genetic distinctness of the sequenced organism by recording additional information e.g. serovar, serotype, biotype, ecotype, or any relevant genetic typing schemes like Group I plasmid. It can also contain alternative taxonomic information. It should contain both the lineage name, and the lineage rank, i.e. biovar:abc123." ;
                                skos:example "serovar:Newport" .


###  https://w3id.org/mixs/0000021
<https://w3id.org/mixs/0000021> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Ploidy" ;
                                skos:definition "The ploidy level of the genome (e.g. allopolyploid, haploid, diploid, triploid, tetraploid). It has implications for the downstream study of duplicated gene and regions of the genomes (and perhaps for difficulties in assembly). For terms, please select terms listed under class ploidy (PATO:001374) of Phenotypic Quality Ontology (PATO), and for a browser of PATO (v 2018-03-27) please refer to http://purl.bioontology.org/ontology/PATO." ;
                                skos:example "allopolyploidy [PATO:0001379]" .


###  https://w3id.org/mixs/0000022
<https://w3id.org/mixs/0000022> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Number Of Replicons" ;
                                skos:definition "Reports the number of replicons in a nuclear genome of eukaryotes, in the genome of a bacterium or archaea or the number of segments in a segmented virus. Always applied to the haploid chromosome count of a eukaryote." ;
                                skos:example 2 .


###  https://w3id.org/mixs/0000023
<https://w3id.org/mixs/0000023> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Extrachromosomal Elements" ;
                                skos:definition 5 ,
                                                "Do plasmids exist of significant phenotypic consequence (e.g. ones that determine virulence or antibiotic resistance). Megaplasmids? Other plasmids (borrelia has 15+ plasmids)." .


###  https://w3id.org/mixs/0000024
<https://w3id.org/mixs/0000024> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Estimated Genome Size" ;
                                skos:definition "The estimated size of the genome prior to sequencing. Of particular importance in the sequencing of (eukaryotic) genome which could remain in draft form for a long or unspecified period." ;
                                skos:example "300000 bp" .


###  https://w3id.org/mixs/0000025
<https://w3id.org/mixs/0000025> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Reference For Biomaterial" ;
                                skos:definition "Primary publication if isolated before genome publication; otherwise, primary genome report." ;
                                skos:example "doi:10.1016/j.syapm.2018.01.009" .


###  https://w3id.org/mixs/0000026
<https://w3id.org/mixs/0000026> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Source Material Identifiers" ;
                                skos:definition "A unique identifier assigned to a material sample (as defined by http://rs.tdwg.org/dwc/terms/materialSampleID, and as opposed to a particular digital record of a material sample) used for extracting nucleic acids, and subsequent sequencing." ;
                                skos:example "MPI012345" .


###  https://w3id.org/mixs/0000027
<https://w3id.org/mixs/0000027> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Known Pathogenicity" ;
                                skos:definition "To what is the entity pathogenic?" ;
                                skos:example "human, animal, plant, fungi, bacteria" .


###  https://w3id.org/mixs/0000028
<https://w3id.org/mixs/0000028> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Observed Biotic Relationship" ;
                                skos:definition "Description of relationship(s) between the subject organism and other organism(s) it is associated with. E.g., parasite on species X; mutualist with species Y. The target organism is the subject of the relationship, and the other organism(s) is the object." ;
                                skos:example "free living" .


###  https://w3id.org/mixs/0000029
<https://w3id.org/mixs/0000029> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Host Scientific Name" ;
                                skos:definition "Report the host's taxonomic name and/or NCBI taxonomy ID." ;
                                skos:example "Homo sapiens and/or 9606" .


###  https://w3id.org/mixs/0000030
<https://w3id.org/mixs/0000030> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Host Specificity Or Range" ;
                                skos:definition "The range and diversity of host species that an organism is capable of infecting, defined by NCBI taxonomy identifier." ;
                                skos:example "9606" .


###  https://w3id.org/mixs/0000031
<https://w3id.org/mixs/0000031> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Host Disease Status" ;
                                skos:definition "List of diseases with which the host has been diagnosed; can include multiple diagnoses. The value of the field depends on host; for humans the terms should be chosen from the DO (Human Disease Ontology) at https://www.disease-ontology.org, non-human host diseases are free text." .


###  https://w3id.org/mixs/0000032
<https://w3id.org/mixs/0000032> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Trophic Level" ;
                                skos:definition "Trophic levels are the feeding position in a food chain. Microbes can be a range of producers (e.g. chemolithotroph)." ;
                                skos:example "heterotroph" .


###  https://w3id.org/mixs/0000033
<https://w3id.org/mixs/0000033> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Propagation" ;
                                skos:definition "The type of reproduction from the parent stock. Values for this field is specific to different taxa. For phage or virus: lytic/lysogenic/temperate/obligately lytic. For plasmids: incompatibility group. For eukaryotes: sexual/asexual." ;
                                skos:example "lytic" .


###  https://w3id.org/mixs/0000034
<https://w3id.org/mixs/0000034> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Encoded Traits" ;
                                skos:definition "Should include key traits like antibiotic resistance or xenobiotic degradation phenotypes for plasmids, converting genes for phage." ;
                                skos:example "beta-lactamase class A" .


###  https://w3id.org/mixs/0000035
<https://w3id.org/mixs/0000035> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Source Of UViGs" ;
                                skos:definition "Type of dataset from which the UViG was obtained." ;
                                skos:example "viral fraction metagenome (virome)" .


###  https://w3id.org/mixs/0000036
<https://w3id.org/mixs/0000036> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Virus Enrichment Approach" ;
                                skos:definition "List of approaches used to enrich the sample for viruses, if any." ;
                                skos:example "DNAse" ,
                                             "FeCl Precipitation" ,
                                             "filtration" ,
                                             "ultracentrifugation" .


###  https://w3id.org/mixs/0000037
<https://w3id.org/mixs/0000037> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Nucleic Acid Extraction" ;
                                skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the material separation to recover the nucleic acid fraction from a sample." ;
                                skos:example "https://mobio.com/media/wysiwyg/pdfs/protocols/12888.pdf" .


###  https://w3id.org/mixs/0000038
<https://w3id.org/mixs/0000038> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Nucleic Acid Amplification" ;
                                skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the enzymatic amplification (PCR, TMA, NASBA) of specific nucleic acids." ;
                                skos:example "https://phylogenomics.me/protocols/16s-pcr-protocol/" .


###  https://w3id.org/mixs/0000039
<https://w3id.org/mixs/0000039> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Library Size" ;
                                skos:definition "Total number of clones in the library prepared for the project." ;
                                skos:example 50 .


###  https://w3id.org/mixs/0000040
<https://w3id.org/mixs/0000040> rdf:type owl:DatatypeProperty ;
                                rdfs:range xsd:integer ;
                                rdfs:label "Library Reads Sequenced" ;
                                skos:definition "Total number of clones sequenced from the library." ;
                                skos:example 20 .


###  https://w3id.org/mixs/0000041
<https://w3id.org/mixs/0000041> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Library Layout" ;
                                skos:definition "Specify whether to expect single, paired, or other configuration of reads." ;
                                skos:example "paired" .


###  https://w3id.org/mixs/0000042
<https://w3id.org/mixs/0000042> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Library Vector" ;
                                skos:definition "Cloning vector type(s) used in construction of libraries." ;
                                skos:example "Bacteriophage P1" .


###  https://w3id.org/mixs/0000043
<https://w3id.org/mixs/0000043> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Library Screening Strategy" ;
                                skos:definition "Specific enrichment or screening methods applied before and/or after creating libraries." ;
                                skos:example "enriched, screened, normalized" .


###  https://w3id.org/mixs/0000044
<https://w3id.org/mixs/0000044> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Target Gene" ;
                                skos:definition "Targeted gene or locus name for marker gene studies." ;
                                skos:example "16S rRNA, 18S rRNA, nif, amoA, rpo" .


###  https://w3id.org/mixs/0000045
<https://w3id.org/mixs/0000045> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Target Subfragment" ;
                                skos:definition "Name of subfragment of a gene or locus. Important to e.g. identify special regions on marker genes like V6 on 16S rRNA." ;
                                skos:example "V6, V9, ITS" .


###  https://w3id.org/mixs/0000046
<https://w3id.org/mixs/0000046> rdf:type owl:DatatypeProperty ;
                                rdfs:label "PCR Primers" ;
                                skos:definition "PCR primers that were used to amplify the sequence of the targeted gene, locus or subfragment. This field should contain all the primers used for a single PCR reaction if multiple forward or reverse primers are present in a single PCR reaction. The primer sequence should be reported in uppercase letters." ;
                                skos:example "FWD:GTGCCAGCMGCCGCGGTAA;REV:GGACTACHVGGGTWTCTAAT" .


###  https://w3id.org/mixs/0000047
<https://w3id.org/mixs/0000047> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Multiplex Identifiers" ;
                                skos:definition "Molecular barcodes, called Multiplex Identifiers (MIDs), that are used to specifically tag unique samples in a sequencing run. Sequence should be reported in uppercase letters." ;
                                skos:example "GTGAATAT" .


###  https://w3id.org/mixs/0000048
<https://w3id.org/mixs/0000048> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Adapters" ;
                                skos:definition "Adapters provide priming sequences for both amplification and sequencing of the sample-library fragments. Both adapters should be reported; in uppercase letters." ;
                                skos:example "AATGATACGGCGACCACCGAGATCTACACGCT;CAAGCAGAAGACGGCATACGAGAT" .


###  https://w3id.org/mixs/0000049
<https://w3id.org/mixs/0000049> rdf:type owl:DatatypeProperty ;
                                rdfs:label "PCR Conditions" ;
                                skos:definition "Description of reaction conditions and components of polymerase chain reaction performed during library preparation." ;
                                skos:example "initial denaturation:94_3;annealing:50_1;elongation:72_1.5;final elongation:72_10;35" ,
                                             "initial denaturation:94degC_1.5min" .


###  https://w3id.org/mixs/0000050
<https://w3id.org/mixs/0000050> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sequencing Method" ;
                                skos:definition "Sequencing machine used. Where possible the term should be taken from the OBI list of DNA sequencers (http://purl.obolibrary.org/obo/OBI_0400103)." ;
                                skos:example "454 Genome Sequencer FLX [OBI:0000702]" .


###  https://w3id.org/mixs/0000051
<https://w3id.org/mixs/0000051> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sequence Quality Check" ;
                                skos:definition "Indicate if the sequence has been called by automatic systems (none) or undergone a manual editing procedure (e.g. by inspecting the raw data or chromatograms). Applied only for sequences that are not submitted to SRA, ENA or DRA." ;
                                skos:example "none" .


###  https://w3id.org/mixs/0000052
<https://w3id.org/mixs/0000052> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Chimera Check Software" ;
                                skos:definition "Tool(s) used for chimera checking, including version number and parameters, to discover and remove chimeric sequences. A chimeric sequence is comprised of two or more phylogenetically distinct parent sequences." ;
                                skos:example "uchime;v4.1;default parameters" .


###  https://w3id.org/mixs/0000053
<https://w3id.org/mixs/0000053> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Taxonomic Identity Marker" ;
                                skos:definition "The phylogenetic marker(s) used to assign an organism name to the SAG or MAG." ;
                                skos:example "other" .


###  https://w3id.org/mixs/0000054
<https://w3id.org/mixs/0000054> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Single Cell Or Viral Particle Lysis Kit Protocol" ;
                                skos:definition "Name of the kit or standard protocol used for cell(s) or particle(s) lysis." ;
                                skos:example "ambion single cell lysis kit" .


###  https://w3id.org/mixs/0000055
<https://w3id.org/mixs/0000055> rdf:type owl:DatatypeProperty ;
                                rdfs:label "WGA Amplification Approach" ;
                                skos:definition "Method used to amplify genomic DNA in preparation for sequencing." ;
                                skos:example "mda based" .


###  https://w3id.org/mixs/0000056
<https://w3id.org/mixs/0000056> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Assembly Quality" ;
                                skos:definition "The assembly quality category is based on sets of criteria outlined for each assembly quality category." ;
                                skos:example "High-quality draft genome" .


###  https://w3id.org/mixs/0000057
<https://w3id.org/mixs/0000057> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Assembly Name" ;
                                skos:definition "Name/version of the assembly provided by the submitter that is used in the genome browsers and in the community." ;
                                skos:example "HuRef, JCVI_ISG_i3_1.0" .


###  https://w3id.org/mixs/0000058
<https://w3id.org/mixs/0000058> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Assembly Software" ;
                                skos:definition "Assembly Software" ;
                                skos:example "metaSPAdes;3.11.0;kmer set 21,33,55,77,99,121, default parameters otherwise" .


###  https://w3id.org/mixs/0000059
<https://w3id.org/mixs/0000059> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Annotation" ;
                                skos:definition "Tool used for annotation, or for cases where annotation was provided by a community jamboree or model organism database rather than by a specific submitter." ;
                                skos:example "prokka" .


###  https://w3id.org/mixs/0000060
<https://w3id.org/mixs/0000060> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Number Of Contigs" ;
                                skos:definition "Total number of contigs in the cleaned/submitted assembly that makes up a given genome, SAG, MAG, or UViG." ;
                                skos:example 40 .


###  https://w3id.org/mixs/0000061
<https://w3id.org/mixs/0000061> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Feature Prediction" ;
                                skos:definition "Method used to predict UViGs features such as ORFs, integration site, etc." ;
                                skos:example "Prodigal;2.6.3;default parameters" .


###  https://w3id.org/mixs/0000062
<https://w3id.org/mixs/0000062> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Reference Databases" ;
                                skos:definition "List of database(s) used for ORF annotation, along with version number and reference to website or publication." ;
                                skos:example "pVOGs;5;http://dmk-brain.ecn.uiowa.edu/pVOGs/ Grazziotin et al. 2017 doi:10.1093/nar/gkw975" .


###  https://w3id.org/mixs/0000063
<https://w3id.org/mixs/0000063> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Similarity Search Method" ;
                                skos:definition "Tool used to compare ORFs with database, along with version and cutoffs used." ;
                                skos:example "HMMER3;3.1b2;hmmsearch, cutoff of 50 on score" .


###  https://w3id.org/mixs/0000064
<https://w3id.org/mixs/0000064> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Taxonomic Classification" ;
                                skos:definition "Method used for taxonomic classification, along with reference database used, classification rank, and thresholds used to classify new genomes." ;
                                skos:example "vConTACT vContact2 (references from NCBI RefSeq v83, genus rank classification, default parameters)" .


###  https://w3id.org/mixs/0000065
<https://w3id.org/mixs/0000065> rdf:type owl:DatatypeProperty ;
                                rdfs:label "16S Recovered" ;
                                skos:definition "Can a 16S gene be recovered from the submitted SAG or MAG?" ;
                                skos:example "true"^^xsd:boolean .


###  https://w3id.org/mixs/0000066
<https://w3id.org/mixs/0000066> rdf:type owl:DatatypeProperty ;
                                rdfs:label "16S Recovery Software" ;
                                skos:definition "Tools used for 16S rRNA gene extraction." ;
                                skos:example "rambl;v2;default parameters" .


###  https://w3id.org/mixs/0000067
<https://w3id.org/mixs/0000067> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Number Of Standard tRNAs Extracted" ;
                                skos:definition "The total number of tRNAs identified from the SAG or MAG." ;
                                skos:example "18" .


###  https://w3id.org/mixs/0000068
<https://w3id.org/mixs/0000068> rdf:type owl:DatatypeProperty ;
                                rdfs:label "tRNA Extraction Software" ;
                                skos:definition "Tools used for tRNA identification." ;
                                skos:example "infernal;v2;default parameters" .


###  https://w3id.org/mixs/0000069
<https://w3id.org/mixs/0000069> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Completeness Score" ;
                                skos:definition "Completeness score is typically based on either the fraction of markers found as compared to a database or the percent of a genome found as compared to a closely related reference genome. High Quality Draft: >90%, Medium Quality Draft: >50%, and Low Quality Draft: < 50% should have the indicated completeness scores." ;
                                skos:example "med;60%" .


###  https://w3id.org/mixs/0000070
<https://w3id.org/mixs/0000070> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Completeness Software" ;
                                skos:definition "Tools used for completion estimate, i.e. checkm, anvi'o, busco." ;
                                skos:example "checkm" .


###  https://w3id.org/mixs/0000071
<https://w3id.org/mixs/0000071> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Completeness Approach" ;
                                skos:definition "The approach used to determine the completeness of a given genomic assembly, which would typically make use of a set of conserved marker genes or a closely related reference genome. For UViG completeness, include reference genome or group used, and contig feature suggesting a complete genome." ;
                                skos:example "other" .


###  https://w3id.org/mixs/0000072
<https://w3id.org/mixs/0000072> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Contamination Score" ;
                                skos:definition "The contamination score is based on the fraction of single-copy genes that are observed more than once in a query genome. The following scores are acceptable for; High Quality Draft: < 5%, Medium Quality Draft: < 10%, Low Quality Draft: < 10%. Contamination must be below 5% for a SAG or MAG to be deposited into any of the public databases" ;
                                skos:example 0.01 .


###  https://w3id.org/mixs/0000073
<https://w3id.org/mixs/0000073> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Contamination Screening Parameters" ;
                                skos:definition "Specific parameters used in the decontamination sofware, such as reference database, coverage, and kmers. Combinations of these parameters may also be used, i.e. kmer and coverage, or reference database and kmer." ;
                                skos:example "kmer" .


###  https://w3id.org/mixs/0000074
<https://w3id.org/mixs/0000074> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Decontamination Software" ;
                                skos:definition "Tool(s) used in contamination screening." ;
                                skos:example "anvi'o" .


###  https://w3id.org/mixs/0000075
<https://w3id.org/mixs/0000075> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sorting Technology" ;
                                skos:definition "Method used to sort/isolate cells or particles of interest." ;
                                skos:example "optical manipulation" .


###  https://w3id.org/mixs/0000076
<https://w3id.org/mixs/0000076> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Single Cell Or Viral Particle Lysis Approach" ;
                                skos:definition "Method used to free DNA from interior of the cell(s) or particle(s)." ;
                                skos:example "enzymatic" .


###  https://w3id.org/mixs/0000077
<https://w3id.org/mixs/0000077> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Binning Parameters" ;
                                skos:definition "The parameters that have been applied during the extraction of genomes from metagenomic datasets." ;
                                skos:example "coverage" ,
                                             "kmer" .


###  https://w3id.org/mixs/0000078
<https://w3id.org/mixs/0000078> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Binning Software" ;
                                skos:definition "Tool(s) used for the extraction of genomes from metagenomic datasets, where possible include a product ID (PID) of the tool(s) used." ;
                                skos:example "MetaCluster-TA (RRID:SCR_004599), MaxBin (biotools:maxbin)" .


###  https://w3id.org/mixs/0000079
<https://w3id.org/mixs/0000079> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Reassembly Post Binning" ;
                                skos:definition "Has an assembly been performed on a genome bin extracted from a metagenomic assembly?" ;
                                skos:example "false"^^xsd:boolean .


###  https://w3id.org/mixs/0000080
<https://w3id.org/mixs/0000080> rdf:type owl:DatatypeProperty ;
                                rdfs:label "MAG Coverage Software" ;
                                skos:definition "Tool(s) used to determine the genome coverage if coverage is used as a binning parameter in the extraction of genomes from metagenomic datasets." ;
                                skos:example "bbmap" .


###  https://w3id.org/mixs/0000081
<https://w3id.org/mixs/0000081> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Viral Identification Software" ;
                                skos:definition "Tool(s) used for the identification of UViG as a viral genome, software or protocol name including version number, parameters, and cutoffs used." ;
                                skos:example "VirSorter; 1.0.4; Virome database, category 2" .


###  https://w3id.org/mixs/0000082
<https://w3id.org/mixs/0000082> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Predicted Genome Type" ;
                                skos:definition "Type of genome predicted for the UViG." ;
                                skos:example "dsDNA" .


###  https://w3id.org/mixs/0000083
<https://w3id.org/mixs/0000083> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Predicted Genome Structure" ,
                                           "non-segmented" ;
                                skos:definition "Expected structure of the viral genome." .


###  https://w3id.org/mixs/0000084
<https://w3id.org/mixs/0000084> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Detection Type" ;
                                skos:definition "Type of UViG detection." ;
                                skos:example "independent sequence (UViG)" .


###  https://w3id.org/mixs/0000085
<https://w3id.org/mixs/0000085> rdf:type owl:DatatypeProperty ;
                                rdfs:label "OTU Classification Approach" ;
                                skos:definition "Cutoffs and approach used when clustering species-level OTUs. Note that results from standard 95% ANI / 85% AF clustering should be provided alongside OTUs defined from another set of thresholds, even if the latter are the ones primarily used during the analysis." ;
                                skos:example "95% ANI;85% AF; greedy incremental clustering" .


###  https://w3id.org/mixs/0000086
<https://w3id.org/mixs/0000086> rdf:type owl:DatatypeProperty ;
                                rdfs:label "OTU Sequence Comparison Approach" ;
                                skos:definition "Tool and thresholds used to compare sequences when computing \"species-level\" OTUs." ;
                                skos:example "blastn;2.6.0+;e-value cutoff: 0.001" .


###  https://w3id.org/mixs/0000087
<https://w3id.org/mixs/0000087> rdf:type owl:DatatypeProperty ;
                                rdfs:label "OTU Database" ;
                                skos:definition "Reference database (i.e. sequences not generated as part of the current study) used to cluster new genomes in \"species-level\" OTUs, if any." ;
                                skos:example "NCBI Viral RefSeq;83" .


###  https://w3id.org/mixs/0000088
<https://w3id.org/mixs/0000088> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Tool Or Approach Used For Host Prediction" ;
                                skos:definition "Tool or approach used for host prediction." ;
                                skos:example "CRISPR spacer match" .


###  https://w3id.org/mixs/0000089
<https://w3id.org/mixs/0000089> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Host Prediction Estimated Accuracy" ;
                                skos:definition "For each tool or approach used for host prediction, estimated false discovery rates should be included, either computed de novo or from the literature." ;
                                skos:example "CRISPR spacer match: 0 or 1 mismatches, estimated 8% FDR at the host genus rank (Edwards et al. 2016 doi:10.1093/femsre/fuv048)" .


###  https://w3id.org/mixs/0000090
<https://w3id.org/mixs/0000090> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Relevant Standard Operating Procedures" ;
                                skos:definition "Standard operating procedures used in assembly and/or annotation of genomes, metagenomes or environmental sequences." ;
                                skos:example "http://press.igsb.anl.gov/earthmicrobiome/protocols-and-standards/its/" .


###  https://w3id.org/mixs/0000091
<https://w3id.org/mixs/0000091> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Relevant Electronic Resources" ;
                                skos:definition "A related resource that is referenced, cited, or otherwise associated to the sequence." ;
                                skos:example "http://www.earthmicrobiome.org/" .


###  https://w3id.org/mixs/0000092
<https://w3id.org/mixs/0000092> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Project Name" ;
                                skos:definition "Name of the project within which the sequencing was organized." ;
                                skos:example "Forest soil metagenome" .


###  https://w3id.org/mixs/0000111
<https://w3id.org/mixs/0000111> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sample Volume Or Weight For DNA Extraction" ;
                                skos:definition "Volume (ml) or mass (g) of total collected sample processed for DNA extraction. Note: total sample collected should be entered under the term Sample Size (MIXS:0000001)." ;
                                skos:example "1500 milliliter" .


###  https://w3id.org/mixs/0001107
<https://w3id.org/mixs/0001107> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Sample Name" ;
                                skos:definition "Sample Name is a name that you choose for the sample. It can have any format, but we suggest that you make it concise, unique and consistent within your lab, and as informative as possible. Every Sample Name from a single Submitter must be unique." ;
                                skos:example "ISDsoil1" .


###  https://w3id.org/mixs/0001320
<https://w3id.org/mixs/0001320> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Taxonomy ID of DNA Sample" ;
                                skos:definition "NCBI taxon id of the sample. Maybe be a single taxon or mixed taxa sample. Use `synthetic metagenome` for mock community/positive controls, or `blank sample` for negative controls." ;
                                skos:example "Gut Metagenome [NCBITaxon:749906]" .


###  https://w3id.org/mixs/0001321
<https://w3id.org/mixs/0001321> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Negative Control Type" ;
                                skos:definition "The substance or equipment used as a negative control in an investigation." .


###  https://w3id.org/mixs/0001322
<https://w3id.org/mixs/0001322> rdf:type owl:DatatypeProperty ;
                                rdfs:label "Positive Control Type" ;
                                skos:definition "The substance, mixture, product, or apparatus used to verify that a process which is part of an investigation delivers a true positive." .


#################################################################
#    Classes
#################################################################

###  http://purl.org/dc/terms/Agent
dcterms:Agent rdf:type owl:Class ;
              rdfs:comment "A person, group, organization, machine, software or other entity that can act. Membership in the dcterms:Agent class is determined by the capacity to act, even if not doing so in a specific context. To act: To participate in an event or process by contributing through behavior, operation, or an effect resulting from active participation — regardless of whether that contribution is intentional, volitional, or conscious." ;
              rdfs:label "Agent" ;
              skos:definition "A resource that acts or has the power to act." ;
              skos:example "Carl Linnaeus" ,
                           "ChatGPT" ,
                           "The El Yunque National Forest ARBIMON System" ,
                           "The National Science Foundation" ,
                           "The Terra Nova Expedition" .


###  http://purl.org/dc/terms/BibliographicResource
dcterms:BibliographicResource rdf:type owl:Class ;
                              rdfs:label "Bibliographic Resource" ;
                              skos:definition "A book, article, or other documentary resource." .


###  http://purl.org/dc/terms/Location
dcterms:Location rdf:type owl:Class ;
                 rdfs:label "Location" ;
                 skos:definition "A spatial region or named place." ;
                 skos:example "the municipality of San Carlos de Bariloche, Río Negro, Argentina" ,
                              "the place defined by a georeference" .


###  http://rs.tdwg.org/chrono/terms/ChronometricAge
chrono:ChronometricAge rdf:type owl:Class ;
                       rdfs:label "Chronometric Age" ;
                       skos:definition "An approximation of temporal position (in the sense conveyed by https://www.w3.org/TR/owl-time/#time:TemporalPosition) that is supported by evidence." ;
                       skos:example "A maximum age associated with a specimen derived from K-Ar dating applied to a proximal volcanic tuff found stratigraphically below the specimen" ,
                                    "An age of a specimen based on what is reported in legacy collections data" ,
                                    "An age range associated with a specimen derived from a ceramics analysis based on other materials found in the same stratum" ,
                                    "An age range associated with a specimen derived from an AMS dating assay applied to an oyster shell in the same stratum" ,
                                    "An age range of a specimen based on its biostratigraphic context" .


###  http://rs.tdwg.org/dwc/terms/Assertion
dwc:Assertion rdf:type owl:Class ;
              rdfs:label "Assertion" ;
              skos:definition "A statement about an rdfs:Resource (http://www.w3.org/2000/01/rdf-schema#Resource)." ;
              skos:example "surface water temperature in Celsius" ,
                           "the number of placental scars" ,
                           "the weight of a dwc:Organism in grams" .


###  http://rs.tdwg.org/dwc/terms/Event
dwc:Event rdf:type owl:Class ;
          rdfs:label "Event" ;
          skos:definition "An action, process, or set of circumstances occurring at a dcterms:Location during a period of time." ;
          skos:example "a biotic survey" ,
                       "a bird observation" ,
                       "a camera trap image capture" ,
                       "a material collecting event" ,
                       "an organism occurrence" .


###  http://rs.tdwg.org/dwc/terms/GeologicalContext
dwc:GeologicalContext rdf:type owl:Class ;
                      rdfs:label "Geological Context" ;
                      skos:definition "A set of geological designations, such as stratigraphy, that qualifies a dcterms:Location." ;
                      skos:example "a particular lithostratigraphic layer" ,
                                   "a specific chronostratigraphic unit" .


###  http://rs.tdwg.org/dwc/terms/Identification
dwc:Identification rdf:type owl:Class ;
                   rdfs:label "Identification" ;
                   skos:definition "A classification of a resource according to a classification scheme." ;
                   skos:example "a nomenclatural act designating a specimen as a holotype" ,
                                "a subspecies determination of an organism" .


###  http://rs.tdwg.org/dwc/terms/MaterialEntity
dwc:MaterialEntity rdf:type owl:Class ;
                   rdfs:label "Material Entity" ;
                   skos:definition "An entity that can be identified, exist for some period of time, and consist in whole or in part of physical matter while it exists." ;
                   skos:example "a flower on a plant specimen" ,
                                "a fossil within a rock" ,
                                "a pollen grain" ,
                                "a rock containing fossils" ,
                                "a specific water sample" ,
                                "a subset of the contents of a trawl" ,
                                "an herbarium sheet with its attached plant specimen" ,
                                "an isolated molecule of DNA" ,
                                "the body of a fish" ,
                                "the entire contents of a trawl" ,
                                "the stomach contents of a fish" .


###  http://rs.tdwg.org/dwc/terms/Media
dwc:Media rdf:type owl:Class ;
          rdfs:label "Media" ;
          skos:definition "A dcmi:MediaType or other media type with other entities as subject matter." .


###  http://rs.tdwg.org/dwc/terms/MolecularProtocol
dwc:MolecularProtocol rdf:type owl:Class ;
                      rdfs:label "Molecular Protocol" ;
                      skos:definition "A protocol used to derive and identify a dwc:NucleotideSequence from an ac:MaterialEntity." ;
                      skos:example "a high-throughput amplicon sequencing protocol targeting 16S rRNA" ,
                                   "a shotgun metagenomics pipeline for microbial community profiling" ,
                                   "a standard DNA barcoding workflow using Sanger sequencing" .


###  http://rs.tdwg.org/dwc/terms/NucleotideAnalysis
dwc:NucleotideAnalysis rdf:type owl:Class ;
                       rdfs:label "Nucleotide Analysis" ;
                       skos:definition "A link between a dwc:NucleotideSequence and a dwc:Event and a dwc:MaterialEntity from which it was derived, using a specified dwc:Protocol." .


###  http://rs.tdwg.org/dwc/terms/NucleotideSequence
dwc:NucleotideSequence rdf:type owl:Class ;
                       rdfs:label "Nucleotide Sequence" ;
                       skos:definition "A digital representation of a nucleotide sequence." .


###  http://rs.tdwg.org/dwc/terms/Occurrence
dwc:Occurrence rdf:type owl:Class ;
               rdfs:label "Occurrence" ;
               skos:definition "A state of a dwc:Organism in a dwc:Event." ;
               skos:example "a fungus in Central Park in the summer of 1929" ,
                            "a virus in a plant leaf in the New York Botanical Garden at 15:29 on 2014-10-23" ,
                            "a wolf pack on the shore of Kluane Lake in 1988" .


###  http://rs.tdwg.org/dwc/terms/Organism
dwc:Organism rdf:type owl:Class ;
             rdfs:label "Organism" ;
             skos:definition "A particular organism or defined group of organisms considered to be taxonomically homogeneous." ;
             skos:example "a specific bird" ,
                          "a specific instance of a bacterial culture" ,
                          "a specific wolf pack" .


###  http://rs.tdwg.org/dwc/terms/OrganismInteraction
dwc:OrganismInteraction rdf:type owl:Class ;
                        rdfs:label "Organism Interaction" ;
                        skos:definition "An interaction between two dwc:Organisms during a dwc:Event." ;
                        skos:example "a Mallophora ruficauda hunting an Apis mellifera in flight" ,
                                     "a bee visiting a flower" ,
                                     "a female spider mating with a male spider" ,
                                     "a lion cub nursing from its mother" ,
                                     "a mosquito sucking blood from a chimpanzee's arm" ,
                                     "a slug eating a fungus growing on decomposing stump" ,
                                     "a viral infection in a plant" .


###  http://rs.tdwg.org/dwc/terms/OrganismRelationship
dwc:OrganismRelationship rdf:type owl:Class ;
                         rdfs:label "Organism Relationship" ;
                         skos:definition "A dwc:ResourceRelationship of one dwc:Organism to another dwc:Organism." ;
                         skos:example "an instance of a dwc:Organism is the mother of another instance of a dwc:Organism" .


###  http://rs.tdwg.org/dwc/terms/Protocol
dwc:Protocol rdf:type owl:Class ;
             rdfs:label "Protocol" ;
             skos:definition "A method used during an action." ;
             skos:example "a Bayesian phylogenetic inference method" ,
                          "a linear regression model to estimate body mass from skeletal measurements" ,
                          "a pitfall trap method for sampling ground-dwelling arthropods" ,
                          "a point-radius georeferencing method" .


###  http://rs.tdwg.org/dwc/terms/Provenance
dwc:Provenance rdf:type owl:Class ;
               rdfs:label "Provenance" ;
               skos:definition "Information about an entity’s origins." .


###  http://rs.tdwg.org/dwc/terms/ResourceRelationship
dwc:ResourceRelationship rdf:type owl:Class ;
                         rdfs:label "Resource Relationship" ;
                         skos:definition "A relationship of one rdfs:Resource (http://www.w3.org/2000/01/rdf-schema#Resource) to another." ;
                         skos:example "a dwc:MaterialEntity is a subsample of another dwc:MaterialEntity" ,
                                      "a uniquely identified dwc:Occurrence represents the same dwc:Occurrence as another uniquely identified dwc:Occurrence" ,
                                      "an instance of a dwc:Organism is the mother of another instance of a dwc:Organism" .


###  http://rs.tdwg.org/dwc/terms/Survey
dwc:Survey rdf:type owl:Class ;
           rdfs:label "Survey" ;
           skos:definition "A biotic survey or inventory." ;
           skos:example "a botanical survey of a protected area to assess native and invasive plant species" ,
                        "a camera trap deployment in a rainforest to monitor large mammals" ,
                        "a coverboard survey for reptiles in forested environments" ,
                        "a frog call survey in wetlands across breeding seasons" ,
                        "a habitat- or ecosystem-level survey (e.g., coral reef health assessment, forest biodiversity assessment)" ,
                        "a macroinvertebrate sampling in a freshwater stream to assess water quality" ,
                        "a pollinator survey in an agricultural landscape" ,
                        "a wetland vegetation mapping" ,
                        "an environmental impact assessment (e.g., pre-construction biological baseline survey for a wind farm project)" .


###  http://rs.tdwg.org/dwc/terms/SurveyTarget
dwc:SurveyTarget rdf:type owl:Class ;
                 rdfs:label "Survey Target" ;
                 skos:definition "An intended scope for dwc:Occurrences in an eco:Survey." ;
                 skos:example "Oncorhynchus mykiss and Oncorhynchus clarkii (only)" ,
                              "all bird species" ,
                              "all bird species except Larus gulls, fulmars and kittiwakes" ,
                              "all total lengths except < 12 inches" ,
                              "reproductive female Ctenomys sociabilis (only)" .


###  http://rs.tdwg.org/dwc/terms/UsagePolicy
dwc:UsagePolicy rdf:type owl:Class ;
                rdfs:label "Usage Policy" ;
                skos:definition "Information about rights, usage, and attribution statements applicable to an entity." .


###  http://www.w3.org/ns/adms#Identifier
adms:Identifier rdf:type owl:Class ;
                rdfs:label "Identifier" .


